---
import { buildMetaDescription } from '@utils/seo';

interface Props {
  type: 'organization' | 'website' | 'product' | 'collection' | 'breadcrumb' | 'faq' | 'itemlist' | 'localbusiness';
  data?: Record<string, unknown>;
}

const { type, data = {} } = Astro.props;
const siteUrl = 'https://igetvapeshub.com';

function getSchema() {
  switch (type) {
    case 'organization':
      return {
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'IGET Vapes Original',
        alternateName: 'IGET Vape Hub',
        url: siteUrl,
        logo: `${siteUrl}/images/logo.svg`,
        description: buildMetaDescription('Adult-focused online store for genuine IGET and Alibarbar vape products in Australia. Curated ranges, clear checkout rules, and Australia-wide delivery support.'),
        email: 'info@igetvapeshub.com',
        contactPoint: {
          '@type': 'ContactPoint',
          contactType: 'customer support',
          email: 'info@igetvapeshub.com',
          areaServed: 'AU',
          availableLanguage: ['English'],
          url: `${siteUrl}/contact`,
        },
        areaServed: {
          '@type': 'Country',
          name: 'Australia',
        },
        knowsAbout: ['IGET vapes', 'Alibarbar vapes', 'Disposable vapes', 'Pod vape systems', 'Australia-wide vape delivery'],
      };
    case 'website':
      return {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'IGET Vapes Original',
        alternateName: 'IGET Vape Hub',
        url: siteUrl,
        description: buildMetaDescription('Shop genuine IGET and Alibarbar vapes online in Australia. Compare high-puff devices, S3 pods, flavour guides, and delivery locations from one adult-focused store.'),
        inLanguage: 'en-AU',
        publisher: {
          '@type': 'Organization',
          name: 'IGET Vapes Original',
          url: siteUrl,
        },
      };
    case 'product':
      return {
        '@context': 'https://schema.org',
        '@type': 'Product',
        name: data.name,
        image: data.image,
        description: buildMetaDescription(String(data.description ?? '')),
        sku: data.sku ?? '',
        mpn: data.mpn ?? '',
        brand: { '@type': 'Brand', name: data.brand ?? 'IGET' },
        category: data.category ?? 'Disposable Vapes',
        offers: {
          '@type': 'Offer',
          price: data.price,
          priceCurrency: 'AUD',
          availability: data.inStock ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
          url: data.url,
          seller: { '@type': 'Organization', name: 'IGET Vapes Original' },
          shippingDetails: {
            '@type': 'OfferShippingDetails',
            shippingDestination: { '@type': 'DefinedRegion', addressCountry: 'AU' },
            deliveryTime: {
              '@type': 'ShippingDeliveryTime',
              handlingTime: { '@type': 'QuantitativeValue', minValue: 1, maxValue: 2, unitCode: 'DAY' },
              transitTime: { '@type': 'QuantitativeValue', minValue: 2, maxValue: 7, unitCode: 'DAY' },
            },
          },
          hasMerchantReturnPolicy: {
            '@type': 'MerchantReturnPolicy',
            applicableCountry: 'AU',
            returnPolicyCategory: 'https://schema.org/MerchantReturnNotPermitted',
          },
        },
        aggregateRating: {
          '@type': 'AggregateRating',
          ratingValue: data.rating ?? '4.9',
          bestRating: '5',
          worstRating: '1',
          reviewCount: data.reviewCount ?? '115',
        },
      };
    case 'collection':
      return {
        '@context': 'https://schema.org',
        '@type': 'CollectionPage',
        name: data.name,
        description: buildMetaDescription(String(data.description ?? '')),
        url: data.url,
        isPartOf: { '@type': 'WebSite', name: 'IGET Vapes Original', url: siteUrl },
      };
    case 'breadcrumb':
      return {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: (data.items as Array<{ name: string; url: string }>)?.map((item, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: item.name,
          item: item.url,
        })),
      };
    case 'faq':
      return {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: (data.questions as Array<{ q: string; a: string }>)?.map(faq => ({
          '@type': 'Question',
          name: faq.q,
          acceptedAnswer: {
            '@type': 'Answer',
            text: faq.a,
          },
        })),
      };
    case 'itemlist':
      return {
        '@context': 'https://schema.org',
        '@type': 'ItemList',
        name: data.name,
        description: buildMetaDescription(String(data.description ?? '')),
        numberOfItems: (data.items as unknown[])?.length ?? 0,
        itemListElement: (data.items as Array<{ name: string; url: string; image?: string; price?: number; position?: number }>)?.map((item, i) => ({
          '@type': 'ListItem',
          position: item.position ?? i + 1,
          name: item.name,
          url: item.url,
          ...(item.image ? { image: item.image } : {}),
        })),
      };
    case 'localbusiness':
      return {
        '@context': 'https://schema.org',
        '@type': 'OnlineStore',
        name: 'IGET Vapes Original',
        url: siteUrl,
        logo: `${siteUrl}/images/logo.svg`,
        description: buildMetaDescription('Adult-focused online store for genuine IGET and Alibarbar products with Australia-wide shipping, mix and match bundles, and email-based support.'),
        email: 'info@igetvapeshub.com',
        currenciesAccepted: 'AUD',
        paymentAccepted: 'Bank Transfer, PayID, Bitcoin',
        priceRange: '$30 - $65',
        areaServed: {
          '@type': 'Country',
          name: 'Australia',
        },
        contactPoint: {
          '@type': 'ContactPoint',
          contactType: 'customer support',
          email: 'info@igetvapeshub.com',
          areaServed: 'AU',
          availableLanguage: ['English'],
          url: `${siteUrl}/contact`,
        },
        aggregateRating: {
          '@type': 'AggregateRating',
          ratingValue: '4.9',
          bestRating: '5',
          reviewCount: '150',
        },
      };
    default:
      return null;
  }
}

const schema = getSchema();
---

{schema && (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
)}
