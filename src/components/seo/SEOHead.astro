---
import { buildMetaDescription, buildMetaTitle } from '@utils/seo';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'product' | 'article';
  noindex?: boolean;
  keywords?: string;
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description = 'Shop genuine IGET and Alibarbar vapes online in Australia with curated ranges, mix and match deals, and fast delivery nationwide.',
  image = '/images/categories/jnr-cruiser.webp',
  canonical,
  type = 'website',
  noindex = false,
  keywords = 'IGET vapes Australia, Alibarbar Australia, buy vape online Australia, vape delivery Australia',
  publishedTime,
  modifiedTime,
} = Astro.props;

const siteUrl = 'https://igetvapeshub.com';
const siteName = 'IGET Vapes Original';
const metaTitle = buildMetaTitle(title);
const metaDescription = buildMetaDescription(description);
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const ogImage = image.startsWith('http') ? image : new URL(image, siteUrl).href;
---

<!-- Primary Meta -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{metaTitle}</title>
<meta name="description" content={metaDescription} />
<meta name="keywords" content={keywords} />
<meta name="author" content={siteName} />
<meta name="publisher" content={siteName} />
<meta name="application-name" content={siteName} />
<link rel="canonical" href={canonicalUrl} />
{noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}
<meta name="theme-color" content="#111c24" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />

<!-- Geo / Language targeting -->
<meta name="geo.region" content="AU" />
<meta name="geo.placename" content="Australia" />
<meta name="language" content="en-AU" />
<meta name="content-language" content="en-AU" />
<link rel="alternate" hreflang="en-au" href={canonicalUrl} />
<link rel="alternate" hreflang="x-default" href={canonicalUrl} />

<!-- AI / LLM / AEO Discovery -->
<meta name="citation_title" content={metaTitle} />
<meta name="citation_author" content={siteName} />
<meta name="citation_public_url" content={canonicalUrl} />
<meta name="subject" content={metaDescription} />
<meta name="coverage" content="Australia" />
<meta name="distribution" content="Global" />
<meta name="rating" content="General" />
<meta name="referrer" content="no-referrer-when-downgrade" />
<link rel="author" href={`${siteUrl}/about`} />

<!-- LLM Discovery -->
<link rel="alternate" type="text/plain" href={`${siteUrl}/llms.txt`} title="LLM Information" />

<!-- Preconnect for performance -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet" />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={metaTitle} />
<meta property="og:description" content={metaDescription} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${metaTitle} — ${siteName}`} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content="en_AU" />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={metaTitle} />
<meta name="twitter:description" content={metaDescription} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={`${metaTitle} — ${siteName}`} />
