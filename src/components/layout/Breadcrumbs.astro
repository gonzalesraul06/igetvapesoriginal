---
interface BreadcrumbItem {
  name: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
const siteUrl = 'https://igetvapeshub.com';
const breadcrumbEntries = [
  { name: 'Home', url: siteUrl },
  ...items.map((item) => ({
    name: item.name,
    url: new URL(item.href ?? Astro.url.pathname, siteUrl).href,
  })),
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbEntries.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    item: item.url,
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

<nav aria-label="Breadcrumb" class="mb-6 text-xs sm:text-sm text-text-muted">
  <ol class="breadcrumb-shell">
    <li>
      <a href="/" class="inline-flex items-center rounded-full px-2.5 py-1 hover:text-text">Home</a>
    </li>
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        <span aria-hidden="true" class="text-text-light">/</span>
        {item.href && i < items.length - 1 ? (
          <a href={item.href} class="inline-flex items-center rounded-full px-2.5 py-1 hover:text-text">{item.name}</a>
        ) : (
          <span aria-current="page" class="rounded-full bg-white/55 px-2.5 py-1 font-medium text-text">{item.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
