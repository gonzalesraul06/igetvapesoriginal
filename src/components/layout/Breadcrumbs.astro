---
interface BreadcrumbItem {
  name: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-5 text-xs sm:text-sm text-text-muted">
  <ol class="flex flex-wrap items-center gap-1.5">
    <li>
      <a href="/" class="inline-flex items-center rounded-md px-1 py-0.5 hover:text-accent hover:bg-surface">Home</a>
    </li>
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        <span aria-hidden="true" class="text-text-light">/</span>
        {item.href && i < items.length - 1 ? (
          <a href={item.href} class="inline-flex items-center rounded-md px-1 py-0.5 hover:text-accent hover:bg-surface">{item.name}</a>
        ) : (
          <span aria-current="page" class="font-medium text-text">{item.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
