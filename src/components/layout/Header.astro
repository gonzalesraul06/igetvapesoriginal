---
import { productCategories, topMenuLinks } from '@data/navigation';
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-30 bg-surface/95 backdrop-blur-sm border-b border-gray-700">
  <!-- Top bar with shipping info (desktop) -->
  <div class="hidden lg:flex items-center justify-center px-4 py-1.5 bg-accent/10 border-b border-gray-700/50 text-xs">
    <span class="text-accent font-medium">🚚 $30 Flat Rate Shipping Australia-Wide — Fast 1-3 Business Day Delivery</span>
  </div>

  <!-- Main header bar -->
  <div class="flex items-center justify-between px-4 py-3 max-w-screen-2xl mx-auto">
    <!-- Left: Hamburger + Logo -->
    <div class="flex items-center gap-3">
      <!-- Hamburger (mobile) -->
      <button id="menu-toggle" class="lg:hidden p-2 text-gray-300 hover:text-white" aria-label="Toggle menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>

      <!-- Logo (visible on mobile only, desktop has sidebar logo) -->
      <a href="/" class="lg:hidden">
        <img src="/images/logo.svg" alt="IGET Vape Original — Buy vapes online Australia" class="h-10 w-auto" loading="eager" />
      </a>
    </div>

    <!-- Center: Desktop navigation links -->
    <nav class="hidden lg:flex items-center gap-6">
      {topMenuLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium transition-colors',
            currentPath === link.href ? 'text-accent' : 'text-gray-300 hover:text-white',
          ]}
        >
          {link.name}
        </a>
      ))}
    </nav>

    <!-- Right icons -->
    <div class="flex items-center gap-3">
      <!-- Account -->
      <a href="/account" class="p-2 text-gray-300 hover:text-white transition-colors" aria-label="My Account">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
      </a>

      <!-- Cart -->
      <button id="cart-toggle" class="p-2 text-gray-300 hover:text-white relative transition-colors" aria-label="Shopping Cart">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
        </svg>
        <span id="cart-count" class="absolute -top-1 -right-1 bg-accent text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center hidden">0</span>
      </button>
    </div>
  </div>
</header>
