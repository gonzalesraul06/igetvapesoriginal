---
import { topMenuLinks } from '@data/navigation';
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-30 bg-surface border-b border-border">
  <div class="flex items-center justify-between px-4 py-3">
    <!-- Left: Account icon -->
    <a href="/account" class="p-2 text-gray-400 hover:text-white transition-colors" aria-label="My Account">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
    </a>

    <!-- Center: Site name -->
    <a href="/" class="text-white font-bold text-base lg:text-lg tracking-wide hover:text-accent transition-colors">
      IGET-Vapes Australia
    </a>

    <!-- Right: Hamburger + Cart -->
    <div class="flex items-center gap-1">
      <button id="menu-toggle" class="lg:hidden p-2 text-gray-400 hover:text-white transition-colors" aria-label="Toggle menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
      <button id="cart-toggle" class="p-2 text-gray-400 hover:text-white relative transition-colors" aria-label="Shopping Cart">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
        </svg>
        <span id="cart-count" class="absolute -top-1 -right-1 bg-accent text-white text-[10px] font-bold rounded-full w-4 h-4 flex items-center justify-center hidden">0</span>
      </button>
    </div>
  </div>

  <!-- Desktop nav links -->
  <nav class="hidden lg:flex items-center justify-center gap-6 px-4 py-2 border-t border-border">
    {topMenuLinks.map(link => (
      <a
        href={link.href}
        class:list={[
          'text-xs font-medium uppercase tracking-wider transition-colors',
          currentPath === link.href ? 'text-accent' : 'text-gray-400 hover:text-white',
        ]}
      >
        {link.name}
      </a>
    ))}
  </nav>
</header>
