---
import { topMenuLinks, productCategories } from '@data/navigation';
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 bg-white border-b border-gray-200">
  <div class="px-4 py-3 max-w-[1400px] mx-auto w-full flex items-center justify-between">
    <div class="flex items-center lg:hidden relative">
      <button id="mobile-menu-toggle" class="p-2 text-gray-800 hover:text-gray-900 transition-colors" aria-label="Toggle menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <a href="/" class="flex-shrink-0 flex items-center justify-center text-gray-900 font-bold text-xl lg:text-2xl tracking-wide hover:text-accent transition-colors mx-auto lg:mx-0">
      IGET-Vapes Australia
    </a>

    <div class="flex items-center gap-2 lg:gap-4">
      <a href="/account" class="hidden lg:flex p-2 text-gray-800 hover:text-gray-900 transition-colors" aria-label="My Account">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />      
        </svg>
      </a>

      <button id="cart-toggle" class="p-2 text-gray-800 hover:text-gray-900 relative transition-colors" aria-label="Shopping Cart">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />    
        </svg>
        <span id="cart-count" class="absolute -top-1 -right-1 bg-red-500 text-white text-[10px] font-bold rounded-full w-5 h-5 flex items-center justify-center hidden">0</span>
      </button>
    </div>
  </div>

  <nav class="hidden lg:block border-t border-gray-100 bg-gray-50">
    <div class="max-w-[1400px] mx-auto w-full px-4 flex items-center justify-center flex-wrap gap-x-6 gap-y-2 py-3">
      {productCategories.map(cat => (
        <a
          href={cat.href}
          class:list={[
            'text-[13px] font-bold uppercase tracking-wider transition-colors text-center',     
            currentPath.startsWith(cat.href) ? 'text-blue-600' : 'text-gray-800 hover:text-blue-500',
          ]}
        >
          {cat.name.replace(/\d+\sPUFFS|SAVE$/, '')} 
          <span class="text-[10px] font-normal text-gray-500 block -mt-1">{cat.name.match(/\d+\sPUFFS|SAVE/)?.[0] || ''}</span>
        </a>
      ))}
    </div>
  </nav>

  <nav class="hidden lg:flex items-center justify-center gap-8 px-4 py-2 border-t border-gray-100 bg-white">
    {topMenuLinks.map(link => (
      <a
        href={link.href}
        class:list={[
          'text-[11px] font-semibold uppercase tracking-widest transition-colors',     
          currentPath === link.href ? 'text-blue-600' : 'text-gray-500 hover:text-gray-900',
        ]}
      >
        {link.name}
      </a>
    ))}
  </nav>
</header>

<div id="mobile-menu-overlay" class="fixed inset-0 bg-black/60 z-[45] hidden lg:hidden backdrop-blur-sm transition-opacity opacity-0"></div>

<nav id="mobile-sidebar-nav" class="fixed top-0 left-0 bottom-0 z-[50] w-[80%] max-w-sm bg-white border-r border-gray-200 transform -translate-x-full transition-transform duration-300 flex flex-col lg:hidden shadow-2xl">
  <div class="flex items-center justify-between p-4 border-b border-gray-100">
    <span class="font-bold text-gray-900 text-lg">Menu</span>
    <button id="close-mobile-menu" class="p-2 text-gray-500 hover:text-gray-900">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
  
  <div class="flex-1 overflow-y-auto">
    <div class="p-4 border-b border-gray-100">
      <ul class="space-y-4">
        {productCategories.map(cat => (
          <li>
            <a
              href={cat.href}
              class:list={[
                'block font-bold text-sm tracking-wide transition-colors',
                currentPath.startsWith(cat.href)
                  ? 'text-blue-600'
                  : 'text-gray-800',
              ]}
            >
              {cat.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
    
    <div class="p-4">
      <ul class="space-y-3">
        {topMenuLinks.map(link => (
          <li>
            <a href={link.href} class="block text-sm text-gray-600 font-medium hover:text-blue-600">
              {link.name}
            </a>
          </li>
        ))}
        <li class="pt-4 border-t border-gray-100">
            <a href="/account" class="block text-sm text-gray-900 font-bold hover:text-blue-600">
              Account / Log In
            </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<script>
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const closeBtn = document.getElementById('close-mobile-menu');
  const sidebar = document.getElementById('mobile-sidebar-nav');
  const overlay = document.getElementById('mobile-menu-overlay');

  function openSidebar() {
    sidebar?.classList.remove('-translate-x-full');
    overlay?.classList.remove('hidden');
    setTimeout(() => {
      overlay?.classList.remove('opacity-0');
    }, 10);
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    sidebar?.classList.add('-translate-x-full');
    overlay?.classList.add('opacity-0');
    setTimeout(() => {
      overlay?.classList.add('hidden');
    }, 300);
    document.body.style.overflow = '';
  }

  toggleBtn?.addEventListener('click', openSidebar);
  closeBtn?.addEventListener('click', closeSidebar);
  overlay?.addEventListener('click', closeSidebar);
</script>
