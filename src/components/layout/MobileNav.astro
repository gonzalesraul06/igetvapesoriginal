---
const currentPath = Astro.url.pathname;

const navItems = [
  { name: 'Home', href: '/', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { name: 'Shop', href: '/products/jnr-cruiser', icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z' },
  { name: 'Deals', href: '/mix-and-match', icon: 'M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z' },
  { name: 'Cart', href: '#cart', icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z' },
  { name: 'Menu', href: '#menu', icon: 'M4 6h16M4 12h16M4 18h16' },
];
---

<nav aria-label="Mobile quick navigation" class="fixed bottom-0 left-0 right-0 z-30 lg:hidden safe-area-bottom" style="background: rgba(255,255,255,0.92); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-top: 1px solid rgba(0,0,0,0.06); box-shadow: 0 -1px 12px rgba(0,0,0,0.04);">
  <div class="flex items-center justify-around py-1 px-1">
    {navItems.map(item => {
      const isCart = item.href === '#cart';
      const isMenu = item.href === '#menu';
      const isActive = !isCart && !isMenu && (currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)));

      return isCart ? (
        <button
          class="mobile-cart-btn flex min-h-[48px] flex-col items-center justify-center gap-0.5 px-3 py-1.5 text-[10px] text-text-muted hover:text-accent transition-colors duration-200 relative"
          aria-label="Open Cart"
        >
          <svg class="w-[22px] h-[22px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
          </svg>
          <span class="font-semibold tracking-wide">{item.name}</span>
          <span id="mobile-cart-count" class="absolute -top-0.5 right-1 bg-accent text-white text-[9px] font-bold w-4 h-4 flex items-center justify-center hidden" style="border-radius: var(--radius-full);">0</span>
        </button>
      ) : isMenu ? (
        <button
          class="mobile-nav-menu-btn flex min-h-[48px] flex-col items-center justify-center gap-0.5 px-3 py-1.5 text-[10px] text-text-muted hover:text-accent transition-colors duration-200"
          aria-label="Open Menu"
        >
          <svg class="w-[22px] h-[22px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
          </svg>
          <span class="font-semibold tracking-wide">{item.name}</span>
        </button>
      ) : (
        <a
          href={item.href}
          class:list={[
            'flex min-h-[48px] flex-col items-center justify-center gap-0.5 px-3 py-1.5 text-[10px] transition-colors duration-200 font-semibold tracking-wide',
            isActive ? 'text-accent' : 'text-text-muted hover:text-accent',
          ]}
          aria-current={isActive ? 'page' : undefined}
        >
          <svg class="w-[22px] h-[22px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
          </svg>
          <span>{item.name}</span>
        </a>
      );
    })}
  </div>
</nav>

<script>
  document.querySelectorAll('.mobile-cart-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('cart-toggle')?.click();
    });
  });

  document.querySelectorAll('.mobile-nav-menu-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('mobile-menu-toggle')?.click();
    });
  });

  // Sync cart count to mobile nav
  const observer = new MutationObserver(() => {
    const desktopCount = document.getElementById('cart-count');
    const mobileCount = document.getElementById('mobile-cart-count');
    if (desktopCount && mobileCount) {
      mobileCount.textContent = desktopCount.textContent ?? '0';
      if (desktopCount.classList.contains('hidden')) {
        mobileCount.classList.add('hidden');
      } else {
        mobileCount.classList.remove('hidden');
      }
    }
  });

  const cartCountEl = document.getElementById('cart-count');
  if (cartCountEl) {
    observer.observe(cartCountEl, { attributes: true, childList: true, characterData: true });
  }
</script>
