---
const currentPath = Astro.url.pathname;

const navItems = [
  { name: 'Home', href: '/', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { name: 'Shop', href: '/products/jnr-cruiser', icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z' },
  { name: 'Deals', href: '/mix-and-match', icon: 'M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z' },
  { name: 'Cart', href: '#cart', icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z' },
  { name: 'Menu', href: '#menu', icon: 'M4 6h16M4 12h16M4 18h16' },
];
---

<nav aria-label="Mobile quick navigation" class="mobile-bottom-nav fixed bottom-0 left-0 right-0 z-30 lg:hidden safe-area-bottom">
  <div class="grid grid-cols-5 gap-1 px-2 py-2">
    {navItems.map((item) => {
      const isCart = item.href === '#cart';
      const isMenu = item.href === '#menu';
      const isActive = !isCart && !isMenu && (currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)));

      return isCart ? (
        <button class="mobile-cart-btn mobile-nav-link relative min-h-[3.55rem] flex-col gap-1 text-[0.66rem]" aria-label="Open cart">
          <svg class="h-[1.2rem] w-[1.2rem]" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
          </svg>
          <span>{item.name}</span>
          <span id="mobile-cart-count" class="absolute right-3 top-1.5 hidden min-h-[1rem] min-w-[1rem] items-center justify-center rounded-full bg-accent px-1 text-[0.55rem] font-bold text-white">0</span>
        </button>
      ) : isMenu ? (
        <button class="mobile-nav-menu-btn mobile-nav-link min-h-[3.55rem] flex-col gap-1 text-[0.66rem]" aria-label="Open menu">
          <svg class="h-[1.2rem] w-[1.2rem]" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
          </svg>
          <span>{item.name}</span>
        </button>
      ) : (
        <a
          href={item.href}
          class:list={['mobile-nav-link min-h-[3.55rem] flex-col gap-1 text-[0.66rem]', isActive && 'is-active']}
          aria-current={isActive ? 'page' : undefined}
        >
          <svg class="h-[1.2rem] w-[1.2rem]" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
          </svg>
          <span>{item.name}</span>
        </a>
      );
    })}
  </div>
</nav>

<script>
  document.querySelectorAll('.mobile-cart-btn').forEach((button) => {
    button.addEventListener('click', () => {
      document.getElementById('cart-toggle')?.click();
    });
  });

  document.querySelectorAll('.mobile-nav-menu-btn').forEach((button) => {
    button.addEventListener('click', () => {
      document.getElementById('mobile-menu-toggle')?.click();
    });
  });

  const observer = new MutationObserver(() => {
    const desktopCount = document.getElementById('cart-count');
    const mobileCount = document.getElementById('mobile-cart-count');
    if (!desktopCount || !mobileCount) return;
    mobileCount.textContent = desktopCount.textContent ?? '0';
    mobileCount.classList.toggle('hidden', desktopCount.classList.contains('hidden'));
  });

  const cartCountEl = document.getElementById('cart-count');
  if (cartCountEl) {
    observer.observe(cartCountEl, { attributes: true, childList: true, characterData: true });
  }
</script>
