---
import { productCategories, footerSupport, footerService, siteConfig } from '@data/navigation';
---

<footer class="bg-surface border-t border-gray-700 mt-12">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Main footer grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand Column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="inline-block mb-4">
          <img src="/images/logo.svg" alt="IGET Vape Original — Australia's trusted vape shop" class="h-12 w-auto" loading="lazy" />
        </a>
        <p class="text-gray-400 text-sm leading-relaxed mb-4">{siteConfig.tagline}</p>
        <div class="space-y-2">
          <div class="flex items-center gap-2 text-sm text-gray-400">
            <svg class="w-4 h-4 text-green-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>$30 Flat Rate Shipping</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-400">
            <svg class="w-4 h-4 text-green-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>1-3 Day Delivery Australia-Wide</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-400">
            <svg class="w-4 h-4 text-green-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>100% Authentic Products</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-400 mt-3">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@igetvapeshub.com" class="hover:text-accent transition-colors">info@igetvapeshub.com</a>
          </div>
        </div>
      </div>

      <!-- Shop Categories -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Shop</h3>
        <ul class="space-y-2.5">
          {productCategories.slice(0, 7).map(cat => (
            <li>
              <a href={cat.href} class="text-gray-400 hover:text-accent text-sm transition-colors">{cat.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Customer Support -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Customer Support</h3>
        <ul class="space-y-2.5">
          {footerSupport.map(link => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-accent text-sm transition-colors">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Customer Service -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Customer Service</h3>
        <ul class="space-y-2.5">
          {footerService.map(link => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-accent text-sm transition-colors">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-gray-700">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <a href="/">
            <img src="/images/logo.svg" alt="IGET Vape Original" class="h-9 w-auto opacity-60 hover:opacity-90 transition-opacity" loading="lazy" />
          </a>
          <p class="text-gray-500 text-xs">&copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.</p>
        </div>
        <div class="flex flex-wrap gap-4 text-xs">
          <a href="/about" class="text-gray-500 hover:text-gray-300 transition-colors">About</a>
          <a href="/contact" class="text-gray-500 hover:text-gray-300 transition-colors">Contact</a>
          <a href="/privacy-policy" class="text-gray-500 hover:text-gray-300 transition-colors">Privacy Policy</a>
          <a href="/terms-and-conditions" class="text-gray-500 hover:text-gray-300 transition-colors">Terms & Conditions</a>
          <a href="/shipping-policy" class="text-gray-500 hover:text-gray-300 transition-colors">Shipping</a>
        </div>
      </div>
    </div>
  </div>
</footer>
