---
import { footerSupport, footerService, siteConfig } from '@data/navigation';
---

<footer class="bg-surface border-t border-border mt-12">
  <div class="max-w-5xl mx-auto px-4 py-10">
    <!-- Two-column footer matching live site -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
      <!-- Customer Support -->
      <div>
        <h3 class="text-gray-900 font-bold text-sm uppercase tracking-wider mb-4">Customer Support</h3>
        <ul class="space-y-2.5">
          {footerSupport.map(link => (
            <li>
              <a href={link.href} class="text-gray-600 hover:text-accent text-sm transition-colors">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Customer Service -->
      <div>
        <h3 class="text-gray-900 font-bold text-sm uppercase tracking-wider mb-4">Customer Service</h3>
        <ul class="space-y-2.5">
          {footerService.map(link => (
            <li>
              <a href={link.href} class="text-gray-600 hover:text-accent text-sm transition-colors">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 pt-6 border-t border-border">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
        <p class="text-gray-500 text-xs">&copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.</p>
        <a href="mailto:info@igetvapeshub.com" class="text-gray-500 hover:text-accent text-xs transition-colors">info@igetvapeshub.com</a>
      </div>
    </div>
  </div>
</footer>
