---
import { footerSupport, footerService, productCategories, siteConfig } from '@data/navigation';
---

<footer class="bg-surface mt-auto border-t border-border">
  <!-- Main footer -->
  <div class="container-site py-10 lg:py-14">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-10">
      <!-- Customer Support -->
      <div>
        <h3 class="text-sm font-bold text-text uppercase tracking-wide mb-4">Customer Support</h3>
        <ul class="space-y-2.5">
          {footerSupport.map(link => (
            <li>
              <a href={link.href} class="text-text-muted hover:text-text text-sm transition-colors duration-200">{link.name}</a>
            </li>
          ))}
          <li>
            <a href={`mailto:${siteConfig.email}`} class="text-text-muted hover:text-text text-sm transition-colors duration-200">{siteConfig.email}</a>
          </li>
        </ul>
      </div>

      <!-- Customer Service -->
      <div>
        <h3 class="text-sm font-bold text-text uppercase tracking-wide mb-4">Customer Service</h3>
        <ul class="space-y-2.5">
          {footerService.map(link => (
            <li>
              <a href={link.href} class="text-text-muted hover:text-text text-sm transition-colors duration-200">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-bold text-text uppercase tracking-wide mb-4">Quick Links</h3>
        <ul class="space-y-2.5">
          {productCategories.slice(0, 6).map(cat => (
            <li>
              <a href={cat.href} class="text-text-muted hover:text-text text-sm transition-colors duration-200">{cat.name.replace(/\d+\sPUFFS|SAVE$/, '').trim()}</a>
            </li>
          ))}
          <li>
            <a href="/mix-and-match" class="text-text-muted hover:text-text text-sm transition-colors duration-200">Mix & Match Deals</a>
          </li>
          <li>
            <a href="/blog" class="text-text-muted hover:text-text text-sm transition-colors duration-200">Blog</a>
          </li>
        </ul>
      </div>

      <!-- Track Your Order -->
      <div>
        <h3 class="text-sm font-bold text-text uppercase tracking-wide mb-4">Track Your Order</h3>
        <p class="text-text-muted text-sm mb-4 leading-relaxed">Enter your tracking number below to check the status of your delivery.</p>
        <form action="https://auspost.com.au/mypost/track/#/search" method="get" target="_blank" rel="noopener noreferrer" class="flex gap-2">
          <input type="text" name="tracking" placeholder="Tracking number" class="flex-1 px-3 py-2 text-sm border border-border bg-white text-text placeholder:text-text-light focus:outline-none focus:border-text" style="border-radius: var(--radius-sm);" />
          <button type="submit" class="btn-primary py-2 px-4 text-xs">Track</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="bg-white border-t border-border">
    <div class="container-site py-4 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-text-muted text-xs">&copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.</p>
      <div class="flex items-center gap-5 text-xs text-text-muted">
        <a href="/privacy-policy" class="hover:text-text transition-colors duration-200">Privacy</a>
        <a href="/terms-and-conditions" class="hover:text-text transition-colors duration-200">Terms</a>
        <a href="/shipping-policy" class="hover:text-text transition-colors duration-200">Shipping</a>
      </div>
    </div>
  </div>
</footer>
