---
import { footerSupport, footerService, productCategories, siteConfig } from '@data/navigation';

const featuredCollections = productCategories.filter((category) => category.slug !== 'mix-and-match').slice(0, 6);
---

<footer class="footer-shell mt-auto text-white">
  <div class="container-site py-14 lg:py-18">
    <div class="grid gap-6 xl:grid-cols-[1.2fr_0.75fr_0.75fr_0.75fr]">
      <section class="footer-card p-7 lg:p-8">
        <p class="footer-kicker">IGET Vapes Original</p>
        <h2 class="mt-3 max-w-xl text-4xl leading-[0.95] tracking-[-0.05em] text-white lg:text-6xl">
          A more deliberate way to shop adult vape products online.
        </h2>
        <p class="mt-5 max-w-2xl text-sm leading-7 text-white/68 lg:text-base">
          Curated collections, clear shipping expectations, and a premium storefront built for adults who want authenticity without noise.
        </p>

        <div class="mt-8 grid gap-3 sm:grid-cols-3">
          <div class="rounded-[1.4rem] border border-white/10 bg-white/5 p-4">
            <p class="text-2xl font-bold tracking-tight text-white">150+</p>
            <p class="mt-1 text-xs font-semibold uppercase tracking-[0.16em] text-white/52">Flavours stocked</p>
          </div>
          <div class="rounded-[1.4rem] border border-white/10 bg-white/5 p-4">
            <p class="text-2xl font-bold tracking-tight text-white">4.9/5</p>
            <p class="mt-1 text-xs font-semibold uppercase tracking-[0.16em] text-white/52">Verified sentiment</p>
          </div>
          <div class="rounded-[1.4rem] border border-white/10 bg-white/5 p-4">
            <p class="text-2xl font-bold tracking-tight text-white">AU-wide</p>
            <p class="mt-1 text-xs font-semibold uppercase tracking-[0.16em] text-white/52">Discreet delivery</p>
          </div>
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href="/mix-and-match" class="btn-primary">View Bundle Deals</a>
          <a href={`mailto:${siteConfig.email}`} class="btn-secondary">{siteConfig.email}</a>
        </div>
      </section>

      <section>
        <p class="footer-kicker mb-4">Collections</p>
        <ul class="space-y-3 text-sm">
          {featuredCollections.map((collection) => (
            <li>
              <a href={collection.href} class="footer-link">{collection.name}</a>
            </li>
          ))}
          <li>
            <a href="/mix-and-match" class="footer-link">Mix &amp; Match</a>
          </li>
        </ul>
      </section>

      <section>
        <p class="footer-kicker mb-4">Support</p>
        <ul class="space-y-3 text-sm">
          {footerSupport.map((link) => (
            <li>
              <a href={link.href} class="footer-link">{link.name}</a>
            </li>
          ))}
        </ul>
      </section>

      <section>
        <p class="footer-kicker mb-4">Account</p>
        <ul class="space-y-3 text-sm">
          {footerService.map((link) => (
            <li>
              <a href={link.href} class="footer-link">{link.name}</a>
            </li>
          ))}
        </ul>

        <div class="mt-8 rounded-[1.4rem] border border-white/10 bg-white/5 p-4 text-sm text-white/68">
          <p class="font-semibold uppercase tracking-[0.16em] text-white/52">Trust Note</p>
          <p class="mt-3 leading-7">
            Adults only. Genuine inventory. Plain packaging. Manual payment confirmation and local support when you need it.
          </p>
        </div>
      </section>
    </div>
  </div>

  <div class="border-t border-white/8">
    <div class="container-site flex flex-col gap-3 py-5 text-xs text-white/42 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {new Date().getFullYear()} {siteConfig.name}. Adults 18+ only.</p>
      <div class="flex flex-wrap gap-5">
        <a href="/privacy-policy" class="footer-link">Privacy</a>
        <a href="/terms-and-conditions" class="footer-link">Terms</a>
        <a href="/shipping-policy" class="footer-link">Shipping</a>
      </div>
    </div>
  </div>
</footer>
