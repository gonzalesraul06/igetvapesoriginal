<!-- Cart slide-out drawer - hydrated client-side -->
<div id="cart-drawer" class="fixed inset-y-0 right-0 z-50 w-full max-w-md bg-surface border-l border-border transform translate-x-full transition-transform duration-300 flex flex-col">
  <!-- Header -->
  <div class="flex items-center justify-between p-4 border-b border-border">
    <h2 class="text-lg font-bold">Shopping Cart</h2>
    <button id="cart-close" class="p-2 text-gray-600 hover:text-gray-900" aria-label="Close cart">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Cart items -->
  <div id="cart-items" class="flex-1 overflow-y-auto p-4 space-y-4">
    <p id="cart-empty" class="text-gray-600 text-center py-8">Your cart is empty</p>
  </div>

  <!-- Footer with total -->
  <div id="cart-footer" class="border-t border-border p-4 hidden">
    <div class="flex justify-between text-sm text-gray-600 mb-1">
      <span>Subtotal</span>
      <span id="cart-subtotal">$0.00</span>
    </div>
    <div class="flex justify-between text-sm text-gray-600 mb-3">
      <span>Shipping</span>
      <span>$30.00</span>
    </div>
    <div class="flex justify-between text-lg font-bold mb-4">
      <span>Total</span>
      <span id="cart-total">$30.00</span>
    </div>
    <div id="cart-minimum-warning" class="hidden mb-3 p-3 bg-yellow-500/10 border border-yellow-500/30 rounded-lg text-center">
      <p class="text-yellow-400 text-sm font-medium">Minimum order is $300. Add <span id="cart-remaining">$0</span> more to checkout.</p>
    </div>
    <a id="cart-checkout-btn" href="/checkout" class="btn-primary w-full block text-center py-3">Proceed to Checkout</a>
  </div>
</div>
<div id="cart-overlay" class="fixed inset-0 bg-black/50 z-40 hidden"></div>

<script>
  import { cartItems, cartOpen, removeFromCart, updateQuantity, getCartTotal, getCartCount, initCart, MINIMUM_ORDER, SHIPPING_COST } from '@utils/cart';

  initCart();

  const drawer = document.getElementById('cart-drawer');
  const overlay = document.getElementById('cart-overlay');
  const closeBtn = document.getElementById('cart-close');
  const toggleBtn = document.getElementById('cart-toggle');
  const itemsContainer = document.getElementById('cart-items');
  const emptyMsg = document.getElementById('cart-empty');
  const footer = document.getElementById('cart-footer');
  const subtotalEl = document.getElementById('cart-subtotal');
  const totalEl = document.getElementById('cart-total');
  const countEl = document.getElementById('cart-count');

  function openCart() {
    drawer?.classList.remove('translate-x-full');
    overlay?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeCart() {
    drawer?.classList.add('translate-x-full');
    overlay?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  toggleBtn?.addEventListener('click', openCart);
  closeBtn?.addEventListener('click', closeCart);
  overlay?.addEventListener('click', closeCart);

  function renderCart() {
    const items = Object.values(cartItems.get());
    const count = getCartCount();
    const total = getCartTotal();

    // Update badge
    if (countEl) {
      countEl.textContent = String(count);
      countEl.classList.toggle('hidden', count === 0);
    }

    if (!itemsContainer || !emptyMsg || !footer) return;

    if (items.length === 0) {
      emptyMsg.classList.remove('hidden');
      footer.classList.add('hidden');
      // Remove all item elements
      itemsContainer.querySelectorAll('.cart-item').forEach(el => el.remove());
      return;
    }

    emptyMsg.classList.add('hidden');
    footer.classList.remove('hidden');

    // Render items
    const frag = document.createDocumentFragment();
    items.forEach(item => {
      const div = document.createElement('div');
      div.className = 'cart-item flex gap-3 bg-primary/50 rounded-lg p-3';
      div.innerHTML = `
        <img src="${item.image}" alt="${item.name}" class="w-16 h-16 rounded object-cover" />
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium truncate">${item.name}</p>
          <p class="text-xs text-gray-600">${item.categoryName}</p>
          <div class="flex items-center gap-2 mt-1">
            <button data-action="dec" data-id="${item.id}" class="w-6 h-6 rounded bg-surface text-gray-700 hover:text-gray-900 text-sm flex items-center justify-center">−</button>
            <span class="text-sm">${item.quantity}</span>
            <button data-action="inc" data-id="${item.id}" class="w-6 h-6 rounded bg-surface text-gray-700 hover:text-gray-900 text-sm flex items-center justify-center">+</button>
          </div>
        </div>
        <div class="text-right">
          <p class="font-semibold">$${(item.price * item.quantity).toFixed(2)}</p>
          <button data-action="remove" data-id="${item.id}" class="text-xs text-gray-500 hover:text-accent mt-1">Remove</button>
        </div>
      `;
      frag.appendChild(div);
    });

    itemsContainer.querySelectorAll('.cart-item').forEach(el => el.remove());
    itemsContainer.appendChild(frag);

    // Update totals
    if (subtotalEl) subtotalEl.textContent = `$${total.toFixed(2)}`;
    if (totalEl) totalEl.textContent = `$${(total + SHIPPING_COST).toFixed(2)}`;

    // Minimum order enforcement
    const warningEl = document.getElementById('cart-minimum-warning');
    const remainingEl = document.getElementById('cart-remaining');
    const checkoutBtn = document.getElementById('cart-checkout-btn');
    if (warningEl && checkoutBtn) {
      if (total < MINIMUM_ORDER) {
        warningEl.classList.remove('hidden');
        if (remainingEl) remainingEl.textContent = `$${(MINIMUM_ORDER - total).toFixed(2)}`;
        checkoutBtn.classList.add('opacity-50', 'pointer-events-none');
        checkoutBtn.setAttribute('aria-disabled', 'true');
      } else {
        warningEl.classList.add('hidden');
        checkoutBtn.classList.remove('opacity-50', 'pointer-events-none');
        checkoutBtn.removeAttribute('aria-disabled');
      }
    }
  }

  // Event delegation for cart item actions
  itemsContainer?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const action = target.dataset.action;
    const id = target.dataset.id;
    if (!action || !id) return;

    const items = cartItems.get();
    if (action === 'inc') updateQuantity(id, (items[id]?.quantity ?? 0) + 1);
    else if (action === 'dec') updateQuantity(id, (items[id]?.quantity ?? 0) - 1);
    else if (action === 'remove') removeFromCart(id);
  });

  // Subscribe to store changes
  cartItems.subscribe(renderCart);
  cartOpen.subscribe(isOpen => { if (isOpen) { openCart(); cartOpen.set(false); } });

  // Initial render
  renderCart();
</script>
