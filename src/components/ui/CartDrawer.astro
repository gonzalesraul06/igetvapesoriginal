---
import { MINIMUM_ORDER } from '@utils/storeConfig';
---

<div id="cart-drawer" class="cart-shell fixed inset-y-0 right-0 z-50 flex w-full max-w-md translate-x-full flex-col transition-transform duration-300 ease-out">
  <div class="flex items-center justify-between border-b border-border/50 px-6 py-5">
    <div>
      <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-text-muted">Cart</p>
      <div class="mt-1 flex items-center gap-2">
        <h2 class="text-2xl text-text">Your selections</h2>
        <span id="cart-header-count" class="hidden min-h-[1.2rem] min-w-[1.2rem] items-center justify-center rounded-full bg-accent px-1 text-[0.62rem] font-bold text-white">0</span>
      </div>
    </div>
    <button id="cart-close" class="header-action h-10 w-10" aria-label="Close cart">
      <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div class="border-b border-border/40 px-6 py-4">
    <div class="grid grid-cols-3 gap-3 text-center">
      <div class="rounded-[1.1rem] border border-border/50 bg-white/50 px-3 py-3">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-text-muted">Authentic</p>
        <p class="mt-1 text-sm font-semibold text-text">Verified stock</p>
      </div>
      <div class="rounded-[1.1rem] border border-border/50 bg-white/50 px-3 py-3">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-text-muted">Dispatch</p>
        <p class="mt-1 text-sm font-semibold text-text">Fast packing</p>
      </div>
      <div class="rounded-[1.1rem] border border-border/50 bg-white/50 px-3 py-3">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-text-muted">Checkout</p>
        <p class="mt-1 text-sm font-semibold text-text">Manual review</p>
      </div>
    </div>
  </div>

  <div id="cart-items" class="flex-1 space-y-3 overflow-y-auto px-6 py-5">
    <div id="cart-empty" class="flex flex-col items-center justify-center py-18 text-center">
      <div class="flex h-18 w-18 items-center justify-center rounded-[1.6rem] border border-border/50 bg-white/55">
        <svg class="h-8 w-8 text-text-muted" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
      </div>
      <h3 class="mt-5 text-2xl text-text">Nothing here yet</h3>
      <p class="mt-2 max-w-xs text-sm leading-7 text-text-muted">Start with a curated range, then review quantities here before moving into checkout.</p>
    </div>
  </div>

  <div id="cart-footer" class="hidden border-t border-border/50 px-6 py-5">
    <div class="utility-note">
      <div class="flex items-center justify-between text-sm text-text-muted">
        <span>Subtotal</span>
        <span id="cart-subtotal" class="font-semibold text-text">$0.00</span>
      </div>
      <div class="mt-2 flex items-center justify-between text-sm text-text-muted">
        <span>Shipping</span>
        <span>Calculated at checkout</span>
      </div>
      <div class="divider my-4"></div>
      <div class="flex items-center justify-between text-base font-bold text-text">
        <span>Total</span>
        <span id="cart-total">$0.00</span>
      </div>
    </div>

    <div id="cart-minimum-warning" class="mt-4 hidden rounded-[1.2rem] border border-[rgba(15,124,114,0.18)] bg-[rgba(227,243,240,0.72)] px-4 py-4 text-sm text-accent-dark">
      Minimum order is ${MINIMUM_ORDER} AUD. Add <span id="cart-remaining" class="font-bold">$0.00</span> more to continue.
    </div>

    <a id="cart-checkout-btn" href="/checkout" class="btn-primary mt-4 flex w-full justify-center text-base">Proceed to Checkout</a>
    <p class="mt-3 text-center text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-text-muted">Adults only. Secure manual order confirmation.</p>
  </div>
</div>

<div id="cart-overlay" class="fixed inset-0 z-40 hidden bg-[rgba(16,23,29,0.48)] opacity-0 backdrop-blur-sm transition-opacity duration-300"></div>

<script>
  import { cartItems, cartOpen, removeFromCart, updateQuantity, getCartTotal, getCartCount, initCart, MINIMUM_ORDER } from '@utils/cart';

  initCart();

  const drawer = document.getElementById('cart-drawer');
  const overlay = document.getElementById('cart-overlay');
  const closeBtn = document.getElementById('cart-close');
  const toggleBtn = document.getElementById('cart-toggle');
  const itemsContainer = document.getElementById('cart-items');
  const emptyMsg = document.getElementById('cart-empty');
  const footer = document.getElementById('cart-footer');
  const subtotalEl = document.getElementById('cart-subtotal');
  const totalEl = document.getElementById('cart-total');
  const countEl = document.getElementById('cart-count');

  function openCart() {
    drawer?.classList.remove('translate-x-full');
    overlay?.classList.remove('hidden');
    requestAnimationFrame(() => overlay?.classList.remove('opacity-0'));
    document.body.style.overflow = 'hidden';
  }

  function closeCart() {
    drawer?.classList.add('translate-x-full');
    overlay?.classList.add('opacity-0');
    window.setTimeout(() => overlay?.classList.add('hidden'), 300);
    document.body.style.overflow = '';
  }

  toggleBtn?.addEventListener('click', openCart);
  closeBtn?.addEventListener('click', closeCart);
  overlay?.addEventListener('click', closeCart);

  function renderCart() {
    const items = Object.values(cartItems.get());
    const count = getCartCount();
    const total = getCartTotal();

    if (countEl) {
      countEl.textContent = String(count);
      countEl.classList.toggle('hidden', count === 0);
    }

    const headerCount = document.getElementById('cart-header-count');
    if (headerCount) {
      headerCount.textContent = String(count);
      headerCount.classList.toggle('hidden', count === 0);
    }

    if (!(itemsContainer instanceof HTMLElement) || !(emptyMsg instanceof HTMLElement) || !(footer instanceof HTMLElement)) {
      return;
    }

    if (items.length === 0) {
      emptyMsg.classList.remove('hidden');
      footer.classList.add('hidden');
      itemsContainer.querySelectorAll('.cart-item').forEach((element) => element.remove());
      return;
    }

    emptyMsg.classList.add('hidden');
    footer.classList.remove('hidden');

    const fragment = document.createDocumentFragment();
    items.forEach((item) => {
      const element = document.createElement('div');
      element.className = 'cart-item cart-item-card flex gap-3 p-3.5';
      element.innerHTML = `
        <img src="${item.image}" alt="${item.name} - ${item.categoryName}" class="h-18 w-18 rounded-[1rem] object-cover bg-white/60 p-1.5" />
        <div class="min-w-0 flex-1">
          <p class="truncate text-sm font-semibold text-text">${item.name}</p>
          <p class="mt-1 text-xs text-text-muted">${item.categoryName}</p>
          <div class="mt-3 flex items-center gap-2">
            <button data-action="dec" data-id="${item.id}" class="flex h-8 w-8 items-center justify-center rounded-full border border-border bg-white/72 text-sm font-semibold text-text transition-colors hover:bg-white">-</button>
            <span class="w-5 text-center text-sm font-semibold text-text">${item.quantity}</span>
            <button data-action="inc" data-id="${item.id}" class="flex h-8 w-8 items-center justify-center rounded-full border border-border bg-white/72 text-sm font-semibold text-text transition-colors hover:bg-white">+</button>
          </div>
        </div>
        <div class="flex flex-col items-end justify-between text-right">
          <p class="text-sm font-bold text-text">$${(item.price * item.quantity).toFixed(2)}</p>
          <button data-action="remove" data-id="${item.id}" class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted transition-colors hover:text-accent">Remove</button>
        </div>
      `;
      fragment.appendChild(element);
    });

    itemsContainer.querySelectorAll('.cart-item').forEach((element) => element.remove());
    itemsContainer.appendChild(fragment);

    if (subtotalEl) subtotalEl.textContent = `$${total.toFixed(2)}`;
    if (totalEl) totalEl.textContent = `$${total.toFixed(2)}`;

    const warningEl = document.getElementById('cart-minimum-warning');
    const remainingEl = document.getElementById('cart-remaining');
    const checkoutBtn = document.getElementById('cart-checkout-btn');
    if (warningEl && checkoutBtn) {
      if (total < MINIMUM_ORDER) {
        warningEl.classList.remove('hidden');
        if (remainingEl) remainingEl.textContent = `$${(MINIMUM_ORDER - total).toFixed(2)}`;
        checkoutBtn.classList.add('opacity-50', 'pointer-events-none');
        checkoutBtn.setAttribute('aria-disabled', 'true');
      } else {
        warningEl.classList.add('hidden');
        checkoutBtn.classList.remove('opacity-50', 'pointer-events-none');
        checkoutBtn.removeAttribute('aria-disabled');
      }
    }
  }

  itemsContainer?.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const action = target.dataset.action;
    const id = target.dataset.id;
    if (!action || !id) return;

    const items = cartItems.get();
    if (action === 'inc') updateQuantity(id, (items[id]?.quantity ?? 0) + 1);
    if (action === 'dec') updateQuantity(id, (items[id]?.quantity ?? 0) - 1);
    if (action === 'remove') removeFromCart(id);
  });

  cartItems.subscribe(renderCart);
  cartOpen.subscribe((isOpen) => {
    if (!isOpen) return;
    openCart();
    cartOpen.set(false);
  });

  renderCart();
</script>
