---
interface ComparisonItem {
  title: string;
  copy: string;
  href: string;
  cta: string;
  tag?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  intro: string;
  items: ComparisonItem[];
}

const {
  eyebrow = 'Compare before you buy',
  title,
  intro,
  items,
} = Astro.props;
---

<section class="section" data-reveal>
  <div class="section-header">
    <span class="eyebrow">
      <span class="eyebrow-dot"></span>
      {eyebrow}
    </span>
    <h2 class="mt-5 text-text">{title}</h2>
    <p>{intro}</p>
  </div>

  <div class="grid gap-4 lg:grid-cols-3">
    {items.map((item, index) => (
      <article class="highlight-card flex h-full flex-col" data-reveal data-reveal-delay={String(index * 45)}>
        {item.tag && <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-text-muted">{item.tag}</p>}
        <h3 class="mt-3 text-3xl text-text">{item.title}</h3>
        <p class="mt-3 flex-1 text-sm leading-8 text-text-muted">{item.copy}</p>
        <a href={item.href} class="btn-secondary mt-6 text-sm">{item.cta}</a>
      </article>
    ))}
  </div>
</section>