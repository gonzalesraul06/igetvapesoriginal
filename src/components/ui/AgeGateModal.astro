<!-- Age verification modal - uses localStorage to remember verification -->
<div id="age-gate" class="fixed inset-0 z-[100] flex items-center justify-center bg-black/80 backdrop-blur-sm hidden">
  <div class="bg-surface border border-gray-700 rounded-2xl p-8 max-w-md mx-4 text-center shadow-2xl">
    <div class="text-5xl mb-4">🔞</div>
    <h2 class="text-2xl font-bold mb-2">Age Verification</h2>
    <p class="text-gray-300 mb-6">You must be 18 years or older to enter this website. Are you of legal age?</p>
    <div class="flex gap-4 justify-center">
      <button id="age-yes" class="btn-primary px-8 py-3 text-lg">Yes, I'm 18+</button>
      <button id="age-no" class="btn-secondary px-8 py-3 text-lg">No</button>
    </div>
  </div>
</div>

<script>
  const gate = document.getElementById('age-gate');
  const btnYes = document.getElementById('age-yes');
  const btnNo = document.getElementById('age-no');

  if (!localStorage.getItem('age-verified')) {
    gate?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  btnYes?.addEventListener('click', () => {
    localStorage.setItem('age-verified', 'true');
    gate?.classList.add('hidden');
    document.body.style.overflow = '';
  });

  btnNo?.addEventListener('click', () => {
    window.location.href = 'https://www.google.com';
  });
</script>
