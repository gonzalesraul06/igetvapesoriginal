<div id="age-gate" class="fixed inset-0 z-[100] hidden bg-[rgba(16,23,29,0.86)] backdrop-blur-xl">
  <div class="fixed inset-0 flex items-center justify-center p-4">
    <div class="age-gate-panel w-full max-w-[34rem] rounded-[2rem] p-8 text-center sm:p-10">
      <div class="flex justify-center">
        <span class="eyebrow">
          <span class="eyebrow-dot"></span>
          Adults only storefront
        </span>
      </div>

      <h2 class="mt-6 text-4xl text-text sm:text-5xl">Before you enter</h2>
      <p class="mx-auto mt-4 max-w-md text-sm leading-7 text-text-muted sm:text-base">
        This storefront is designed for adults purchasing genuine vape products in Australia. Please confirm that you are 18 years of age or older.
      </p>

      <div class="mt-8 grid gap-3 text-left sm:grid-cols-3">
        <div class="utility-note">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-text-muted">Adults 18+</p>
          <p class="mt-2 text-sm text-text">Age verification required before browsing.</p>
        </div>
        <div class="utility-note">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-text-muted">Authentic stock</p>
          <p class="mt-2 text-sm text-text">Curated devices sourced from authorised supply.</p>
        </div>
        <div class="utility-note">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-text-muted">Discreet delivery</p>
          <p class="mt-2 text-sm text-text">Plain packaging and Australia-wide support.</p>
        </div>
      </div>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
        <button id="age-yes" class="btn-primary min-w-[11rem] justify-center">Yes, I am 18+</button>
        <button id="age-no" class="btn-secondary min-w-[11rem] justify-center">Leave site</button>
      </div>
    </div>
  </div>
</div>

<script>
  const gate = document.getElementById('age-gate');
  const btnYes = document.getElementById('age-yes');
  const btnNo = document.getElementById('age-no');

  if (!localStorage.getItem('age-verified')) {
    gate?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  btnYes?.addEventListener('click', () => {
    localStorage.setItem('age-verified', 'true');
    gate?.classList.add('hidden');
    document.body.style.overflow = '';
  });

  btnNo?.addEventListener('click', () => {
    window.location.href = 'https://www.google.com';
  });
</script>
