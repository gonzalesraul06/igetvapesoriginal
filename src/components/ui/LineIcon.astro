---
interface Props {
  name:
    | 'arrow-right'
    | 'battery'
    | 'box'
    | 'capacity'
    | 'check'
    | 'coil'
    | 'flavours'
    | 'ice'
    | 'price'
    | 'puffs'
    | 'sale'
    | 'system'
    | 'tips'
    | 'weight';
  class?: string;
  title?: string;
}

const { name, class: className = 'h-5 w-5', title } = Astro.props;
const decorative = !title;
