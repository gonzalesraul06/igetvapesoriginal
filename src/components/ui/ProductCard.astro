---
import StarRating from '@components/ui/StarRating.astro';
import { formatPrice } from '@utils/formatPrice';

interface Props {
  name: string;
  slug: string;
  categorySlug: string;
  categoryName: string;
  price: number;
  image: string;
  inStock: boolean;
  isNew?: boolean;
  rating?: number;
}

const { name, slug, categorySlug, categoryName, price, image, inStock, isNew = false, rating = 5 } = Astro.props;
const productUrl = `/products/${categorySlug}/${slug}`;
const itemId = `${categorySlug}-${slug}`;
---

<div class="card group" data-in-stock={inStock}>
  <!-- Image -->
  <a href={productUrl} class="block relative overflow-hidden aspect-square bg-surface">
    <img
      src={image}
      alt={`${name} — ${categoryName} Disposable Vape Australia`}
      class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      loading="lazy"
      width="300"
      height="300"
    />
    {isNew && <span class="badge-new absolute top-3 left-3 text-[10px]" style="box-shadow: 0 2px 8px rgba(233,69,96,0.3);">New</span>}
    {!inStock && (
      <div class="absolute inset-0 bg-white/85 backdrop-blur-sm flex items-center justify-center">
        <span class="badge-out-of-stock text-xs">Out of Stock</span>
      </div>
    )}
  </a>

  <!-- Info -->
  <div class="p-3.5 sm:p-4">
    <a href={productUrl} class="block">
      <h3 class="text-xs sm:text-sm font-semibold truncate text-text group-hover:text-accent transition-colors duration-200 leading-tight">{name}</h3>
    </a>
    <div class="flex items-center justify-between mt-2.5">
      <span class="text-base sm:text-lg font-bold text-accent tracking-tight">{formatPrice(price)}</span>
      <StarRating rating={rating} size="sm" />
    </div>

    {inStock ? (
      <div class="mt-3.5 flex items-center gap-2">
        <div class="flex items-center border border-border rounded-lg overflow-hidden bg-surface">
          <button
            class="qty-dec w-8 h-8 flex items-center justify-center text-text-muted hover:text-text hover:bg-white transition-colors text-sm font-medium"
            data-item-id={itemId}
            aria-label="Decrease quantity"
          >&minus;</button>
          <span class="qty-val w-8 h-8 flex items-center justify-center text-xs font-semibold text-text bg-white" data-item-id={itemId}>1</span>
          <button
            class="qty-inc w-8 h-8 flex items-center justify-center text-text-muted hover:text-text hover:bg-white transition-colors text-sm font-medium"
            data-item-id={itemId}
            aria-label="Increase quantity"
          >+</button>
        </div>
        <button
          class="add-to-cart flex-1 btn-accent py-2 text-xs"
          data-item-id={itemId}
          data-category-slug={categorySlug}
          data-flavour-slug={slug}
          data-name={name}
          data-category-name={categoryName}
          data-price={price}
          data-image={image}
        >
          Add to Cart
        </button>
      </div>
    ) : (
      <button disabled class="mt-3.5 w-full py-2 text-xs bg-surface text-text-muted/50 rounded-lg cursor-not-allowed font-medium border border-border">
        Sold Out
      </button>
    )}
  </div>
</div>

<script>
  import { addToCart } from '@utils/cart';

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;

    // Quantity buttons
    if (target.classList.contains('qty-dec') || target.classList.contains('qty-inc')) {
      const id = target.dataset.itemId;
      if (!id) return;
      const valEl = document.querySelector(`.qty-val[data-item-id="${id}"]`);
      if (!valEl) return;
      let val = parseInt(valEl.textContent ?? '1');
      if (target.classList.contains('qty-dec')) val = Math.max(1, val - 1);
      else val = Math.min(99, val + 1);
      valEl.textContent = String(val);
    }

    // Add to cart
    if (target.classList.contains('add-to-cart')) {
      const { itemId, categorySlug, flavourSlug, name, categoryName, price, image } = target.dataset;
      if (!itemId || !categorySlug || !flavourSlug || !name || !categoryName || !price || !image) return;
      const valEl = document.querySelector(`.qty-val[data-item-id="${itemId}"]`);
      const qty = parseInt(valEl?.textContent ?? '1');
      addToCart({
        id: itemId,
        categorySlug,
        flavourSlug,
        name,
        categoryName,
        price: parseFloat(price),
        image,
      }, qty);
    }
  });
</script>
