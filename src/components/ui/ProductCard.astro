---
import StarRating from '@components/ui/StarRating.astro';
import { formatPrice } from '@utils/formatPrice';

interface Props {
  name: string;
  slug: string;
  categorySlug: string;
  categoryName: string;
  price: number;
  image: string;
  inStock: boolean;
  isNew?: boolean;
  rating?: number;
}

const {
  name,
  slug,
  categorySlug,
  categoryName,
  price,
  image,
  inStock,
  isNew = false,
  rating = 5,
} = Astro.props;
const productUrl = `/products/${categorySlug}/${slug}`;
const itemId = `${categorySlug}-${slug}`;
---

<article class="card group flex h-full flex-col p-3" data-in-stock={inStock}>
  <a href={productUrl} class="collection-media aspect-square">
    <img
      src={image}
      alt={`${name} - ${categoryName} disposable vape`}
      loading="lazy"
      width="300"
      height="300"
    />

    <div class="absolute left-3 top-3 flex gap-2">
      {isNew && <span class="badge-new">New</span>}
      {!inStock && <span class="badge-out-of-stock">Sold out</span>}
    </div>
  </a>

  <div class="flex h-full flex-col px-1 pb-1 pt-4">
    <div class="flex items-center justify-between gap-2">
      <span class="collection-chip">{categoryName}</span>
      <StarRating rating={rating} size="sm" />
    </div>

    <a href={productUrl} class="mt-4 block">
      <h3 class="line-clamp-2 text-xl leading-tight text-text transition-colors duration-200 group-hover:text-accent-dark">{name}</h3>
    </a>

    <p class="mt-2 text-sm leading-7 text-text-muted">Clean flavour delivery, rechargeable convenience, and an authentic adult retail source.</p>

    <div class="mt-4 flex items-end justify-between gap-3">
      <div>
        <p class="text-[0.7rem] font-bold uppercase tracking-[0.14em] text-text-muted">From</p>
        <p class="collection-price">{formatPrice(price)}</p>
      </div>

      <span class:list={['badge', inStock ? '' : 'badge-out-of-stock']}>
        {inStock ? 'In stock' : 'Unavailable'}
      </span>
    </div>

    <div class="mt-auto pt-5">
      {inStock ? (
        <div class="flex items-center gap-2.5">
          <div class="flex items-center gap-1 rounded-full border border-border bg-white/70 p-1">
            <button
              class="qty-dec flex h-8 w-8 items-center justify-center rounded-full text-sm font-bold text-text-muted transition-colors hover:bg-white hover:text-text"
              data-item-id={itemId}
              aria-label="Decrease quantity"
            >
              -
            </button>
            <span class="qty-val flex h-8 min-w-[2rem] items-center justify-center text-sm font-semibold text-text" data-item-id={itemId}>1</span>
            <button
              class="qty-inc flex h-8 w-8 items-center justify-center rounded-full text-sm font-bold text-text-muted transition-colors hover:bg-white hover:text-text"
              data-item-id={itemId}
              aria-label="Increase quantity"
            >
              +
            </button>
          </div>

          <button
            class="add-to-cart btn-primary flex-1 justify-center py-3 text-xs uppercase tracking-[0.14em]"
            data-item-id={itemId}
            data-category-slug={categorySlug}
            data-flavour-slug={slug}
            data-name={name}
            data-category-name={categoryName}
            data-price={price}
            data-image={image}
          >
            Add to cart
          </button>
        </div>
      ) : (
        <button disabled class="btn-secondary w-full justify-center py-3 text-xs uppercase tracking-[0.14em]">
          Currently unavailable
        </button>
      )}
    </div>
  </div>
</article>

<script>
  import { addToCart } from '@utils/cart';

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    if (target.classList.contains('qty-dec') || target.classList.contains('qty-inc')) {
      const id = target.dataset.itemId;
      if (!id) return;
      const valueElement = document.querySelector(`.qty-val[data-item-id="${id}"]`);
      if (!(valueElement instanceof HTMLElement)) return;
      let value = Number.parseInt(valueElement.textContent ?? '1', 10);
      if (target.classList.contains('qty-dec')) value = Math.max(1, value - 1);
      if (target.classList.contains('qty-inc')) value = Math.min(99, value + 1);
      valueElement.textContent = String(value);
    }

    if (target.classList.contains('add-to-cart')) {
      const { itemId, categorySlug, flavourSlug, name, categoryName, price, image } = target.dataset;
      if (!itemId || !categorySlug || !flavourSlug || !name || !categoryName || !price || !image) return;
      const quantityElement = document.querySelector(`.qty-val[data-item-id="${itemId}"]`);
      const quantity = Number.parseInt(quantityElement?.textContent ?? '1', 10);
      addToCart(
        {
          id: itemId,
          categorySlug,
          flavourSlug,
          name,
          categoryName,
          price: Number.parseFloat(price),
          image,
        },
        quantity,
      );
    }
  });
</script>
