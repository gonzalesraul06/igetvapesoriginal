---
import StarRating from '@components/ui/StarRating.astro';
import { formatPrice } from '@utils/formatPrice';

interface Props {
  name: string;
  slug: string;
  categorySlug: string;
  categoryName: string;
  price: number;
  image: string;
  inStock: boolean;
  isNew?: boolean;
  rating?: number;
}

const { name, slug, categorySlug, categoryName, price, image, inStock, isNew = false, rating = 5 } = Astro.props;
const productUrl = `/products/${categorySlug}/${slug}`;
const itemId = `${categorySlug}-${slug}`;
---

<div class="card group" data-in-stock={inStock}>
  <!-- Image -->
  <a href={productUrl} class="block relative overflow-hidden aspect-square">
    <img
      src={image}
      alt={name}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      loading="lazy"
      width="300"
      height="300"
    />
    {isNew && <span class="badge-new absolute top-2 left-2">New</span>}
    {!inStock && (
      <div class="absolute inset-0 bg-black/50 flex items-center justify-center">
        <span class="badge-out-of-stock text-sm">Out of Stock</span>
      </div>
    )}
  </a>

  <!-- Info -->
  <div class="p-4">
    <a href={productUrl} class="block">
      <h3 class="text-sm font-semibold truncate hover:text-accent">{name}</h3>
    </a>
    <div class="flex items-center justify-between mt-2">
      <span class="text-lg font-bold text-accent">{formatPrice(price)}</span>
      <StarRating rating={rating} />
    </div>

    {inStock ? (
      <div class="mt-3 flex items-center gap-2">
        <div class="flex items-center border border-gray-600 rounded-lg overflow-hidden">
          <button
            class="qty-dec w-8 h-8 flex items-center justify-center text-gray-300 hover:text-white hover:bg-muted transition-colors"
            data-item-id={itemId}
            aria-label="Decrease quantity"
          >−</button>
          <span class="qty-val w-8 h-8 flex items-center justify-center text-sm" data-item-id={itemId}>1</span>
          <button
            class="qty-inc w-8 h-8 flex items-center justify-center text-gray-300 hover:text-white hover:bg-muted transition-colors"
            data-item-id={itemId}
            aria-label="Increase quantity"
          >+</button>
        </div>
        <button
          class="add-to-cart flex-1 btn-primary py-2 text-sm"
          data-item-id={itemId}
          data-category-slug={categorySlug}
          data-flavour-slug={slug}
          data-name={name}
          data-category-name={categoryName}
          data-price={price}
          data-image={image}
        >
          Add to Cart
        </button>
      </div>
    ) : (
      <button disabled class="mt-3 w-full py-2 text-sm bg-gray-700 text-gray-400 rounded-lg cursor-not-allowed">
        Sold Out
      </button>
    )}
  </div>
</div>

<script>
  import { addToCart } from '@utils/cart';

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;

    // Quantity buttons
    if (target.classList.contains('qty-dec') || target.classList.contains('qty-inc')) {
      const id = target.dataset.itemId;
      if (!id) return;
      const valEl = document.querySelector(`.qty-val[data-item-id="${id}"]`);
      if (!valEl) return;
      let val = parseInt(valEl.textContent ?? '1');
      if (target.classList.contains('qty-dec')) val = Math.max(1, val - 1);
      else val = Math.min(99, val + 1);
      valEl.textContent = String(val);
    }

    // Add to cart
    if (target.classList.contains('add-to-cart')) {
      const { itemId, categorySlug, flavourSlug, name, categoryName, price, image } = target.dataset;
      if (!itemId || !categorySlug || !flavourSlug || !name || !categoryName || !price || !image) return;
      const valEl = document.querySelector(`.qty-val[data-item-id="${itemId}"]`);
      const qty = parseInt(valEl?.textContent ?? '1');
      addToCart({
        id: itemId,
        categorySlug,
        flavourSlug,
        name,
        categoryName,
        price: parseFloat(price),
        image,
      }, qty);
    }
  });
</script>
