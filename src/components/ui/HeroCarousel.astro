---
interface Slide {
  image: string;
  title: string;
  subtitle: string;
  cta: string;
  href: string;
}

interface Props {
  slides: Slide[];
}

const { slides } = Astro.props;
---

<div class="relative rounded-2xl overflow-hidden mb-8" id="hero-carousel">
  {slides.map((slide, i) => (
    <div
      class:list={['carousel-slide absolute inset-0 transition-opacity duration-500', i === 0 ? 'opacity-100' : 'opacity-0']}
      data-index={i}
    >
      <img src={slide.image} alt={slide.title} class="w-full h-64 sm:h-80 lg:h-96 object-cover" loading={i === 0 ? 'eager' : 'lazy'} />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent flex flex-col justify-end p-6 lg:p-10">
        <h2 class="text-2xl lg:text-4xl font-extrabold mb-2">{slide.title}</h2>
        <p class="text-white/80 mb-4 max-w-md">{slide.subtitle}</p>
        <a href={slide.href} class="btn-primary w-fit">{slide.cta}</a>
      </div>
    </div>
  ))}

  <!-- Make first slide relative so container has height -->
  <div class="relative">
    <img src={slides[0].image} alt="" class="w-full h-64 sm:h-80 lg:h-96 object-cover invisible" aria-hidden="true" />
  </div>

  <!-- Dots -->
  {slides.length > 1 && (
    <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2">
      {slides.map((_, i) => (
        <button
          class:list={['carousel-dot w-2.5 h-2.5 rounded-full transition-colors', i === 0 ? 'bg-accent' : 'bg-white/40']}
          data-index={i}
          aria-label={`Go to slide ${i + 1}`}
        />
      ))}
    </div>
  )}
</div>

<script>
  const carousel = document.getElementById('hero-carousel');
  if (carousel) {
    const slides = carousel.querySelectorAll('.carousel-slide');
    const dots = carousel.querySelectorAll('.carousel-dot');
    let current = 0;
    const total = slides.length;
    if (total <= 1) { /* no script needed */ } else {
      function showSlide(index: number) {
        slides.forEach((s, i) => {
          s.classList.toggle('opacity-100', i === index);
          s.classList.toggle('opacity-0', i !== index);
        });
        dots.forEach((d, i) => {
          d.classList.toggle('bg-accent', i === index);
          d.classList.toggle('bg-white/40', i !== index);
        });
        current = index;
      }

      dots.forEach(dot => {
        dot.addEventListener('click', () => {
          const idx = parseInt((dot as HTMLElement).dataset.index ?? '0');
          showSlide(idx);
        });
      });

      setInterval(() => showSlide((current + 1) % total), 5000);
    }
  }
</script>
