---
interface Slide {
  image: string;
  title: string;
  subtitle: string;
  cta: string;
  href: string;
}

interface Props {
  slides: Slide[];
}

const { slides } = Astro.props;
---

<div class="relative overflow-hidden mb-10" id="hero-carousel" style="border-radius: var(--radius-xl);">
  {slides.map((slide: Slide, i: number) => (
    <div
      class:list={['carousel-slide absolute inset-0 transition-opacity duration-700 ease-out', i === 0 ? 'opacity-100' : 'opacity-0']}
      data-index={i}
    >
      <img src={slide.image} alt={`${slide.title} — IGET Vapes Australia`} class="w-full h-72 sm:h-80 lg:h-[420px] object-cover" loading={i === 0 ? 'eager' : 'lazy'} />
      <div class="absolute inset-0 flex flex-col justify-end p-6 sm:p-8 lg:p-12" style="background: linear-gradient(to top, rgba(8,13,26,0.85) 0%, rgba(8,13,26,0.3) 50%, transparent 100%);">
        <h2 class="text-2xl sm:text-3xl lg:text-[2.75rem] font-extrabold text-white mb-2 tracking-tight leading-tight">{slide.title}</h2>
        <p class="text-white/75 mb-5 max-w-lg text-sm sm:text-base leading-relaxed">{slide.subtitle}</p>
        <a href={slide.href} class="btn-primary w-fit">{slide.cta}</a>
      </div>
    </div>
  ))}

  <!-- Make first slide relative so container has height -->
  <div class="relative">
    <img src={slides[0].image} alt="" class="w-full h-72 sm:h-80 lg:h-[420px] object-cover invisible" aria-hidden="true" />
  </div>

  <!-- Dots -->
  {slides.length > 1 && (
    <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2.5">
      {slides.map((_: Slide, i: number) => (
        <button
          class:list={['carousel-dot w-2 h-2 transition-all duration-300', i === 0 ? 'bg-white w-6' : 'bg-white/40']}
          style="border-radius: var(--radius-full);"
          data-index={i}
          aria-label={`Go to slide ${i + 1}`}
        />
      ))}
    </div>
  )}
</div>

<script>
  const carousel = document.getElementById('hero-carousel');
  if (carousel) {
    const slides = carousel.querySelectorAll('.carousel-slide');
    const dots = carousel.querySelectorAll('.carousel-dot');
    let current = 0;
    const total = slides.length;
    if (total <= 1) { /* no script needed */ } else {
      function showSlide(index: number) {
        slides.forEach((s, i) => {
          s.classList.toggle('opacity-100', i === index);
          s.classList.toggle('opacity-0', i !== index);
        });
        dots.forEach((d, i) => {
          if (i === index) {
            d.classList.add('bg-white', 'w-6');
            d.classList.remove('bg-white/40', 'w-2');
          } else {
            d.classList.remove('bg-white', 'w-6');
            d.classList.add('bg-white/40', 'w-2');
          }
        });
        current = index;
      }

      dots.forEach(dot => {
        dot.addEventListener('click', () => {
          const idx = parseInt((dot as HTMLElement).dataset.index ?? '0');
          showSlide(idx);
        });
      });

      setInterval(() => showSlide((current + 1) % total), 5000);
    }
  }
</script>
