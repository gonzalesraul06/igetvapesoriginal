---
import { productCategories } from '@data/navigation';

const cats = productCategories.filter(c => c.slug !== 'mix-and-match');
---

<section class="mb-12">
  <h2 class="text-xl font-bold mb-6 tracking-tight">Shop by Category</h2>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-5">
    {cats.map(cat => (
      <a href={cat.href} class="card group p-4 sm:p-5 flex flex-col items-center text-center">
        <div class="w-full aspect-square overflow-hidden mb-3" style="background: linear-gradient(135deg, #f8f9fb 0%, #f1f3f8 100%); border-radius: var(--radius-lg);">
          <img
            src={`/images/categories/${cat.slug}.webp`}
            alt={`${cat.name} — Buy Online Australia`}
            class="w-full h-full object-contain p-3 group-hover:scale-105 transition-transform duration-500 ease-out"
            loading="lazy"
            width="200"
            height="200"
          />
        </div>
        <h3 class="text-sm font-semibold text-text group-hover:text-accent transition-colors duration-200">{cat.name}</h3>
      </a>
    ))}
  </div>
</section>
