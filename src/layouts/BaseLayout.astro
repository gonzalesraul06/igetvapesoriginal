---
import SEOHead from '@components/seo/SEOHead.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import MobileNav from '@components/layout/MobileNav.astro';
import AgeGateModal from '@components/ui/AgeGateModal.astro';
import CartDrawer from '@components/ui/CartDrawer.astro';
import '@styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'product';
  noindex?: boolean;
  keywords?: string;
  publishedTime?: string;
  modifiedTime?: string;
}

const { title, description, image, canonical, type, noindex, keywords, publishedTime, modifiedTime } = Astro.props;    
---

<!doctype html>
<html lang="en-AU" class="scroll-smooth">
  <head>
    <SEOHead
      title={title}
      description={description}
      image={image}
      canonical={canonical}
      type={type}
      noindex={noindex}
      keywords={keywords}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
    />
  </head>
  <body class="antialiased">
    <AgeGateModal />
    <div class="min-h-screen flex flex-col">
      <Header />
      <main class="flex-1 w-full container-site pb-20 lg:pb-0">
        <slot />
      </main>
      <Footer />
    </div>
    <CartDrawer />
    <MobileNav />
    <!--Start of Tawk.to Script-->
    <script is:inline>
      var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
      Tawk_API.customStyle = {
        visibility: {
          desktop: { position: 'br', xOffset: 20, yOffset: 20 },
          mobile: { position: 'br', xOffset: 10, yOffset: 75 }
        }
      };
      (function(){
        var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
        s1.async=true;
        s1.src='https://embed.tawk.to/69beb4c7cfaccd1c358252af/1jk8f4bah';
        s1.charset='UTF-8';
        s1.setAttribute('crossorigin','*');
        s0.parentNode.insertBefore(s1,s0);
      })();
    </script>
    <!--End of Tawk.to Script-->
  </body>
</html>
