---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/layout/Breadcrumbs.astro';
import SchemaMarkup from '@components/seo/SchemaMarkup.astro';
---

<BaseLayout
  title="Contact IGET Vapes Original | Australia"
  description="Contact IGET Vapes Original for adult retail support, order updates, shipping questions, and product guidance across Australia."
>
  <SchemaMarkup type="localbusiness" />
  <Breadcrumbs items={[{ name: 'Contact' }]} />

  <div class="contact-grid">
    <section class="contact-panel" data-reveal>
      <span class="eyebrow">
        <span class="eyebrow-dot"></span>
        Contact and support
      </span>

      <h1 class="mt-5 text-5xl text-text lg:text-6xl">Talk to a real person, not a template.</h1>
      <p class="mt-5 max-w-2xl text-base leading-8 text-text-muted">
        Use this page for order questions, flavour availability, shipping concerns, or help choosing the right line. The tone of the site should carry through here: clear, adult, and useful.
      </p>

      <div class="support-grid mt-8">
        <div class="info-card p-6 text-left">
          <div class="icon-wrap mx-0 mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h2 class="text-3xl text-text">Email-first support</h2>
          <p class="mt-3 text-sm">Best for order changes, payment confirmations, and product-specific questions.</p>
          <a href="mailto:info@igetvapeshub.com" class="mt-4 inline-flex text-sm font-semibold text-accent-dark hover:text-accent">info@igetvapeshub.com</a>
        </div>

        <div class="info-card p-6 text-left">
          <div class="icon-wrap mx-0 mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h2 class="text-3xl text-text">Fast triage</h2>
          <p class="mt-3 text-sm">Messages are reviewed quickly so urgent shipping or order issues do not sit in a queue without context.</p>
        </div>

        <div class="info-card p-6 text-left">
          <div class="icon-wrap mx-0 mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h2 class="text-3xl text-text">Australia-wide</h2>
          <p class="mt-3 text-sm">Support covers metro and regional delivery questions with the same adult-only checkout rules across all states.</p>
        </div>

        <div class="info-card p-6 text-left">
          <div class="icon-wrap mx-0 mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h2 class="text-3xl text-text">Useful replies</h2>
          <p class="mt-3 text-sm">Share your order number and the exact issue if you have one. It shortens the path from first message to solution.</p>
        </div>
      </div>

      <div class="utility-note mt-8">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-text-muted">What to include</p>
        <p class="mt-3 text-sm leading-7 text-text">
          Name, order reference if available, the range or flavour you are asking about, and whether the question is about delivery, payment instructions, or product guidance.
        </p>
      </div>
    </section>

    <section class="form-panel" data-reveal data-reveal-delay="80">
      <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-text-muted">Send a message</p>
      <h2 class="mt-3 text-4xl text-text">We will route it properly.</h2>
      <p class="mt-3 text-sm leading-7 text-text-muted">Use the form below and keep the message specific. That produces the fastest and most helpful response.</p>

      <form id="contact-form" class="mt-8 space-y-5">
        <div class="grid gap-5 md:grid-cols-2">
          <div>
            <label for="name" class="form-label">Name</label>
            <input type="text" id="name" name="name" required class="form-input" placeholder="Your full name" />
          </div>
          <div>
            <label for="email" class="form-label">Email</label>
            <input type="email" id="email" name="email" required class="form-input" placeholder="name@example.com" />
          </div>
        </div>

        <div>
          <label for="subject" class="form-label">Subject</label>
          <select id="subject" name="subject" required class="form-input">
            <option value="">Select a subject</option>
            <option value="order">Order inquiry</option>
            <option value="product">Product question</option>
            <option value="flavours">Flavour availability</option>
            <option value="shipping">Shipping and delivery</option>
            <option value="returns">Returns or refunds</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div>
          <label for="order-number" class="form-label">Order number</label>
          <input type="text" id="order-number" name="orderNumber" class="form-input" placeholder="#12345 (optional)" />
        </div>

        <div>
          <label for="message" class="form-label">Message</label>
          <textarea id="message" name="message" required rows="6" class="form-input resize-y" placeholder="Tell us exactly what you need help with."></textarea>
        </div>

        <button type="submit" class="btn-primary flex w-full justify-center">Send message</button>
      </form>

      <div class="utility-note mt-6">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-text-muted">Helpful shortcuts</p>
        <div class="mt-3 flex flex-wrap gap-3 text-sm">
          <a href="/products/iget-bar-pro" class="btn-secondary">Browse Bar Pro</a>
          <a href="/products/alibarbar-ingot" class="btn-secondary">Browse Alibarbar</a>
          <a href="/delivery" class="btn-secondary">Delivery locations</a>
          <a href="/shipping-policy" class="btn-secondary">Shipping policy</a>
        </div>
      </div>
    </section>
  </div>

  <script>
    const showFormError = (message: string) => {
      let errorElement = document.getElementById('form-error');
      if (!errorElement) {
        errorElement = document.createElement('div');
        errorElement.id = 'form-error';
        errorElement.className = 'rounded-[1.2rem] border border-[rgba(182,87,87,0.22)] bg-white/70 px-4 py-4 text-sm text-danger';
        const form = document.getElementById('contact-form');
        form?.prepend(errorElement);
      }
      errorElement.textContent = message;
      errorElement.classList.remove('hidden');
      errorElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
    };

    const form = document.getElementById('contact-form');
    if (form instanceof HTMLFormElement) {
      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const submitButton = form.querySelector('button[type="submit"]');
        if (!(submitButton instanceof HTMLButtonElement)) return;

        const originalText = submitButton.textContent;
        submitButton.disabled = true;
        submitButton.textContent = 'Sending...';

        try {
          const formData = new FormData(form);
          const payload = {
            name: formData.get('name'),
            email: formData.get('email'),
            subject: formData.get('subject'),
            orderNumber: formData.get('orderNumber') || '',
            message: formData.get('message'),
          };

          const response = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          const result = await response.json();

          if (response.ok && result.success) {
            form.innerHTML = `
              <div class="rounded-[1.6rem] border border-[rgba(15,124,114,0.18)] bg-[rgba(227,243,240,0.72)] px-6 py-10 text-center">
                <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-text-muted">Message sent</p>
                <h3 class="mt-3 text-4xl text-text">We have it.</h3>
                <p class="mt-3 text-sm leading-7 text-text-muted">A response will follow as soon as the support team reviews your details.</p>
              </div>
            `;
            return;
          }

          showFormError(result.error || 'Unable to send the message right now. Please try again.');
        } catch {
          showFormError('Network error. Please check your connection and try again.');
        }

        submitButton.disabled = false;
        submitButton.textContent = originalText;
      });
    }
  </script>
</BaseLayout>