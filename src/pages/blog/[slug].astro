---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/layout/Breadcrumbs.astro';
import SchemaMarkup from '@components/seo/SchemaMarkup.astro';
import { blogPosts } from '@data/blog-posts';

export function getStaticPaths() {
  return blogPosts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const siteUrl = 'https://igetvapeshub.com';
const postUrl = `${siteUrl}/blog/${post.slug}`;
const postImage = post.image.startsWith('http') ? post.image : `${siteUrl}${post.image}`;

// Related posts: same category, different slug, max 3
const related = blogPosts
  .filter(p => p.category === post.category && p.slug !== post.slug)
  .slice(0, 3);

// Map blog post tags/content to relevant product categories for internal linking
const productCategoryMap: Array<{ name: string; href: string; desc: string }> = [];
const contentLower = (post.content + ' ' + post.tags.join(' ')).toLowerCase();
if (contentLower.includes('jnr cruiser') || contentLower.includes('jnr-cruiser')) {
  productCategoryMap.push({ name: 'JNR Cruiser 12000 Puffs', href: '/products/jnr-cruiser', desc: 'From $65 — 25ml capacity' });
}
if (contentLower.includes('iget one') || contentLower.includes('iget-one')) {
  productCategoryMap.push({ name: 'IGET One 12000 Puffs', href: '/products/iget-one', desc: 'From $55 — Dense vapour' });
}
if (contentLower.includes('bar pro') || contentLower.includes('iget-bar-pro') || contentLower.includes('iget bar pro')) {
  productCategoryMap.push({ name: 'IGET Bar Pro 10000 Puffs', href: '/products/iget-bar-pro', desc: 'From $48 — 26 flavours' });
}
if (contentLower.includes('s3') || contentLower.includes('pod system') || contentLower.includes('refillable')) {
  productCategoryMap.push({ name: 'IGET S3 Pod System', href: '/products/iget-bar-plus-s3', desc: 'From $48 — Refillable pods' });
}
if (contentLower.includes('alibarbar ingot') || contentLower.includes('alibarbar-ingot') || contentLower.includes('ingot 9000')) {
  productCategoryMap.push({ name: 'Alibarbar Ingot 9000 Puffs', href: '/products/alibarbar-ingot', desc: 'From $40 — 33 flavours' });
}
if (contentLower.includes('ice adjust') || contentLower.includes('alibarbar-ice-adjust')) {
  productCategoryMap.push({ name: 'Alibarbar Ice Adjust 12000', href: '/products/alibarbar-ice-adjust', desc: 'From $50 — Adjustable ice' });
}
// If no specific matches, show the top 3 best sellers
if (productCategoryMap.length === 0) {
  productCategoryMap.push(
    { name: 'IGET Bar Pro 10000 Puffs', href: '/products/iget-bar-pro', desc: "Australia's #1 seller — $48" },
    { name: 'JNR Cruiser 12000 Puffs', href: '/products/jnr-cruiser', desc: 'Maximum performance — $65' },
    { name: 'Alibarbar Ingot 9000 Puffs', href: '/products/alibarbar-ingot', desc: 'Best value — $40' },
  );
}

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.excerpt,
  image: postImage,
  datePublished: post.date,
  dateModified: post.date,
  author: { '@type': 'Organization', name: post.author, url: siteUrl },
  publisher: {
    '@type': 'Organization',
    name: 'IGET Vapes Original',
    url: siteUrl,
    logo: { '@type': 'ImageObject', url: `${siteUrl}/images/logo.svg` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
  url: postUrl,
  keywords: post.tags.join(', '),
  articleSection: post.category,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.article-content h2', '.article-content p:first-of-type'],
  },
};
---

<BaseLayout
  title={`${post.title} | IGET Vapes Blog`}
  description={post.excerpt}
  image={post.image}
  canonical={postUrl}
>
  <SchemaMarkup
    type="breadcrumb"
    data={{
      items: [
        { name: 'Home', url: siteUrl },
        { name: 'Blog', url: `${siteUrl}/blog` },
        { name: post.title, url: postUrl },
      ],
    }}
  />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <Breadcrumbs items={[{ name: 'Blog', href: '/blog' }, { name: post.title }]} />

  <article class="max-w-4xl mx-auto">
    <!-- Header -->
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-medium text-accent bg-accent/10 px-2.5 py-1 rounded-full">{post.category}</span>
        <span class="text-xs text-text-muted">{post.readTime}</span>
      </div>
      <h1 class="text-3xl lg:text-4xl font-extrabold mb-4 leading-tight tracking-tight">{post.title}</h1>
      <p class="text-lg text-text-muted leading-relaxed mb-4">{post.excerpt}</p>
      <div class="flex items-center gap-4 text-sm text-text-muted">
        <span>By <strong class="text-text">{post.author}</strong></span>
        <span>•</span>
        <time datetime={post.date}>{new Date(post.date).toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
      </div>
    </header>

    <!-- Featured Image -->
    <div class="aspect-video rounded-lg overflow-hidden bg-surface mb-10">
      <img
        src={post.image}
        alt={`${post.title} — IGET Vapes Blog Australia`}
        class="w-full h-full object-cover"
        loading="eager"
        width="800"
        height="450"
      />
    </div>

    <!-- Article Content -->
    <div class="article-content prose prose-invert prose-lg max-w-none mb-12
      [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:mt-10 [&_h2]:mb-4
      [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-3
      [&_p]:text-text-muted [&_p]:leading-relaxed [&_p]:mb-4
      [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-4 [&_ul]:space-y-2
      [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-4 [&_ol]:space-y-2
      [&_li]:text-text-muted
      [&_strong]:text-text
      [&_a]:text-accent [&_a]:underline [&_a]:hover:text-text"
      set:html={post.content}
    />

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mb-10 pt-6 border-t border-border">
      {post.tags.map(tag => (
        <span class="text-xs bg-surface border border-border text-text-muted px-3 py-1.5 rounded-full">{tag}</span>
      ))}
    </div>

    <!-- Related Posts -->
    {related.length > 0 && (
      <section class="mt-10 pt-10 border-t border-border">
        <h2 class="text-xl font-bold mb-6">Related Articles</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {related.map(r => (
            <a href={`/blog/${r.slug}`} class="group block card border border-border/50 hover:border-accent/50 transition-all overflow-hidden">
              <div class="aspect-video overflow-hidden bg-surface">
                <img src={r.image} alt={`${r.title} — ${r.category} Guide`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" width="400" height="225" />
              </div>
              <div class="p-4">
                <span class="text-xs text-accent">{r.category}</span>
                <h3 class="text-sm font-bold mt-1 group-hover:text-accent transition-colors line-clamp-2">{r.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Shop Related Products CTA -->
    <section class="mt-10 pt-10 border-t border-border">
      <h2 class="text-xl font-bold mb-2">Shop Related Products</h2>
      <p class="text-sm text-text-muted mb-5">Browse the vapes mentioned in this article — all 100% authentic with fast Australia-wide delivery.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {productCategoryMap.slice(0, 3).map(cat => (
          <a href={cat.href} class="group block bg-surface rounded-xl border border-border hover:border-accent/50 p-5 transition-all">
            <h3 class="font-bold text-sm group-hover:text-accent transition-colors">{cat.name}</h3>
            <p class="text-xs text-text-muted mt-1">{cat.desc}</p>
            <span class="inline-block mt-3 text-xs text-accent font-medium">Shop Now →</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Back to Blog -->
    <div class="mt-10 text-center">
      <a href="/blog" class="btn-secondary">← Back to Blog</a>
    </div>
  </article>
</BaseLayout>
