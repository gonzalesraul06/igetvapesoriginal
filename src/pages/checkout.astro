---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/layout/Breadcrumbs.astro';
import { MINIMUM_ORDER } from '@utils/storeConfig';
---

<BaseLayout title="Checkout | IGET Vapes" noindex={true}>
  <Breadcrumbs items={[{ name: 'Checkout' }]} />

  <div class="page-header" data-reveal>
    <span class="eyebrow">
      <span class="eyebrow-dot"></span>
      Secure adult checkout
    </span>
    <h1 class="mt-5">Place the order with full context.</h1>
    <p>
      The checkout flow makes the rules obvious: adults only, ${MINIMUM_ORDER} AUD minimum, state-based shipping, an immediate confirmation email, and manual payment follow-up from the team.
    </p>
  </div>

  <div id="checkout-flow" class="checkout-grid">
    <section class="form-panel" data-reveal>
      <div class="utility-note mb-6">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-text-muted">Before you submit</p>
        <p class="mt-3 text-sm leading-7 text-text">
          Make sure your shipping details are complete and your subtotal clears the minimum order threshold. A confirmation email is sent immediately, then payment instructions follow after review.
        </p>
      </div>

      <form id="checkout-form" class="space-y-6">
        <div>
          <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-text-muted">Step 1</p>
          <h2 class="mt-2 text-4xl text-text">Shipping details</h2>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label for="first-name" class="form-label">First name</label>
            <input type="text" id="first-name" name="firstName" required placeholder="John" class="form-input" />
          </div>
          <div>
            <label for="last-name" class="form-label">Last name</label>
            <input type="text" id="last-name" name="lastName" required placeholder="Smith" class="form-input" />
          </div>
        </div>

        <div>
          <label for="checkout-email" class="form-label">Email</label>
          <input type="email" id="checkout-email" name="email" required placeholder="john@example.com.au" class="form-input" />
        </div>

        <div>
          <label for="phone" class="form-label">Phone</label>
          <input type="tel" id="phone" name="phone" required placeholder="04XX XXX XXX" class="form-input" />
        </div>

        <div>
          <label for="address" class="form-label">Street address</label>
          <input type="text" id="address" name="address" required placeholder="123 George Street" class="form-input" />
        </div>

        <div>
          <label for="address2" class="form-label">Apartment, unit, suite</label>
          <input type="text" id="address2" name="address2" placeholder="Optional" class="form-input" />
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label for="city" class="form-label">Suburb</label>
            <input type="text" id="city" name="city" required placeholder="Sydney" class="form-input" />
          </div>
          <div>
            <label for="state" class="form-label">State or territory</label>
            <select id="state" name="state" required class="form-input">
              <option value="">Select state</option>
              <option value="ACT">Australian Capital Territory</option>
              <option value="NSW">New South Wales</option>
              <option value="NT">Northern Territory</option>
              <option value="QLD">Queensland</option>
              <option value="SA">South Australia</option>
              <option value="TAS">Tasmania</option>
              <option value="VIC">Victoria</option>
              <option value="WA">Western Australia</option>
            </select>
          </div>
        </div>

        <div>
          <label for="postcode" class="form-label">Postcode</label>
          <input type="text" id="postcode" name="postcode" required pattern="[0-9]{4}" maxlength="4" inputmode="numeric" placeholder="2000" class="form-input" />
        </div>

        <div>
          <label for="notes" class="form-label">Order notes</label>
          <textarea id="notes" name="notes" rows="4" placeholder="Optional delivery instructions" class="form-input resize-none"></textarea>
        </div>

        <div class="pt-2">
          <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-text-muted">Step 2</p>
          <h2 class="mt-2 text-4xl text-text">Payment method</h2>
          <p class="mt-3 text-sm leading-7 text-text-muted">
            Payments are handled manually after the order is placed. Choose the method you want instructions for.
          </p>
        </div>

        <div class="space-y-3">
          <label class="payment-option cursor-pointer">
            <input type="radio" name="payment" value="bank-transfer" checked class="mt-1 h-4 w-4 accent-accent" />
            <div>
              <p class="font-semibold text-text">Bank transfer (EFT)</p>
              <p class="mt-1 text-sm text-text-muted">Direct deposit instructions for an Australian bank account.</p>
            </div>
          </label>

          <label class="payment-option cursor-pointer">
            <input type="radio" name="payment" value="payid" class="mt-1 h-4 w-4 accent-accent" />
            <div>
              <p class="font-semibold text-text">PayID</p>
              <p class="mt-1 text-sm text-text-muted">Fast transfer using a PayID after your order reference is created.</p>
            </div>
          </label>

          <label class="payment-option cursor-pointer">
            <input type="radio" name="payment" value="bitcoin" class="mt-1 h-4 w-4 accent-accent" />
            <div>
              <p class="font-semibold text-text">Bitcoin</p>
              <p class="mt-1 text-sm text-text-muted">Wallet details are sent once the order is submitted for review.</p>
            </div>
          </label>
        </div>

        <div class="utility-note">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-text-muted">Payment process</p>
          <p class="mt-3 text-sm leading-7 text-text">
            Submit the order first. A confirmation email arrives straight away, then the team sends the payment details for the method you selected. Processing starts after payment is confirmed.
          </p>
        </div>

        <button type="submit" class="btn-primary flex w-full justify-center text-base">Place order</button>
        <p id="checkout-feedback" class="hidden rounded-[1.2rem] border px-4 py-3 text-sm" aria-live="polite"></p>
      </form>
    </section>

    <aside class="summary-panel" data-reveal data-reveal-delay="80">
      <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-text-muted">Order summary</p>
      <h2 class="mt-2 text-4xl text-text">Review before you confirm.</h2>

      <div id="checkout-items" class="mt-6 space-y-3">
        <p class="text-text-muted">Loading cart...</p>
      </div>

      <div class="utility-note mt-6">
        <div class="flex items-center justify-between text-sm text-text-muted">
          <span>Subtotal</span>
          <span id="checkout-subtotal" class="font-semibold text-text">$0.00</span>
        </div>
        <div class="mt-2 flex items-center justify-between text-sm text-text-muted">
          <span>Shipping <span id="checkout-shipping-state"></span></span>
          <span id="checkout-shipping" class="font-semibold text-text">Select state</span>
        </div>
        <div id="checkout-minimum-warning" class="mt-4 hidden rounded-[1.2rem] border border-[rgba(15,124,114,0.18)] bg-[rgba(227,243,240,0.72)] px-4 py-4 text-sm text-accent-dark">
          Minimum order is ${MINIMUM_ORDER} AUD. Add <span id="checkout-remaining" class="font-bold">$0.00</span> more to proceed.
          <a href="/" class="mt-2 inline-flex font-semibold text-accent-dark underline-offset-4 hover:underline">Continue shopping</a>
        </div>
        <div class="divider my-4"></div>
        <div class="flex items-center justify-between text-base font-bold text-text">
          <span>Total</span>
          <span id="checkout-total">$0.00</span>
        </div>
      </div>

      <div class="utility-note mt-6">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-text-muted">Shipping rates</p>
        <div class="mt-3 grid grid-cols-2 gap-x-4 gap-y-2 text-sm text-text-muted">
          <span>ACT / NSW / VIC</span><span class="text-right font-semibold text-text">$10</span>
          <span>QLD / SA</span><span class="text-right font-semibold text-text">$15</span>
          <span>WA / TAS</span><span class="text-right font-semibold text-text">$20</span>
          <span>NT</span><span class="text-right font-semibold text-text">$25</span>
        </div>
      </div>
    </aside>
  </div>

  <script>
    import { cartItems, getCartTotal, MINIMUM_ORDER, getShippingCost } from '@utils/cart';

    function renderCheckout() {
      const items = Object.values(cartItems.get());
      const itemsContainer = document.getElementById('checkout-items');
      const subtotalEl = document.getElementById('checkout-subtotal');
      const shippingEl = document.getElementById('checkout-shipping');
      const shippingStateEl = document.getElementById('checkout-shipping-state');
      const totalEl = document.getElementById('checkout-total');
      const warningEl = document.getElementById('checkout-minimum-warning');
      const remainingEl = document.getElementById('checkout-remaining');
      const submitButton = document.querySelector('#checkout-form button[type="submit"]');
      const stateField = document.getElementById('state');

      if (!(itemsContainer instanceof HTMLElement)) return;

      if (items.length === 0) {
        itemsContainer.innerHTML = '<p class="text-sm leading-7 text-text-muted">Your cart is empty. <a href="/" class="font-semibold text-accent-dark hover:text-accent">Return to collections</a>.</p>';
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = true;
          submitButton.textContent = 'Cart required';
        }
        return;
      }

      itemsContainer.innerHTML = items.map((item) => `
        <div class="rounded-[1.2rem] border border-border/50 bg-white/55 px-4 py-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-sm font-semibold text-text">${item.name}</p>
              <p class="mt-1 text-xs uppercase tracking-[0.12em] text-text-muted">${item.categoryName}</p>
            </div>
            <p class="text-sm font-bold text-text">$${(item.price * item.quantity).toFixed(2)}</p>
          </div>
          <p class="mt-3 text-xs font-semibold uppercase tracking-[0.14em] text-text-muted">Qty ${item.quantity}</p>
        </div>
      `).join('');

      const subtotal = getCartTotal();
      const state = stateField instanceof HTMLSelectElement ? stateField.value : '';
      const shipping = state ? getShippingCost(state) : 0;
      const total = subtotal + shipping;

      if (subtotalEl) subtotalEl.textContent = `$${subtotal.toFixed(2)}`;
      if (shippingEl) shippingEl.textContent = state ? `$${shipping.toFixed(2)}` : 'Select state';
      if (shippingStateEl) shippingStateEl.textContent = state ? `(${state})` : '';
      if (totalEl) totalEl.textContent = state ? `$${total.toFixed(2)}` : `$${subtotal.toFixed(2)}+`;

      if (submitButton instanceof HTMLButtonElement) {
        if (subtotal < MINIMUM_ORDER) {
          warningEl?.classList.remove('hidden');
          if (remainingEl) remainingEl.textContent = `$${(MINIMUM_ORDER - subtotal).toFixed(2)}`;
          submitButton.disabled = true;
          submitButton.textContent = `Minimum order $${MINIMUM_ORDER}`;
        } else {
          warningEl?.classList.add('hidden');
          submitButton.disabled = false;
          submitButton.textContent = 'Place order';
        }
      }
    }

    document.getElementById('state')?.addEventListener('change', renderCheckout);
    cartItems.subscribe(renderCheckout);
    renderCheckout();

    const checkoutForm = document.getElementById('checkout-form');
    checkoutForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!(checkoutForm instanceof HTMLFormElement)) return;

      const submitButton = checkoutForm.querySelector('button[type="submit"]');
      const feedbackEl = document.getElementById('checkout-feedback');
      if (!(submitButton instanceof HTMLButtonElement)) return;

      const originalText = submitButton.textContent;
      submitButton.disabled = true;
      submitButton.textContent = 'Placing order...';

      if (feedbackEl) {
        feedbackEl.className = 'hidden rounded-[1.2rem] border px-4 py-3 text-sm';
        feedbackEl.textContent = '';
      }

      try {
        const formData = new FormData(checkoutForm);
        const items = Object.values(cartItems.get());
        const subtotal = getCartTotal();
        const state = String(formData.get('state') ?? '');
        const shipping = getShippingCost(state);
        const payment = String(formData.get('payment') ?? 'bank-transfer');

        const payload = {
          firstName: String(formData.get('firstName') ?? ''),
          lastName: String(formData.get('lastName') ?? ''),
          email: String(formData.get('email') ?? ''),
          phone: String(formData.get('phone') ?? ''),
          address: String(formData.get('address') ?? ''),
          address2: String(formData.get('address2') ?? ''),
          city: String(formData.get('city') ?? ''),
          state,
          postcode: String(formData.get('postcode') ?? ''),
          notes: String(formData.get('notes') ?? ''),
          payment,
          items: items.map((item) => ({
            categorySlug: item.categorySlug,
            flavourSlug: item.flavourSlug,
            quantity: item.quantity,
          })),
          subtotal,
          shipping,
          total: subtotal + shipping,
        };

        const response = await fetch('/api/order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const result = await response.json();

        if (response.ok && result.success) {
          cartItems.set({});
          localStorage.removeItem('iget-cart');

          const paymentLabels = new Map([
            ['bank-transfer', 'Bank transfer'],
            ['payid', 'PayID'],
            ['bitcoin', 'Bitcoin'],
          ]);
          const paymentLabel = paymentLabels.get(payload.payment) ?? payload.payment;
          const flow = document.getElementById('checkout-flow');

          if (flow) {
            const orderRefNode = document.createElement('div');
            orderRefNode.textContent = String(result.orderRef ?? '');
            const safeOrderRef = orderRefNode.innerHTML;

            const paymentLabelNode = document.createElement('div');
            paymentLabelNode.textContent = paymentLabel;
            const safePaymentLabel = paymentLabelNode.innerHTML;

            const emailNode = document.createElement('div');
            emailNode.textContent = payload.email;
            const safeEmail = emailNode.innerHTML;

            flow.innerHTML = `
              <section class="cta-band lg:col-span-2">
                <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-white/48">Order placed</p>
                <h2 class="mt-3 text-5xl text-white">Your order is now in review.</h2>
                <p class="mt-4 max-w-3xl text-sm leading-7 text-white/78 lg:text-base">
                  Reference <strong>${safeOrderRef}</strong> has been created and a confirmation email has been sent to <strong>${safeEmail}</strong>. Payment instructions for <strong>${safePaymentLabel}</strong> will follow after the order is reviewed.
                </p>
                <div class="mt-6 flex flex-wrap gap-3">
                  <a href="/" class="btn-primary">Continue shopping</a>
                  <a href="/contact" class="btn-secondary">Need help?</a>
                </div>
              </section>
            `;
          }
          return;
        }

        if (feedbackEl) {
          feedbackEl.textContent = result.error || 'Unable to place the order right now. Please try again.';
          feedbackEl.className = 'rounded-[1.2rem] border border-[rgba(182,87,87,0.22)] bg-white/70 px-4 py-3 text-sm text-danger';
        }
      } catch {
        if (feedbackEl) {
          feedbackEl.textContent = 'Network error. Please check your connection and try again.';
          feedbackEl.className = 'rounded-[1.2rem] border border-[rgba(182,87,87,0.22)] bg-white/70 px-4 py-3 text-sm text-danger';
        }
      }

      submitButton.disabled = false;
      submitButton.textContent = originalText;
      renderCheckout();
    });
  </script>
</BaseLayout>
