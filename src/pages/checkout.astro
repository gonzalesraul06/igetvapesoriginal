---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Checkout — IGET Vapes Australia" noindex={true}>
  <div class="section-sm">
  <h1 class="text-2xl font-bold mb-2 text-text">Checkout</h1>
  <p class="text-text-muted text-sm mb-8">Complete your order details below. All fields marked are required.</p>

  <div id="checkout-container" class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
    <!-- Order form -->
    <div>
      <h2 class="text-lg font-bold mb-4 text-text flex items-center gap-2">
        <span class="w-7 h-7 rounded-full bg-accent text-white text-xs font-bold flex items-center justify-center">1</span>
        Shipping Details
      </h2>
      <form id="checkout-form" class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="first-name" class="block text-sm font-medium text-text mb-1">First Name</label>
            <input type="text" id="first-name" name="firstName" required placeholder="John" class="w-full bg-white border border-border rounded px-4 py-3 text-text placeholder-text-muted/50 focus:border-accent focus:ring-2 focus:ring-accent/10 focus:outline-none transition-all" />
          </div>
          <div>
            <label for="last-name" class="block text-sm font-medium text-text mb-1">Last Name</label>
            <input type="text" id="last-name" name="lastName" required placeholder="Smith" class="w-full bg-white border border-border rounded px-4 py-3 text-text placeholder-text-muted/50 focus:border-accent focus:ring-2 focus:ring-accent/10 focus:outline-none transition-all" />
          </div>
        </div>

        <div>
          <label for="checkout-email" class="block text-sm font-medium text-text mb-1">Email Address</label>
          <input type="email" id="checkout-email" name="email" required placeholder="john@example.com.au" class="w-full bg-white border border-border rounded px-4 py-3 text-text placeholder-text-muted/50 focus:border-accent focus:ring-2 focus:ring-accent/10 focus:outline-none transition-all" />
        </div>

        <div>
          <label for="phone" class="block text-sm font-medium text-text mb-1">Phone Number</label>
          <input type="tel" id="phone" name="phone" required placeholder="04XX XXX XXX" class="w-full bg-white border border-border rounded px-4 py-3 text-text placeholder-text-muted/50 focus:border-accent focus:ring-2 focus:ring-accent/10 focus:outline-none transition-all" />
        </div>

        <div>
          <label for="address" class="block text-sm font-medium text-text mb-1">Street Address</label>
          <input type="text" id="address" name="address" required placeholder="123 George Street" class="w-full bg-white border border-border rounded px-4 py-3 text-text placeholder-text-muted/50 focus:border-accent focus:ring-2 focus:ring-accent/10 focus:outline-none transition-all" />
        </div>

        <div>
          <label for="address2" class="block text-sm font-medium text-text mb-1">Apartment / Unit / Suite <span class="text-text-muted">(optional)</span></label>
          <input type="text" id="address2" name="address2" placeholder="Unit 4, Level 2" class="w-full bg-white border border-border rounded px-4 py-3 text-text placeholder-text-muted/50 focus:border-accent focus:ring-2 focus:ring-accent/10 focus:outline-none transition-all" />
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="city" class="block text-sm font-medium text-text mb-1">Suburb</label>
            <input type="text" id="city" name="city" required placeholder="Sydney" class="w-full bg-white border border-border rounded px-4 py-3 text-text placeholder-text-muted/50 focus:border-accent focus:ring-2 focus:ring-accent/10 focus:outline-none transition-all" />
          </div>
          <div>
            <label for="state" class="block text-sm font-medium text-text mb-1">State / Territory</label>
            <select id="state" name="state" required class="w-full bg-white border border-border rounded px-4 py-3 text-text focus:border-accent focus:ring-2 focus:ring-accent/10 focus:outline-none transition-all">
              <option value="">Select State</option>
              <option value="ACT">Australian Capital Territory (ACT)</option>
              <option value="NSW">New South Wales (NSW)</option>
              <option value="NT">Northern Territory (NT)</option>
              <option value="QLD">Queensland (QLD)</option>
              <option value="SA">South Australia (SA)</option>
              <option value="TAS">Tasmania (TAS)</option>
              <option value="VIC">Victoria (VIC)</option>
              <option value="WA">Western Australia (WA)</option>
            </select>
          </div>
        </div>

        <div>
          <label for="postcode" class="block text-sm font-medium text-text mb-1">Postcode</label>
          <input type="text" id="postcode" name="postcode" required pattern="[0-9]{4}" maxlength="4" inputmode="numeric" placeholder="2000" class="w-full bg-white border border-border rounded px-4 py-3 text-text placeholder-text-muted/50 focus:border-accent focus:ring-2 focus:ring-accent/10 focus:outline-none transition-all" />
        </div>

        <div>
          <label for="notes" class="block text-sm font-medium text-text mb-1">Order Notes <span class="text-text-muted">(optional)</span></label>
          <textarea id="notes" name="notes" rows="2" placeholder="Any special delivery instructions..." class="w-full bg-white border border-border rounded px-4 py-3 text-text placeholder-text-muted/50 focus:border-accent focus:ring-2 focus:ring-accent/10 focus:outline-none resize-none transition-all"></textarea>
        </div>

        <div class="pt-6">
          <h2 class="text-lg font-bold mb-3 text-text flex items-center gap-2">
            <span class="w-7 h-7 rounded-full bg-accent text-white text-xs font-bold flex items-center justify-center">2</span>
            Payment Method
          </h2>
          <p class="text-sm text-text-muted mb-4">All payments are processed manually. You will receive payment instructions via email after placing your order.</p>
          <div class="space-y-3">
            <label class="flex items-center gap-3 p-4 border border-border rounded cursor-pointer hover:border-accent/50 hover:bg-accent/5 transition-all has-[:checked]:border-accent has-[:checked]:bg-accent/5">
              <input type="radio" name="payment" value="bank-transfer" checked class="text-accent w-4 h-4 accent-accent" />
              <div class="flex items-center gap-3 flex-1">
                <svg class="w-5 h-5 text-text-muted shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                <div>
                  <span class="font-medium text-text">Bank Transfer (EFT)</span>
                  <p class="text-xs text-text-muted">Direct deposit to our Australian bank account</p>
                </div>
              </div>
            </label>
            <label class="flex items-center gap-3 p-4 border border-border rounded cursor-pointer hover:border-accent/50 hover:bg-accent/5 transition-all has-[:checked]:border-accent has-[:checked]:bg-accent/5">
              <input type="radio" name="payment" value="payid" class="text-accent w-4 h-4 accent-accent" />
              <div class="flex items-center gap-3 flex-1">
                <svg class="w-5 h-5 text-text-muted shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                <div>
                  <span class="font-medium text-text">PayID</span>
                  <p class="text-xs text-text-muted">Instant transfer via PayID — fast & secure</p>
                </div>
              </div>
            </label>
            <label class="flex items-center gap-3 p-4 border border-border rounded cursor-pointer hover:border-accent/50 hover:bg-accent/5 transition-all has-[:checked]:border-accent has-[:checked]:bg-accent/5">
              <input type="radio" name="payment" value="bitcoin" class="text-accent w-4 h-4 accent-accent" />
              <div class="flex items-center gap-3 flex-1">
                <svg class="w-5 h-5 text-text-muted shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <div>
                  <span class="font-medium text-text">Bitcoin (BTC)</span>
                  <p class="text-xs text-text-muted">Pay with cryptocurrency — wallet address provided after order</p>
                </div>
              </div>
            </label>
          </div>
        </div>

        <!-- Payment instruction notice -->
        <div class="bg-accent/5 border border-accent/15 rounded p-4 mt-2">
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <div>
              <p class="text-sm font-semibold text-text">How payment works</p>
              <p class="text-sm text-text-muted mt-1">After placing your order, you'll receive a confirmation email with detailed payment instructions for your selected method. Your order will be processed once payment is confirmed.</p>
            </div>
          </div>
        </div>

        <button type="submit" class="btn-primary w-full py-3 text-base mt-6">Place Order</button>
      </form>
    </div>

    <!-- Order summary -->
    <div>
      <div class="bg-surface rounded-2xl p-6 sticky top-24 border border-border">
        <h2 class="text-lg font-bold mb-4 text-text flex items-center gap-2">
          <svg class="w-5 h-5 text-text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          Order Summary
        </h2>
        <div id="checkout-items" class="space-y-3 mb-4">
          <p class="text-text-muted">Loading cart...</p>
        </div>
        <div class="border-t border-border pt-4 space-y-2.5 text-sm">
          <div class="flex justify-between text-text-muted">
            <span>Subtotal</span>
            <span id="checkout-subtotal" class="font-medium text-text">$0.00</span>
          </div>
          <div class="flex justify-between text-text-muted">
            <span>Shipping <span id="checkout-shipping-state" class="text-xs"></span></span>
            <span id="checkout-shipping" class="font-medium text-text">Select state</span>
          </div>
          <div id="checkout-minimum-warning" class="hidden p-3 bg-accent/5 border border-accent/20 rounded text-center">
            <p class="text-accent text-sm font-medium">Minimum order is $250 AUD. Add <span id="checkout-remaining" class="font-bold">$0</span> more to proceed.</p>
            <a href="/" class="text-accent text-sm hover:underline mt-1 inline-block">Continue Shopping &rarr;</a>
          </div>
          <div class="flex justify-between text-lg font-bold pt-3 border-t border-border text-text">
            <span>Total (AUD)</span>
            <span id="checkout-total">$0.00</span>
          </div>
        </div>

        <!-- Shipping rates info -->
        <div class="mt-4 p-3 bg-white rounded border border-border">
          <p class="text-xs font-semibold text-text mb-2">Shipping Rates by State</p>
          <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-xs text-text-muted">
            <span>ACT / NSW / VIC</span><span class="text-right font-medium text-text">$10</span>
            <span>QLD / SA</span><span class="text-right font-medium text-text">$15</span>
            <span>WA / TAS</span><span class="text-right font-medium text-text">$20</span>
            <span>NT</span><span class="text-right font-medium text-text">$25</span>
          </div>
        </div>
      </div>
    </div>
  </div>
  </div>

  <script>
    import { cartItems, getCartTotal, MINIMUM_ORDER, getShippingCost } from '@utils/cart';

    let currentShipping = 0;

    function renderCheckout() {
      const items = Object.values(cartItems.get());
      const container = document.getElementById('checkout-items');
      const subtotalEl = document.getElementById('checkout-subtotal');
      const totalEl = document.getElementById('checkout-total');
      const shippingEl = document.getElementById('checkout-shipping');
      const shippingStateEl = document.getElementById('checkout-shipping-state');
      if (!container) return;

      if (items.length === 0) {
        container.innerHTML = '<p class="text-text-muted">Your cart is empty. <a href="/" class="text-accent hover:underline font-medium">Continue shopping</a></p>';
        return;
      }

      container.innerHTML = items.map(item => `
        <div class="flex justify-between items-center text-sm">
          <span class="text-text">${item.name} <span class="text-text-muted">&times; ${item.quantity}</span></span>
          <span class="font-medium text-text">$${(item.price * item.quantity).toFixed(2)}</span>
        </div>
      `).join('');

      const subtotal = getCartTotal();
      const stateSelect = document.getElementById('state') as HTMLSelectElement;
      const state = stateSelect?.value || '';

      if (state) {
        currentShipping = getShippingCost(state);
        if (shippingEl) shippingEl.textContent = `$${currentShipping.toFixed(2)}`;
        if (shippingStateEl) shippingStateEl.textContent = `(${state})`;
      } else {
        currentShipping = 0;
        if (shippingEl) shippingEl.textContent = 'Select state';
        if (shippingStateEl) shippingStateEl.textContent = '';
      }

      if (subtotalEl) subtotalEl.textContent = `$${subtotal.toFixed(2)}`;
      const total = subtotal + currentShipping;
      if (totalEl) totalEl.textContent = state ? `$${total.toFixed(2)}` : `$${subtotal.toFixed(2)}+`;

      // Minimum order enforcement
      const warningEl = document.getElementById('checkout-minimum-warning');
      const remainingEl = document.getElementById('checkout-remaining');
      const submitBtn = document.querySelector('#checkout-form button[type="submit"]') as HTMLButtonElement;
      if (warningEl && submitBtn) {
        if (subtotal < MINIMUM_ORDER && items.length > 0) {
          warningEl.classList.remove('hidden');
          if (remainingEl) remainingEl.textContent = `$${(MINIMUM_ORDER - subtotal).toFixed(2)}`;
          submitBtn.disabled = true;
          submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
          submitBtn.textContent = `Minimum Order $${MINIMUM_ORDER} AUD Required`;
        } else if (items.length > 0) {
          warningEl.classList.add('hidden');
          submitBtn.disabled = false;
          submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
          submitBtn.textContent = 'Place Order';
        }
      }
    }

    // Recalculate shipping when state changes
    document.getElementById('state')?.addEventListener('change', renderCheckout);

    cartItems.subscribe(renderCheckout);
    renderCheckout();

    // Handle checkout form submission
    const checkoutForm = document.getElementById('checkout-form') as HTMLFormElement;
    checkoutForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = checkoutForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Placing Order...';

      try {
        const formData = new FormData(checkoutForm);
        const items = Object.values(cartItems.get());
        const subtotal = getCartTotal();
        const state = formData.get('state') as string;
        const shipping = getShippingCost(state);

        const payload = {
          firstName: formData.get('firstName'),
          lastName: formData.get('lastName'),
          email: formData.get('email'),
          phone: formData.get('phone'),
          address: formData.get('address'),
          address2: formData.get('address2') || '',
          city: formData.get('city'),
          state,
          postcode: formData.get('postcode'),
          notes: formData.get('notes') || '',
          payment: formData.get('payment'),
          items: items.map(i => ({ name: i.name, quantity: i.quantity, price: i.price })),
          subtotal,
          shipping,
          total: subtotal + shipping,
        };

        const res = await fetch('/api/order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const result = await res.json();

        if (res.ok && result.success) {
          // Clear cart
          cartItems.set({});
          localStorage.removeItem('iget-cart');

          // Get payment method label
          const paymentLabels: Record<string, string> = {
            'bank-transfer': 'Bank Transfer (EFT)',
            'payid': 'PayID',
            'bitcoin': 'Bitcoin (BTC)',
          };
          const paymentLabel = paymentLabels[payload.payment as string] || payload.payment;

          // Show success with payment instruction notice
          const container = document.getElementById('checkout-container');
          if (container) {
            container.innerHTML = `
              <div class="col-span-full max-w-xl mx-auto text-center py-12">
                <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-green-100 flex items-center justify-center">
                  <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                </div>
                <h2 class="text-2xl font-bold mb-2">Order Placed Successfully!</h2>
                <p class="text-text-muted mb-1">Your order reference:</p>
                <p class="text-xl font-extrabold text-accent mb-4">${result.orderRef}</p>

                <div class="bg-blue-50 border border-blue-200 rounded p-5 text-left mb-6">
                  <div class="flex items-start gap-3">
                    <svg class="w-6 h-6 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    <div>
                      <p class="font-bold text-blue-900 text-base">Payment Instructions Incoming</p>
                      <p class="text-blue-800 text-sm mt-1">We've sent an order confirmation email to <strong>${payload.email}</strong> with detailed <strong>${paymentLabel}</strong> payment instructions.</p>
                      <p class="text-blue-700 text-sm mt-2">Please check your inbox (and spam folder) and complete the payment to process your order. Once payment is confirmed, we'll pack and ship your order.</p>
                    </div>
                  </div>
                </div>

                <div class="bg-surface rounded p-4 mb-6">
                  <p class="text-sm font-semibold text-text mb-2">What happens next?</p>
                  <div class="text-sm text-text-muted space-y-1 text-left max-w-sm mx-auto">
                    <p><span class="font-bold text-accent">1.</span> Check your email for payment instructions</p>
                    <p><span class="font-bold text-accent">2.</span> Complete payment via ${paymentLabel}</p>
                    <p><span class="font-bold text-accent">3.</span> We confirm payment &amp; ship your order</p>
                    <p><span class="font-bold text-accent">4.</span> Receive tracking details via email</p>
                  </div>
                </div>

                <a href="/" class="btn-primary px-8 py-3 inline-block">Continue Shopping</a>
              </div>
            `;
          }
        } else {
          alert(result.error || 'Failed to place order. Please try again.');
          submitBtn.disabled = false;
          submitBtn.textContent = originalText;
        }
      } catch (err) {
        alert('Network error. Please check your connection and try again.');
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
  </script>
</BaseLayout>
