---
// @ts-ignore - types generated by astro sync
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/layout/Breadcrumbs.astro';
import SchemaMarkup from '@components/seo/SchemaMarkup.astro';
import { productCategories } from '@data/navigation';
import { formatPrice } from '@utils/formatPrice';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map((location: any) => ({
    params: { slug: location.id },
    props: { location: location.data },
  }));
}

const { slug } = Astro.params;
const { location } = Astro.props;
const siteUrl = 'https://igetvapeshub.com';

// Derive city name from title (e.g. "IGET Vapes Sydney ..." → "Sydney")
const cityName = location.title.replace(/^IGET Vapes\s+/, '').split(/\s*[—–-]\s*/)[0].trim();

const shippingRates: Record<string, { cost: number; days: string }> = {
  'New South Wales': { cost: 10, days: '2-4' },
  'Victoria': { cost: 10, days: '2-4' },
  'Australian Capital Territory': { cost: 10, days: '2-4' },
  'Queensland': { cost: 15, days: '3-5' },
  'South Australia': { cost: 15, days: '3-5' },
  'Western Australia': { cost: 20, days: '4-7' },
  'Tasmania': { cost: 20, days: '4-7' },
  'Northern Territory': { cost: 25, days: '5-10' },
};

const stateInfo = shippingRates[location.state] ?? { cost: 15, days: '3-7' };

const categories = productCategories.filter(c => c.slug !== 'mix-and-match');
---

<BaseLayout
  title={location.title}
  description={location.description}
  keywords={`iget vapes ${cityName.toLowerCase()}, buy vapes ${cityName.toLowerCase()}, vape shop ${cityName.toLowerCase()}, disposable vapes ${cityName.toLowerCase()}, ${cityName.toLowerCase()} vape delivery, iget bar ${cityName.toLowerCase()}`}
>
  <SchemaMarkup type="organization" />
  <Breadcrumbs items={[{ name: 'Delivery Locations', href: '/delivery' }, { name: cityName }]} />

  <!-- Hero -->
  <section class="mb-12 lg:mb-16">
    <div class="relative overflow-hidden p-8 sm:p-10 lg:p-14" style="background: linear-gradient(135deg, var(--color-dark) 0%, #1e1b4b 100%); border-radius: var(--radius-xl);">
      <div class="abstract-mesh absolute inset-0 opacity-20"></div>
      <div class="relative">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 text-[10px] uppercase tracking-[0.16em] font-bold text-white/70 mb-4" style="background: rgba(255,255,255,0.08); border-radius: var(--radius-full);">
          <span class="w-1.5 h-1.5 bg-green animate-pulse" style="border-radius: var(--radius-full);"></span>
          {location.state} — Fast Delivery
        </span>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4" style="letter-spacing: -0.025em; line-height: 1.1;">
          Buy IGET Vapes in <span class="text-gradient">{cityName}</span>
        </h1>
        <p class="text-white/70 max-w-2xl text-base sm:text-lg leading-relaxed mb-6">{location.description}</p>
        <div class="flex flex-wrap gap-3">
          <a href="/products/jnr-cruiser" class="btn-primary">Shop Now</a>
          <a href="/mix-and-match" class="px-6 py-2.5 text-sm font-semibold text-white transition-colors duration-250 hover:bg-white/10" style="border: 1px solid rgba(255,255,255,0.2); border-radius: var(--radius-lg);">Mix & Match Deals</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Shipping Info for this Location -->
  <section class="mb-12 lg:mb-16">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="p-5 text-center" style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg);">
        <div class="w-10 h-10 mx-auto mb-3 flex items-center justify-center text-accent" style="background: rgba(233,69,96,0.08); border-radius: var(--radius-md);">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0H21M3.375 14.25V3.375c0-.621.504-1.125 1.125-1.125h9.75c.621 0 1.125.504 1.125 1.125v5.25M3.375 14.25h11.25"/></svg>
        </div>
        <p class="text-[10px] uppercase tracking-[0.14em] text-text-muted mb-1 font-semibold">Shipping to {cityName}</p>
        <p class="text-2xl font-extrabold text-text tracking-tight">${stateInfo.cost}</p>
        <p class="text-xs text-text-muted mt-0.5">flat rate per order</p>
      </div>
      <div class="p-5 text-center" style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg);">
        <div class="w-10 h-10 mx-auto mb-3 flex items-center justify-center text-accent" style="background: rgba(233,69,96,0.08); border-radius: var(--radius-md);">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <p class="text-[10px] uppercase tracking-[0.14em] text-text-muted mb-1 font-semibold">Delivery Time</p>
        <p class="text-2xl font-extrabold text-text tracking-tight">{stateInfo.days} days</p>
        <p class="text-xs text-text-muted mt-0.5">business days via Australia Post</p>
      </div>
      <div class="p-5 text-center" style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg);">
        <div class="w-10 h-10 mx-auto mb-3 flex items-center justify-center text-accent" style="background: rgba(233,69,96,0.08); border-radius: var(--radius-md);">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
        </div>
        <p class="text-[10px] uppercase tracking-[0.14em] text-text-muted mb-1 font-semibold">Guarantee</p>
        <p class="text-2xl font-extrabold text-text tracking-tight">100%</p>
        <p class="text-xs text-text-muted mt-0.5">genuine products guaranteed</p>
      </div>
    </div>
  </section>

  <!-- Available Products -->
  <section class="mb-12 lg:mb-16">
    <h2 class="text-2xl font-bold mb-2 tracking-tight">IGET Vapes Available in {cityName}</h2>
    <p class="text-text-muted mb-6">Shop our full range of genuine IGET & Alibarbar disposable vapes with delivery to {cityName} and all {location.state} areas.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {categories.map(cat => (
        <a href={cat.href} class="group p-5 transition-all duration-250 hover:-translate-y-0.5" style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg);">
          <h3 class="font-bold text-text group-hover:text-accent transition-colors duration-250 mb-1">{cat.name}</h3>
          <p class="text-sm text-text-muted mb-3">Fast delivery to {cityName}</p>
          <span class="text-xs font-semibold text-accent">Shop Now →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Why Buy from Us -->
  <section class="mb-12 lg:mb-16">
    <h2 class="text-2xl font-bold mb-6 tracking-tight">Why Buy IGET Vapes Online in {cityName}?</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div class="p-6" style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-xl);">
        <div class="flex items-center gap-2.5 mb-3">
          <span class="w-8 h-8 flex items-center justify-center text-accent text-sm" style="background: rgba(233,69,96,0.08); border-radius: var(--radius-md);">🛒</span>
          <h3 class="text-lg font-bold tracking-tight">Skip the Vape Shop Queues</h3>
        </div>
        <p class="text-text-muted text-sm" style="line-height: 1.75;">No need to search for "vape shops near me" in {cityName}. Order online from the comfort of your home and get genuine IGET vapes delivered straight to your door.</p>
      </div>

      <div class="p-6" style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-xl);">
        <div class="flex items-center gap-2.5 mb-3">
          <span class="w-8 h-8 flex items-center justify-center text-accent text-sm" style="background: rgba(233,69,96,0.08); border-radius: var(--radius-md);">💰</span>
          <h3 class="text-lg font-bold tracking-tight">Best Prices in Australia</h3>
        </div>
        <p class="text-text-muted text-sm" style="line-height: 1.75;">Our online prices beat most {cityName} vape shops. Plus, save even more with our <a href="/mix-and-match" class="text-accent hover:underline">Mix & Match deals</a> — buy in bulk and pay less.</p>
      </div>

      <div class="p-6" style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-xl);">
        <div class="flex items-center gap-2.5 mb-3">
          <span class="w-8 h-8 flex items-center justify-center text-accent text-sm" style="background: rgba(233,69,96,0.08); border-radius: var(--radius-md);">✅</span>
          <h3 class="text-lg font-bold tracking-tight">100% Genuine Products</h3>
        </div>
        <p class="text-text-muted text-sm" style="line-height: 1.75;">Every IGET vape and Alibarbar vape we sell is sourced from authorised distributors. No fakes, no counterfeits — guaranteed authentic products delivered to {cityName}.</p>
      </div>

      <div class="p-6" style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-xl);">
        <div class="flex items-center gap-2.5 mb-3">
          <span class="w-8 h-8 flex items-center justify-center text-accent text-sm" style="background: rgba(233,69,96,0.08); border-radius: var(--radius-md);">📦</span>
          <h3 class="text-lg font-bold tracking-tight">Discreet & Fast Shipping</h3>
        </div>
        <p class="text-text-muted text-sm" style="line-height: 1.75;">All orders shipped in plain, discreet packaging via Australia Post. {cityName} orders typically arrive in {stateInfo.days} business days for just ${stateInfo.cost} flat-rate shipping.</p>
      </div>
    </div>
  </section>

  <!-- Popular Flavours CTA -->
  <section class="mb-12 lg:mb-16">
    <div class="relative overflow-hidden p-8 sm:p-10 text-center" style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-xl);">
      <h2 class="text-2xl font-bold mb-3 tracking-tight">150+ Vape Flavours Delivered to {cityName}</h2>
      <p class="text-text-muted max-w-xl mx-auto mb-6">From Watermelon Ice and Blueberry Raspberry to Cool Mint and Grape Ice — shop Australia's biggest range of genuine disposable vape flavours.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/products/jnr-cruiser" class="btn-primary">JNR Cruiser 12000</a>
        <a href="/products/iget-one" class="btn-secondary">IGET One 12000</a>
        <a href="/products/iget-bar-pro" class="btn-secondary">IGET Bar Pro</a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="mb-12 lg:mb-16">
    <h2 class="text-2xl font-bold mb-6 tracking-tight">Frequently Asked Questions — {cityName} Delivery</h2>
    <div class="space-y-3">
      <details class="group" style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg);">
        <summary class="p-5 cursor-pointer flex items-center justify-between font-semibold hover:text-accent transition-colors duration-250 list-none text-sm select-none">
          <span>How long does delivery take to {cityName}?</span>
          <svg class="w-4.5 h-4.5 text-text-muted group-open:rotate-180 transition-transform duration-300 flex-shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="px-5 pb-5 text-text-muted text-sm pt-4" style="line-height: 1.8; border-top: 1px solid var(--color-border-light);">
          Orders shipped to {cityName} typically arrive within {stateInfo.days} business days via Australia Post standard shipping. We dispatch orders Monday to Friday within 24 hours of receiving payment.
        </div>
      </details>

      <details class="group" style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg);">
        <summary class="p-5 cursor-pointer flex items-center justify-between font-semibold hover:text-accent transition-colors duration-250 list-none text-sm select-none">
          <span>How much does shipping cost to {cityName}?</span>
          <svg class="w-4.5 h-4.5 text-text-muted group-open:rotate-180 transition-transform duration-300 flex-shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="px-5 pb-5 text-text-muted text-sm pt-4" style="line-height: 1.8; border-top: 1px solid var(--color-border-light);">
          Shipping to {cityName} ({location.state}) is a flat rate of ${stateInfo.cost} AUD per order, regardless of how many items you purchase. There are no hidden fees or surcharges.
        </div>
      </details>

      <details class="group" style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg);">
        <summary class="p-5 cursor-pointer flex items-center justify-between font-semibold hover:text-accent transition-colors duration-250 list-none text-sm select-none">
          <span>Are the vapes you sell genuine?</span>
          <svg class="w-4.5 h-4.5 text-text-muted group-open:rotate-180 transition-transform duration-300 flex-shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="px-5 pb-5 text-text-muted text-sm pt-4" style="line-height: 1.8; border-top: 1px solid var(--color-border-light);">
          Yes — 100%. Every IGET vape and Alibarbar vape we sell is sourced directly from authorised distributors. We never sell counterfeit or grey-market products. Each product comes with authentic verification.
        </div>
      </details>

      <details class="group" style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg);">
        <summary class="p-5 cursor-pointer flex items-center justify-between font-semibold hover:text-accent transition-colors duration-250 list-none text-sm select-none">
          <span>What is the minimum order amount?</span>
          <svg class="w-4.5 h-4.5 text-text-muted group-open:rotate-180 transition-transform duration-300 flex-shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="px-5 pb-5 text-text-muted text-sm pt-4" style="line-height: 1.8; border-top: 1px solid var(--color-border-light);">
          The minimum order is $250 AUD. This helps us keep shipping costs low and ensures you get the best value. Use our <a href="/mix-and-match" class="text-accent hover:underline">Mix & Match</a> deals to easily reach the minimum while saving on bulk purchases.
        </div>
      </details>

      <details class="group" style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg);">
        <summary class="p-5 cursor-pointer flex items-center justify-between font-semibold hover:text-accent transition-colors duration-250 list-none text-sm select-none">
          <span>What payment methods do you accept?</span>
          <svg class="w-4.5 h-4.5 text-text-muted group-open:rotate-180 transition-transform duration-300 flex-shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="px-5 pb-5 text-text-muted text-sm pt-4" style="line-height: 1.8; border-top: 1px solid var(--color-border-light);">
          We accept Bank Transfer (EFT), PayID (instant transfer), and Bitcoin (BTC). Payment instructions are sent via email after you place your order. See our <a href="/payment-methods" class="text-accent hover:underline">Payment Methods</a> page for full details.
        </div>
      </details>
    </div>
  </section>

  <!-- SEO Content Block -->
  <section class="mb-12 lg:mb-16">
    <div class="p-6 lg:p-8" style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-xl);">
      <h2 class="text-xl font-bold mb-4 tracking-tight">Buy IGET Vapes Online — {cityName}, {location.state}</h2>
      <div class="text-text-muted text-sm space-y-3" style="line-height: 1.8;">
        <p>Looking to <strong>buy IGET vapes in {cityName}</strong>? IGET Vapes Original is Australia's #1 trusted online vape store, delivering genuine disposable vapes to {cityName} and all {location.state} suburbs. Skip the hassle of searching for "vape shops near me" — shop our premium range online and get fast, discreet delivery to your door.</p>
        <p>Our range includes the <strong>JNR Cruiser 12000 Puffs</strong>, <strong>IGET One 12000 Puffs</strong>, <strong>IGET Bar Pro 10000 Puffs</strong>, <strong>IGET Bar Plus S3</strong>, <strong>Alibarbar Ingot 9000 Puffs</strong>, and the <strong>Alibarbar Ice Adjust 12000 Puffs</strong>. With over 150 vape flavours to choose from, we have something for every taste.</p>
        <p>All {cityName} orders ship for just <strong>${stateInfo.cost} flat-rate</strong> via Australia Post and arrive within <strong>{stateInfo.days} business days</strong>. Every product is 100% genuine and sourced from authorised distributors.</p>
      </div>
    </div>
  </section>

  <!-- Back to All Locations -->
  <div class="text-center">
    <a href="/delivery" class="btn-secondary py-3.5 px-8" style="border-radius: var(--radius-lg);">← View All Delivery Locations</a>
  </div>
</BaseLayout>
