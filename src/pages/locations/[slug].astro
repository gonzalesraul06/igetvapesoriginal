---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/layout/Breadcrumbs.astro';
import SchemaMarkup from '@components/seo/SchemaMarkup.astro';
import { productCategories } from '@data/navigation';
import { MINIMUM_ORDER } from '@utils/storeConfig';

type LocationEntry = CollectionEntry<'locations'>;
type LocationData = LocationEntry['data'];

interface RelatedLocation {
  slug: string;
  name: string;
}

interface LocationFaq {
  q: string;
  a: string;
  links?: Array<{ text: string; href: string }>;
}

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map((location) => ({
    params: { slug: location.id },
    props: { location: location.data },
  }));
}

const { slug } = Astro.params;
const { location } = Astro.props as { location: LocationData };
const siteUrl = 'https://igetvapeshub.com';
const allLocations = await getCollection('locations');

function getCityName(title: string, id?: string) {
  const derived = title.replace(/^IGET Vapes\s+/, '').split(/\s*[—–-]\s*/)[0].trim();
  if (derived) return derived;
  return (id ?? '').split('-').map((segment) => `${segment.charAt(0).toUpperCase()}${segment.slice(1)}`).join(' ');
}

const cityName = getCityName(location.title, slug);
const shippingRates: Record<string, { cost: number; days: string }> = {
  'New South Wales': { cost: 10, days: '2-4' },
  Victoria: { cost: 10, days: '2-4' },
  'Australian Capital Territory': { cost: 10, days: '2-4' },
  Queensland: { cost: 15, days: '3-5' },
  'South Australia': { cost: 15, days: '3-5' },
  'Western Australia': { cost: 20, days: '4-7' },
  Tasmania: { cost: 20, days: '4-7' },
  'Northern Territory': { cost: 25, days: '5-10' },
};

const stateInfo = shippingRates[location.state] ?? { cost: 15, days: '3-7' };
const categories = productCategories.filter((category) => category.slug !== 'mix-and-match');
const relatedLocations: RelatedLocation[] = allLocations
  .filter((entry) => entry.data.state === location.state && entry.id !== slug)
  .map((entry) => ({ slug: entry.id, name: getCityName(entry.data.title, entry.id) }))
  .sort((left, right) => left.name.localeCompare(right.name))
  .slice(0, 4);

const metaTitle = `IGET Vapes ${cityName} | Fast Delivery`;
const metaDescription = `Shop genuine IGET and Alibarbar vapes with fast delivery to ${cityName}, ${location.state}. Browse bestselling devices, S3 pods, and mix and match bundles online.`;
const locationFaqs: LocationFaq[] = [
  {
    q: `How long does delivery take to ${cityName}?`,
    a: `Orders shipped to ${cityName} typically arrive within ${stateInfo.days} business days via Australia Post. Dispatch runs Monday to Friday once payment is confirmed.`,
  },
  {
    q: `How much does shipping cost to ${cityName}?`,
    a: `Shipping to ${cityName}, ${location.state} is a flat rate of $${stateInfo.cost} AUD per order, regardless of the number of items in your cart.`,
  },
  {
    q: 'Are the products on this site genuine?',
    a: 'Yes. Every IGET and Alibarbar product sold through IGET Vapes Original is sourced from authorised supply and backed by our authenticity commitment.',
  },
  {
    q: 'What is the minimum order amount?',
    a: `The minimum order is $${MINIMUM_ORDER} AUD. Mix and Match bundles are the easiest way to reach the threshold while keeping flavour choice flexible.`,
    links: [{ text: 'Mix and Match deals', href: '/mix-and-match' }],
  },
  {
    q: 'What payment methods do you accept?',
    a: 'We accept Bank Transfer, PayID, and Bitcoin. Payment instructions are sent by email after the order is placed.',
    links: [{ text: 'Payment methods', href: '/payment-methods' }],
  },
];

const categoryItems = categories.map((category, index) => ({
  name: category.name,
  url: `${siteUrl}${category.href}`,
  position: index + 1,
}));
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  keywords={`IGET vapes ${cityName}, ${cityName} vape delivery, buy vapes online ${cityName}, Alibarbar ${cityName}, ${location.state} vape delivery`}
>
  <SchemaMarkup type="organization" />
  <SchemaMarkup type="collection" data={{ name: `IGET Vapes ${cityName}`, description: metaDescription, url: `${siteUrl}/locations/${slug}` }} />
  <SchemaMarkup type="itemlist" data={{ name: `${cityName} delivery collections`, description: `Popular IGET and Alibarbar ranges available for delivery to ${cityName}.`, items: categoryItems }} />
  <SchemaMarkup type="faq" data={{ questions: locationFaqs.map(({ q, a }) => ({ q, a })) }} />
  <Breadcrumbs items={[{ name: 'Delivery Locations', href: '/delivery' }, { name: cityName }]} />

  <div class="page-header" data-reveal>
    <h1>IGET Vapes Delivery in {cityName}</h1>
    <p>{location.description}</p>
  </div>

  <section class="grid grid-cols-1 gap-4 sm:grid-cols-3" data-reveal data-reveal-delay="40">
    <article class="card p-5 text-center">
      <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-text-muted">Shipping</p>
      <h2 class="mt-3 text-4xl text-text">${stateInfo.cost}</h2>
      <p class="mt-2 text-sm text-text-muted">Flat rate per order to {cityName}</p>
    </article>

    <article class="card p-5 text-center">
      <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-text-muted">Delivery window</p>
      <h2 class="mt-3 text-4xl text-text">{stateInfo.days}</h2>
      <p class="mt-2 text-sm text-text-muted">Business days via Australia Post</p>
    </article>

    <article class="card p-5 text-center">
      <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-text-muted">Store promise</p>
      <h2 class="mt-3 text-4xl text-text">Genuine</h2>
      <p class="mt-2 text-sm text-text-muted">Authorised supply with adult-only checkout rules</p>
    </article>
  </section>

  <section class="mt-10" data-reveal data-reveal-delay="80">
    <div class="card p-6 lg:p-8">
      <span class="eyebrow">
        <span class="eyebrow-dot"></span>
        Popular ranges for {cityName}
      </span>
      <h2 class="mt-5 text-4xl text-text">Choose the right line before you choose the flavour.</h2>
      <p class="mt-4 max-w-3xl text-sm leading-7 text-text-muted lg:text-base">
        These are the most useful entry points for adult shoppers in {cityName}: high-puff devices, refillable value, and flavour-forward Alibarbar options with Australia-wide support.
      </p>

      <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {categories.map((category) => (
          <a href={category.href} class="rounded-[1.2rem] border border-border/60 bg-white/60 px-4 py-4 transition-colors duration-200 hover:border-accent/40 hover:bg-white/72">
            <p class="font-semibold text-text">{category.name}</p>
            <p class="mt-2 text-sm text-text-muted">Fast delivery to {cityName}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="mt-10 grid grid-cols-1 gap-5 md:grid-cols-2" data-reveal data-reveal-delay="120">
    <article class="card p-6">
      <h2 class="text-4xl text-text">Why adults order online for {cityName}</h2>
      <p class="mt-4 text-sm leading-7 text-text-muted lg:text-base">
        The advantage is not just convenience. It is clearer product comparison, sharper delivery expectations, and less guesswork than local stock-hunting or unreliable marketplace listings.
      </p>
      <div class="mt-5 space-y-3 text-sm text-text-muted">
        <p><strong>Authenticity first:</strong> sourced through authorised supply, not grey-market listings.</p>
        <p><strong>Better range coverage:</strong> compare IGET, S3 pods, and Alibarbar in one place.</p>
        <p><strong>Clearer value:</strong> mix and match bundles make the minimum order easier to reach.</p>
      </div>
    </article>

    <article class="card p-6">
      <h2 class="text-4xl text-text">Helpful internal links</h2>
      <p class="mt-4 text-sm leading-7 text-text-muted lg:text-base">
        Use these pages if you need broader ordering context before you submit checkout details.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="/mix-and-match" class="btn-secondary text-sm">Mix and Match deals</a>
        <a href="/shipping-policy" class="btn-secondary text-sm">Shipping policy</a>
        <a href="/payment-methods" class="btn-secondary text-sm">Payment methods</a>
        <a href="/delivery" class="btn-secondary text-sm">All delivery locations</a>
      </div>
    </article>
  </section>

  <section class="mt-10 space-y-3" data-reveal data-reveal-delay="160">
    <h2 class="text-4xl text-text">Frequently asked questions for {cityName}</h2>
    {locationFaqs.map((faq) => (
      <details class="faq-item">
        <summary>{faq.q}</summary>
        <div class="px-4 pb-4 text-sm text-text-muted">
          <p>{faq.a}</p>
          {faq.links && faq.links.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-3">
              {faq.links.map((link) => (
                <a href={link.href} class="text-accent hover:underline">{link.text}</a>
              ))}
            </div>
          )}
        </div>
      </details>
    ))}
  </section>

  {relatedLocations.length > 0 && (
    <section class="mt-10" data-reveal data-reveal-delay="200">
      <h2 class="text-4xl text-text">More delivery areas in {location.state}</h2>
      <div class="mt-5 flex flex-wrap gap-3">
        {relatedLocations.map((related) => (
          <a href={`/locations/${related.slug}`} class="btn-secondary text-sm">{related.name}</a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
