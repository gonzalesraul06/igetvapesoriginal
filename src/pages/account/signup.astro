---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/layout/Breadcrumbs.astro';
---

<BaseLayout title="Create Account — IGET Vapes Australia" noindex={true}>
  <Breadcrumbs items={[{ name: 'Account', href: '/account' }, { name: 'Sign Up' }]} />

  <div class="max-w-md">
    <h1 class="text-3xl font-extrabold mb-6">Create Account</h1>

    <div class="card p-6">
      <form class="space-y-4">
        <div>
          <label for="signup-name" class="block text-sm font-medium mb-1">Full Name</label>
          <input type="text" id="signup-name" name="name" required class="w-full bg-white border border-border rounded-xl px-4 py-3 text-text placeholder-text-muted/50 focus:border-accent focus:ring-2 focus:ring-accent/10 focus:outline-none transition-all" />
        </div>
        <div>
          <label for="signup-email" class="block text-sm font-medium mb-1">Email</label>
          <input type="email" id="signup-email" name="email" required class="w-full bg-white border border-border rounded-xl px-4 py-3 text-text placeholder-text-muted/50 focus:border-accent focus:ring-2 focus:ring-accent/10 focus:outline-none transition-all" />
        </div>
        <div>
          <label for="signup-password" class="block text-sm font-medium mb-1">Password</label>
          <input type="password" id="signup-password" name="password" required minlength="8" class="w-full bg-white border border-border rounded-xl px-4 py-3 text-text placeholder-text-muted/50 focus:border-accent focus:ring-2 focus:ring-accent/10 focus:outline-none transition-all" />
        </div>
        <div>
          <label for="signup-confirm" class="block text-sm font-medium mb-1">Confirm Password</label>
          <input type="password" id="signup-confirm" name="confirmPassword" required minlength="8" class="w-full bg-white border border-border rounded-xl px-4 py-3 text-text placeholder-text-muted/50 focus:border-accent focus:ring-2 focus:ring-accent/10 focus:outline-none transition-all" />
        </div>
        <div class="flex items-start gap-2">
          <input type="checkbox" id="age-confirm" required class="mt-1" />
          <label for="age-confirm" class="text-sm text-text-muted">I confirm that I am 18 years of age or older</label>
        </div>
        <button type="submit" class="btn-primary w-full py-3">Create Account</button>
      </form>
      <p class="text-center text-sm text-text-muted mt-4">
        Already have an account? <a href="/account" class="text-accent hover:underline">Log in</a>
      </p>
    </div>
  </div>
</BaseLayout>
