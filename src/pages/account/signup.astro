---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/layout/Breadcrumbs.astro';
---

<BaseLayout title="Create Account — IGET Vapes Australia" noindex={true}>
  <Breadcrumbs items={[{ name: 'Account', href: '/account' }, { name: 'Sign Up' }]} />

  <div class="max-w-md">
    <div class="page-header">
      <h1>Create Account</h1>
    </div>

    <div class="card p-6">
      <form class="space-y-4">
        <div>
          <label for="signup-name" class="form-label">Full Name</label>
          <input type="text" id="signup-name" name="name" required class="form-input" />
        </div>
        <div>
          <label for="signup-email" class="form-label">Email</label>
          <input type="email" id="signup-email" name="email" required class="form-input" />
        </div>
        <div>
          <label for="signup-password" class="form-label">Password</label>
          <input type="password" id="signup-password" name="password" required minlength="8" class="form-input" />
        </div>
        <div>
          <label for="signup-confirm" class="form-label">Confirm Password</label>
          <input type="password" id="signup-confirm" name="confirmPassword" required minlength="8" class="form-input" />
        </div>
        <div class="flex items-start gap-2">
          <input type="checkbox" id="age-confirm" required class="mt-1" />
          <label for="age-confirm" class="text-sm text-text-muted">I confirm that I am 18 years of age or older</label>
        </div>
        <button type="submit" class="btn-primary w-full py-3">Create Account</button>
      </form>
      <p class="text-center text-sm text-text-muted mt-4">
        Already have an account? <a href="/account" class="text-accent hover:underline">Log in</a>
      </p>
    </div>
  </div>
</BaseLayout>
