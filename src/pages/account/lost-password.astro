---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/layout/Breadcrumbs.astro';
---

<BaseLayout title="Reset Password — IGET Vapes Australia" noindex={true}>
  <Breadcrumbs items={[{ name: 'Account', href: '/account' }, { name: 'Lost Password' }]} />

  <div class="max-w-md">
    <h1 class="text-3xl font-extrabold mb-6">Reset Password</h1>

    <div class="card p-6">
      <p class="text-gray-300 text-sm mb-4">Enter your email address and we'll send you a link to reset your password.</p>
      <form class="space-y-4">
        <div>
          <label for="reset-email" class="block text-sm font-medium mb-1">Email Address</label>
          <input type="email" id="reset-email" name="email" required class="w-full bg-primary border border-gray-600 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:border-accent focus:outline-none" />
        </div>
        <button type="submit" class="btn-primary w-full py-3">Send Reset Link</button>
      </form>
      <p class="text-center text-sm text-gray-400 mt-4">
        <a href="/account" class="text-accent hover:underline">Back to login</a>
      </p>
    </div>
  </div>
</BaseLayout>
