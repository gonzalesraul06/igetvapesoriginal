---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/layout/Breadcrumbs.astro';
---

<BaseLayout title="My Orders — IGET Vapes Australia" noindex={true}>
  <Breadcrumbs items={[{ name: 'Account', href: '/account' }, { name: 'Orders' }]} />

  <h1 class="text-3xl font-extrabold mb-6">My Orders</h1>

  <div class="card p-6">
    <p class="text-text-muted text-center py-8">No orders found. <a href="/" class="text-accent hover:underline">Start shopping</a></p>
  </div>
</BaseLayout>
