---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/layout/Breadcrumbs.astro';
import { formatPrice } from '@utils/formatPrice';

const products = await getCollection('products');

const bundles = [
  { qty: 3, discount: 5, label: 'Buy 3' },
  { qty: 5, discount: 10, label: 'Buy 5' },
  { qty: 10, discount: 15, label: 'Buy 10' },
];
---

<BaseLayout
  title="Mix & Match Vape Deals — Save on Bulk Orders | IGET Vapes"
  description="Mix and match your favourite IGET vape flavours and save up to 15%. Bundle deals on JNR Cruiser, IGET One, Bar Pro and more."
>
  <Breadcrumbs items={[{ name: 'Mix & Match' }]} />

  <div class="page-header">
    <h1>Mix &amp; Match — Save More</h1>
    <p>Pick any combination of flavours across all our product ranges and save on bulk orders. The more you buy, the more you save!</p>
  </div>

  <!-- Discount tiers -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12">
    {bundles.map(bundle => (
      <div class="card p-6 text-center border border-border hover:border-accent hover:shadow-lg transition-all duration-200 rounded-xl">
        <div class="text-3xl font-extrabold text-accent mb-1">{bundle.discount}% OFF</div>
        <p class="text-text-muted">{bundle.label} or more</p>
      </div>
    ))}
  </div>

  <!-- Category quick links -->
  <h2 class="text-2xl font-bold mb-6">Choose Your Products</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
    {products.map(p => (
      <a href={`/products/${p.data.slug}`} class="card p-4 flex items-center gap-4 hover:border-accent border border-border hover:shadow-md transition-all duration-200 rounded-xl">
        <img
          src={p.data.image}
          alt={`${p.data.name} — Mix & Match Vape Deals Australia`}
          class="w-16 h-16 rounded-lg object-cover"
          loading="lazy"
          width="64"
          height="64"
        />
        <div>
          <h3 class="font-semibold text-sm">{p.data.name}</h3>
          <p class="text-xs text-text-muted">{p.data.flavours.filter(f => f.inStock).length} flavours in stock • From {formatPrice(p.data.price)}</p>
        </div>
      </a>
    ))}
  </div>

  <!-- How it works -->
  <div class="card p-6 lg:p-8 rounded-xl">
    <h2 class="text-xl font-bold mb-4">How It Works</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
      <div>
        <div class="text-3xl mb-2">1️⃣</div>
        <h3 class="font-semibold mb-1">Choose Your Flavours</h3>
        <p class="text-sm text-text-muted">Browse any category and add flavours to your cart</p>
      </div>
      <div>
        <div class="text-3xl mb-2">2️⃣</div>
        <h3 class="font-semibold mb-1">Hit the Quantity</h3>
        <p class="text-sm text-text-muted">Add 3, 5, or 10+ items for increasing discounts</p>
      </div>
      <div>
        <div class="text-3xl mb-2">3️⃣</div>
        <h3 class="font-semibold mb-1">Save Automatically</h3>
        <p class="text-sm text-text-muted">Discount applied at checkout — no code needed</p>
      </div>
    </div>
  </div>
</BaseLayout>
