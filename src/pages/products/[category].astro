const comparisonItems = comparisonGuides[product.slug] ?? comparisonGuides['iget-bar-pro'];
const trustBullets = [
  `The ${product.name} collection page surfaces puff count, flavour breadth, pricing, and availability in one place so adults can compare the range without extra guesswork.`,
  'Shipping thresholds, state-based delivery pricing, and checkout rules are made clear before purchase, which reduces cart friction and support back-and-forth.',
  reviewCount > 0
    ? `On-site reviews and rating signals help show how the range performs after purchase instead of relying on vague manufacturer-only claims.`
    : 'Availability and flavour coverage are maintained from the product content layer so the range page stays aligned with the catalogue.',
  'The comparison cards below route directly to higher-capacity, lower-cost, or more specialised alternatives when this range is not the right fit.',
];
const trustStats = [
  { label: 'Flavours listed', value: String(product.flavours.length) },
  { label: 'Currently in stock', value: String(inStockCount) },
  { label: 'Review signals', value: reviewCount > 0 ? `${reviewCount} reviews` : 'Live catalogue' },
];
const trustLinks = [
  { text: 'Delivery locations', href: '/delivery' },
  { text: 'Mix and match bundles', href: '/mix-and-match' },
  { text: 'Contact support', href: '/contact' },
];

const faqSchema = seo.faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: seo.faqs.map((f: {q: string; a: string}) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: product.name,
  description: seo.description,
  url: categoryUrl,
  numberOfItems: product.flavours.length,
  itemListElement: product.flavours.slice(0, 20).map((f: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: `${f.name} — ${product.name}`,
    url: `${siteUrl}/products/${product.slug}/${f.slug}`,
  })),
};

const productGroupSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: seo.intro,
  image: product.image.startsWith('http') ? product.image : `${siteUrl}${product.image}`,
  brand: { '@type': 'Brand', name: product.slug.startsWith('alibarbar') ? 'Alibarbar' : 'IGET' },
  offers: {
    '@type': 'AggregateOffer',
    lowPrice: product.price,
    highPrice: product.price,
    priceCurrency: 'AUD',
    offerCount: inStockCount,
    availability: inStockCount > 0 ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
  },
  aggregateRating: reviewCount > 0 ? {
    '@type': 'AggregateRating',
    ratingValue: avgRating,
    reviewCount,
  } : undefined,
};
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  image={product.image}
>
  <SchemaMarkup type="collection" data={{ name: product.name, description: seo.description, url: categoryUrl }} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(productGroupSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <Breadcrumbs items={[{ name: product.name }]} />

  <div class="page-stack">

  <!-- Hero Section -->
  <div class="bg-white p-6 sm:p-8" style="border: 1px solid var(--color-border-light); border-radius: var(--radius-xl);">
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight mb-3" style="line-height: 1.08; letter-spacing: -0.025em;">
      {seo.h1}
    </h1>
    <p class="text-base sm:text-lg text-accent font-semibold mb-5">{seo.h1Accent}</p>
    <div class="flex flex-wrap items-center gap-2 text-xs text-text-muted mb-5">
      <span class="inline-flex items-center gap-1.5 bg-white px-3.5 py-2 font-medium" style="border: 1px solid var(--color-border-light); border-radius: var(--radius-md);">{product.puffs.toLocaleString()} Puffs</span>
      <span class="inline-flex items-center gap-1.5 bg-white px-3.5 py-2 font-medium" style="border: 1px solid var(--color-border-light); border-radius: var(--radius-md);">From {formatPrice(product.price)}</span>
      <span class="inline-flex items-center gap-1.5 bg-white px-3.5 py-2 font-medium" style="border: 1px solid var(--color-border-light); border-radius: var(--radius-md);">
        <span class="w-2 h-2 rounded-full bg-green animate-pulse"></span>
        {inStockCount} in stock
      </span>
      {product.isNew && <span class="badge-new">New</span>}
    </div>
    <p class="text-text-muted text-sm sm:text-base max-w-3xl" style="line-height: 1.7;">{seo.intro}</p>
  </div>

  <!-- Quick Spec Highlights -->
  {seo.highlights.length > 0 && (
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
      {seo.highlights.map((h: {icon: 'battery' | 'capacity' | 'coil' | 'flavours' | 'ice' | 'price' | 'puffs' | 'system' | 'weight'; label: string; value: string}) => (
        <div class="bg-white p-5 text-center transition-shadow duration-250" style="border: 1px solid var(--color-border-light); border-radius: var(--radius-lg);">
          <div class="mb-3 flex justify-center text-accent-dark">
            <LineIcon name={h.icon} class="h-7 w-7" title={h.label} />
          </div>
          <div class="text-[10px] uppercase tracking-[0.14em] font-semibold text-text-muted mb-0.5">{h.label}</div>
          <div class="font-bold text-text text-xl tracking-tight">{h.value}</div>
        </div>
      ))}
    </div>
  )}

  <!-- Product Grid -->
  <div>
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl sm:text-2xl font-bold tracking-tight">All {product.flavours.length} {product.name} Flavours</h2>
      <span class="text-sm text-text-muted hidden sm:block font-medium">{inStockCount} available</span>
    </div>
    <ProductGrid
      flavours={product.flavours}
      categorySlug={product.slug}
      categoryName={product.name}
    />
  </div>

  <!-- Buying Guide -->
  {seo.buyingGuide && (
    <div class="p-6 sm:p-8 mb-12" style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg);">
      <h2 class="text-xl sm:text-2xl font-bold mb-4 tracking-tight">Buying Guide — {product.name}</h2>
      <p class="text-text-muted text-sm sm:text-base" style="line-height: 1.75;">{seo.buyingGuide}</p>
    </div>
  )}

  <ComparisonCards
    eyebrow="Collection comparison"
    title={`How ${product.name} stacks up against the main alternatives.`}
    intro="Most buyers are not choosing in a vacuum. These comparison routes help adults decide whether this range is the strongest fit or whether another line better matches their priorities."
    items={comparisonItems}
  />

  <TrustModule
    eyebrow="Collection trust signals"
    title={`Why adults use this page to evaluate ${product.name}.`}
    intro="Search-focused collection pages should explain why the range is credible, how it is merchandised, and where shoppers should go next if they need a different format."
    reviewer="IGET Vapes Hub merchandising team"
    reviewedOn="March 2026"
    bullets={trustBullets}
    stats={trustStats}
    links={trustLinks}
  />

  <!-- Key Features -->
  {seo.features.length > 0 && (
    <div class="mb-12">
      <h2 class="text-xl sm:text-2xl font-bold mb-5 tracking-tight">Key Features</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {seo.features.map((f: {title: string; desc: string}) => (
          <div class="card p-6">
            <h3 class="font-bold text-text text-base mb-2">{f.title}</h3>
            <p class="text-text-muted text-sm" style="line-height: 1.7;">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- FAQ Section -->
  {seo.faqs.length > 0 && (
    <div class="mb-12">
      <h2 class="text-xl sm:text-2xl font-bold mb-5 tracking-tight">Frequently Asked Questions — {product.name}</h2>
      <div class="space-y-3">
        {seo.faqs.map((faq: {q: string; a: string}) => (
          <details class="bg-white group transition-all duration-250" style="border: 1px solid var(--color-border-light); border-radius: var(--radius-lg);">
            <summary class="p-5 cursor-pointer flex items-center justify-between font-semibold hover:text-accent transition-colors duration-200 list-none text-sm sm:text-base select-none">
              <span class="pr-6">{faq.q}</span>
              <svg class="w-4.5 h-4.5 text-text-muted group-open:rotate-180 transition-transform duration-300 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 text-text-muted text-sm" style="border-top: 1px solid var(--color-border-light); padding-top: 1rem; line-height: 1.75;">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  )}

  <!-- Related Blog Links -->
  {seo.relatedLinks.length > 0 && (
    <div class="flex flex-wrap items-center gap-2.5 mb-12">
      <span class="text-sm text-text-muted py-2 font-medium">Related Guides:</span>
      {seo.relatedLinks.map((link: {text: string; href: string}) => (
        <a href={link.href} class="text-xs bg-white text-accent hover:text-accent-dark px-4 py-2 transition-all duration-200 font-medium" style="border: 1px solid var(--color-border-light); border-radius: var(--radius-md);">{link.text}</a>
      ))}
    </div>
  )}

  <!-- SEO Content Block -->
  {seo.seoContent && (
    <div class="p-6 sm:p-8 mb-12
      [&_p]:text-text-muted [&_p]:mb-4 [&_p:last-child]:mb-0 [&_p]:text-sm [&_p]:sm:text-base
      [&_strong]:text-text
      [&_a]:text-accent [&_a]:underline [&_a]:hover:text-accent-dark"
      style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg); line-height: 1.8;"
      set:html={seo.seoContent}
    />
  )}

  <div class="mb-12 p-6 sm:p-8" style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg);">
    <h2 class="text-xl sm:text-2xl font-bold mb-3 tracking-tight">Fast Delivery Across Australia</h2>
    <p class="text-text-muted text-sm sm:text-base mb-5" style="line-height: 1.75;">We deliver genuine {product.name} orders to major metro and regional areas, with <a href="/mix-and-match" class="text-accent hover:text-accent-dark">Mix &amp; Match bundles</a> and <a href="/delivery" class="text-accent hover:text-accent-dark">location-specific delivery pages</a> to help shoppers compare options faster.</p>
    <div class="flex flex-wrap gap-3">
      {deliveryLinks.map((link) => (
        <a href={link.href} class="btn-secondary text-sm">{link.name} delivery</a>
      ))}
      <a href="/delivery" class="btn-secondary text-sm">All delivery locations</a>
    </div>
  </div>

  <!-- Explore Other Models -->
  <div>
    <h2 class="text-xl sm:text-2xl font-bold mb-5 tracking-tight">Explore Other Models</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
      {productCategories.filter(c => c.slug !== product.slug && c.slug !== 'mix-and-match').map(c => (
        <a href={c.href} class="group bg-white p-4 text-center transition-all duration-250 hover:text-accent" style="border: 1px solid var(--color-border-light); border-radius: var(--radius-lg);">
          <span class="block text-xs font-semibold transition-colors duration-200 leading-tight">
            {c.name.replace(/\d+\sPUFFS|SAVE$/g, '').trim()}
          </span>
        </a>
      ))}
      <a href="/mix-and-match" class="group p-4 text-center transition-all duration-250" style="background: rgba(233,69,96,0.05); border: 1px solid rgba(233,69,96,0.15); border-radius: var(--radius-lg);">
        <span class="block text-xs font-semibold text-accent transition-colors duration-200 leading-tight">
          Mix & Match
        </span>
      </a>
    </div>
  </div>

  <!-- Back to all products -->
  <div class="text-center pb-2">
    <a href="/" class="btn-secondary py-3 px-8 text-sm" style="border-radius: var(--radius-lg);">&larr; Back to All Products</a>
  </div>
  </div>
</BaseLayout>
