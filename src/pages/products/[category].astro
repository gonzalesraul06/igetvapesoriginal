      { text: 'Alibarbar Ice Adjust Full Review', href: '/blog/alibarbar-ice-adjust-review' },
      { text: 'Alibarbar Complete Guide', href: '/blog/alibarbar-vapes-complete-guide' },
      { text: 'Best Menthol Vapes Australia', href: '/blog/best-menthol-vapes-australia' },
    ],
    seoContent: '<p>The <strong>Alibarbar Ice Adjust 12000 Puffs</strong> is a groundbreaking disposable vape with <strong>adjustable ice intensity</strong>. The innovative twist-dial airflow ring lets you control the menthol/cooling sensation in real time — something no other disposable vape in Australia offers.</p><p>With <strong>15 premium Alibarbar flavours</strong> and 12,000 puffs from a 20ml capacity, the Ice Adjust delivers both longevity and customisation. Whether you want a barely-there cool breeze with your Mango Magic or a full arctic blast with your Watermelon — the choice is yours.</p><p>Buy the Alibarbar Ice Adjust online at IGET Vapes Original with <strong>fast Australia-wide delivery</strong>. All flavours in stock with genuine product guarantee. We deliver to Sydney, Melbourne, Brisbane, Perth, Adelaide, Canberra, Gold Coast, Hobart, Darwin and all regional areas across Australia.</p>',
  },
};

const seo = categorySEO[product.slug] || {
  title: `${product.name} — ${product.puffs} Puffs | Buy Online Australia`,
  description: `Shop ${product.name} with ${product.flavours.length} flavours. ${product.puffs} puffs, from ${formatPrice(product.price)}. Fast delivery Australia-wide.`,
  h1: product.name,
  h1Accent: `${product.puffs.toLocaleString()} Puffs — Buy Online Australia`,
  intro: product.description,
  highlights: [],
  buyingGuide: '',
  features: [],
  faqs: [],
  relatedLinks: [],
  seoContent: '',
};

const faqSchema = seo.faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: seo.faqs.map((f: {q: string; a: string}) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: product.name,
  description: seo.description,
  url: categoryUrl,
  numberOfItems: product.flavours.length,
  itemListElement: product.flavours.slice(0, 20).map((f: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: `${f.name} — ${product.name}`,
    url: `${siteUrl}/products/${product.slug}/${f.slug}`,
  })),
};

const productGroupSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: seo.intro,
  image: product.image.startsWith('http') ? product.image : `${siteUrl}${product.image}`,
  brand: { '@type': 'Brand', name: product.slug.startsWith('alibarbar') ? 'Alibarbar' : 'IGET' },
  offers: {
    '@type': 'AggregateOffer',
    lowPrice: product.price,
    highPrice: product.price,
    priceCurrency: 'AUD',
    offerCount: inStockCount,
    availability: inStockCount > 0 ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
  },
  aggregateRating: reviewCount > 0 ? {
    '@type': 'AggregateRating',
    ratingValue: avgRating,
    reviewCount,
  } : undefined,
};
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  image={product.image}
>
  <SchemaMarkup type="breadcrumb" data={{ items: [{ name: 'Home', url: siteUrl }, { name: product.name, url: categoryUrl }] }} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(productGroupSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <Breadcrumbs items={[{ name: product.name }]} />

  <!-- Hero Section -->
  <div class="mb-10">
    <h1 class="text-3xl lg:text-4xl font-extrabold mb-2">
      {seo.h1} — <span class="text-accent">{seo.h1Accent}</span>
    </h1>
    <div class="flex flex-wrap items-center gap-4 text-sm text-gray-400 mb-4">
      <span>{product.puffs.toLocaleString()} Puffs</span>
      <span>•</span>
      <span>From {formatPrice(product.price)}</span>
      <span>•</span>
      <span>{inStockCount} of {product.flavours.length} flavours in stock</span>
      {reviewCount > 0 && (
        <>
          <span>•</span>
          <span>★ {avgRating} ({reviewCount} reviews)</span>
        </>
      )}
      {product.isNew && <span class="badge-new">New</span>}
    </div>
    <p class="text-gray-300 text-lg leading-relaxed max-w-4xl">{seo.intro}</p>
  </div>

  <!-- Quick Spec Highlights -->
  {seo.highlights.length > 0 && (
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-10">
      {seo.highlights.map((h: {icon: string; label: string; value: string}) => (
        <div class="bg-surface rounded-xl p-4 text-center border border-border">
          <div class="text-2xl mb-1">{h.icon}</div>
          <div class="text-xs text-gray-400">{h.label}</div>
          <div class="font-bold text-white text-lg">{h.value}</div>
        </div>
      ))}
    </div>
  )}

  <!-- Product Grid -->
  <div class="mb-10">
    <h2 class="text-xl font-bold mb-5">All {product.flavours.length} {product.name} Flavours</h2>
    <ProductGrid
      flavours={product.flavours}
      categorySlug={product.slug}
      categoryName={product.name}
    />
  </div>

  <!-- Buying Guide -->
  {seo.buyingGuide && (
    <div class="bg-surface rounded-2xl p-6 lg:p-8 border border-border mb-10">
      <h2 class="text-xl font-bold mb-3">Buying Guide — {product.name}</h2>
      <p class="text-gray-300 leading-relaxed">{seo.buyingGuide}</p>
    </div>
  )}

  <!-- Key Features -->
  {seo.features.length > 0 && (
    <div class="mb-10">
      <h2 class="text-xl font-bold mb-5">Key Features</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {seo.features.map((f: {title: string; desc: string}) => (
          <div class="bg-surface rounded-xl p-5 border border-border">
            <h3 class="font-bold text-white mb-2">{f.title}</h3>
            <p class="text-gray-300 text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- FAQ Section -->
  {seo.faqs.length > 0 && (
    <div class="mb-10">
      <h2 class="text-xl font-bold mb-5">Frequently Asked Questions — {product.name}</h2>
      <div class="space-y-3">
        {seo.faqs.map((faq: {q: string; a: string}) => (
          <details class="bg-surface rounded-xl border border-border group">
            <summary class="p-5 cursor-pointer flex items-center justify-between font-semibold hover:text-accent transition-colors list-none text-sm">
              <span>{faq.q}</span>
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 text-gray-300 text-sm leading-relaxed border-t border-border/50 pt-4">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  )}

  <!-- Related Blog Links -->
  {seo.relatedLinks.length > 0 && (
    <div class="flex flex-wrap gap-3 mb-10">
      <span class="text-sm text-gray-400 py-2">Related Guides:</span>
      {seo.relatedLinks.map((link: {text: string; href: string}) => (
        <a href={link.href} class="text-sm bg-surface border border-border text-accent hover:border-accent px-4 py-2 rounded-full transition-colors">{link.text}</a>
      ))}
    </div>
  )}

  <!-- SEO Content Block -->
  {seo.seoContent && (
    <div class="bg-surface rounded-2xl p-6 lg:p-8 border border-border mb-10
      [&_p]:text-gray-300 [&_p]:leading-relaxed [&_p]:mb-4 [&_p:last-child]:mb-0
      [&_strong]:text-white
      [&_a]:text-accent [&_a]:underline [&_a]:hover:text-white"
      set:html={seo.seoContent}
    />
  )}

  <!-- Back to all products -->
  <div class="text-center">
    <a href="/" class="btn-secondary">← Back to All Products</a>
  </div>
</BaseLayout>
