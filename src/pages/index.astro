/* ── FAQs targeting user-searched keywords ── */
const faqs = [
  {
    q: 'What is an IGET vape and where can I buy IGET vapes in Australia?',
    a: 'IGET vapes are premium disposable vaping devices from one of Australia\'s leading vape brands. You can buy IGET vapes online right here at IGET Vapes Original — Australia\'s #1 trusted vape shop. We stock IGET Bar Pro, IGET One, JNR Cruiser, IGET S3, Alibarbar Ingot and Alibarbar Ice Adjust with over 150 flavours available.',
