    price: 50,
    puffs: '12,000',
    badge: null,
    description: 'Alibarbar Ice Adjust — adjustable ice intensity with premium alibarbar vape flavours.',
    productImages: [
      '/images/products/alibarbar-ice-adjust/alibarbar-ice-adjust-watermelon.webp',
      '/images/products/alibarbar-ice-adjust/alibarbar-ice-adjust-blueberry-blast.webp',
      '/images/products/alibarbar-ice-adjust/alibarbar-ice-adjust-mango-magic.webp',
      '/images/products/alibarbar-ice-adjust/alibarbar-ice-adjust-strawberry-kiwi.webp',
    ],
  },
];

/* ── FAQs targeting user-searched keywords ── */
const faqs = [
  {
    q: 'What is an IGET vape and where can I buy IGET vapes in Australia?',
    a: 'IGET vapes are premium disposable vaping devices from one of Australia\'s leading vape brands. You can buy IGET vapes online right here at IGET Vapes Original — Australia\'s #1 trusted vape shop. We stock IGET Bar Pro, IGET One, JNR Cruiser, IGET S3, Alibarbar Ingot and Alibarbar Ice Adjust with over 150 flavours available.',
  },
  {
    q: 'How long does an IGET disposable vape last?',
    a: 'The puff count varies by model. The JNR Cruiser and IGET One deliver up to 12,000 puffs, the IGET Bar Pro and IGET S3 offer up to 10,000 puffs, and the Alibarbar Ingot provides up to 9,000 puffs. For most users, a single disposable vape lasts 1–3 weeks depending on usage.',
  },
  {
    q: 'Do you deliver IGET vapes to all states in Australia?',
    a: 'Yes! We ship Australia-wide including Sydney, Melbourne, Brisbane, Perth, Adelaide, Gold Coast, Canberra, Hobart and Darwin. Whether you searched "vape shops near me" or "vape shop Perth" or "vape shop Brisbane" — we deliver directly to your door with $30 flat-rate shipping.',
  },
  {
    q: 'Are your IGET vapes and Alibarbar vapes genuine?',
    a: 'Every IGET vape and Alibarbar vape sold on our store is 100% authentic, sourced directly from authorised distributors. We guarantee genuine products — never buy from unverified vape stores. All our Alibarbar flavours, IGET Bar Pro and IGET One devices are fully quality-assured.',
  },
  {
    q: 'What Alibarbar flavours are available?',
    a: 'We carry the full Alibarbar flavours list including Strawberry Watermelon, Grape Ice, Cool Mint, Kiwi Pineapple, Skittles, Mango Magic, and many more across both the Alibarbar Ingot 9000 and Alibarbar Ice Adjust 12000 ranges. Browse our Alibarbar categories to see every flavour.',
  },
  {
    q: 'What are the best cheap vapes for sale in Australia?',
    a: 'Our IGET S3 Pod replacements start from just $30, making them some of the best cheap vapes available online in Australia. The Alibarbar Ingot 9000 at $40 and IGET Bar Pro at $48 also offer excellent value. Use our Mix & Match bundle deals to save even more on bulk vape orders.',
  },
  {
    q: 'What are your most popular IGET vape flavours?',
    a: 'Top-selling vape flavours include Strawberry Watermelon, Cherry Pomegranate, Blueberry Raspberry, Cool Mint, Grape Ice, Orange Fanta Soda, and Mango Ice. These are popular across IGET Bar Pro, IGET One, and Alibarbar ranges. Red Bull-inspired flavours are also trending.',
  },
  {
    q: 'How do I buy vapes online from your vape shop?',
    a: 'Simply browse our categories, add your favourite disposable vapes to cart, and checkout securely. We accept multiple payment methods. Your order ships same day or next business day with discreet packaging. No need to search "vape shop near me" — we deliver Australia-wide!',
  },
];

const seoTitle = "Buy IGET Vapes Online Australia | Alibarbar, IGET Bar Pro, Disposable Vapes — #1 Vape Shop";
const seoDescription = "Buy IGET vapes & Alibarbar vapes online in Australia. JNR Cruiser 12000 puffs, IGET Bar Pro, IGET One, Alibarbar flavours & more. 150+ flavours, cheap vapes, best prices. Fast Australia-wide delivery from the #1 online vape shop. Order now!";

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Buy IGET Vapes & Alibarbar Vapes Online Australia',
  itemListElement: categories.map((cat, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: cat.name,
    url: `https://igetvapesoriginal.com${cat.href}`,
  })),
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'Store',
  name: 'IGET Vapes Original',
  description: 'Australia\'s #1 online vape shop — buy IGET vapes, Alibarbar vapes, disposable vapes online with fast delivery Australia-wide.',
  url: 'https://igetvapesoriginal.com',
  areaServed: { '@type': 'Country', name: 'Australia' },
  priceRange: '$$',
  currenciesAccepted: 'AUD',
  paymentAccepted: 'Credit Card, Debit Card',
};
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
>
  <SchemaMarkup type="organization" />
  <SchemaMarkup type="website" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

  <!-- H1 — Primary SEO keywords: iget vapes, vape shop, buy vape online, disposable vapes australia -->
  <section class="mb-6">
    <h1 class="text-2xl lg:text-4xl font-extrabold leading-tight mb-2">
      Shop the Best Selection of IGET Vapes at<br class="hidden lg:block" />
      <span class="text-accent">Australia's #1 Trusted Online Vape Shop</span>
    </h1>
  </section>

  <!-- Hero Category Grid — large product carousel cards matching live site -->
  <section class="mb-10" id="hero-categories">
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
      {categories.map((cat, idx) => (
        <a
          href={cat.href}
          class:list={[
            'group relative block rounded-xl overflow-hidden border border-border hover:border-accent/50 transition-all duration-300 bg-surface',
            idx === 0 ? 'sm:col-span-2 xl:col-span-2 xl:row-span-2' : '',
          ]}
        >
          <div class="category-hero relative" data-category={cat.slug}>
            {cat.productImages.map((img, i) => (
              <img
                src={img}
                alt={`${cat.name} ${i === 0 ? '— buy online Australia' : `flavour ${i + 1}`}`}
                class:list={[
                  'cat-img w-full object-contain transition-opacity duration-700',
                  idx === 0 ? 'h-56 sm:h-72 xl:h-[26rem]' : 'h-48 sm:h-52',
                  i === 0 ? 'opacity-100 relative' : 'opacity-0 absolute inset-0',
                ]}
                loading={idx < 3 ? 'eager' : 'lazy'}
                width="400"
                height="400"
              />
            ))}
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent flex flex-col justify-end p-4">
            {cat.badge && (
              <span class="badge-new w-fit mb-2 text-[10px]">{cat.badge}</span>
            )}
            <h2 class:list={[
              'font-extrabold uppercase tracking-wide text-gray-900',
              idx === 0 ? 'text-xl lg:text-2xl' : 'text-sm lg:text-base',
            ]}>
              {cat.name}
            </h2>
            <div class="flex items-center gap-3 mt-2">
              <span class="btn-primary py-1.5 px-4 text-xs group-hover:bg-red-700 transition-colors">Shop Now</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Site intro text matching live site -->
  <section class="mb-10">
    <div class="prose max-w-none">
      <h2 class="text-xl lg:text-2xl font-bold mb-4">IGET-Vape Australia</h2>
      <p>
        Welcome to <strong>IGET Vape</strong>, the premier online destination for high-quality, innovative vapes in Australia. IGET-Vapes are known for their sleek designs, advanced technology, and top-notch flavours.
      </p>
      <p>
        At IGET Vape, we offer a wide range of IGET Vape products to meet the needs of every vaper, from beginner to advanced – Australia Wide. Our selection includes IGET Bar, IGET Bar Plus, IGET Hot, IGET Legend, and more. They come in a range of juicy flavours such as Banana Ice, Blueberry Ice, Cherry Pomegranate – and everything else you can imagine.
      </p>
      <p>
        We are committed to providing our Australian customers with the best possible shopping experience. Thank you for choosing IGET Vape – Australia for all of your vaping needs. We look forward to serving you and helping you find the perfect vape for your lifestyle.
      </p>
    </div>
  </section>

  <!-- Delivery Info — targeting location-based keywords -->
  <section class="card p-6 lg:p-8 mb-10">
    <h2 class="text-xl font-bold mb-4">Vape Delivery Across Australia</h2>
    <div class="prose max-w-none">
      <p>We deliver <strong>IGET vapes</strong> and <strong>Alibarbar vapes</strong> to every state and territory in Australia. Flat-rate shipping of <strong>$30 AUD</strong> on all orders with discreet packaging.</p>
      <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-2 mt-4 not-prose">
        {['Sydney', 'Melbourne', 'Brisbane', 'Perth', 'Adelaide', 'Gold Coast', 'Canberra', 'Hobart', 'Darwin', 'Cairns', 'Townsville', 'Newcastle'].map(city => (
          <div class="bg-primary rounded-lg px-3 py-2 text-center text-xs">
            <span class="text-gray-700">{city}</span>
          </div>
        ))}
      </div>
      <p class="mt-3 text-sm">Plus all regional areas. <a href="/delivery">View all delivery locations</a>.</p>
    </div>
  </section>

  <!-- FAQ Section — targeting long-tail search queries -->
  <section class="mb-10">
    <h2 class="text-xl font-bold mb-4">Frequently Asked Questions</h2>
    <div class="space-y-2">
      {faqs.map((faq, i) => (
        <details class="card group" id={`faq-${i}`}>
          <summary class="p-4 cursor-pointer flex items-center justify-between text-sm font-medium hover:text-accent transition-colors list-none">
            <span>{faq.q}</span>
            <svg class="w-4 h-4 text-gray-500 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-4 pb-4 text-gray-600 text-sm leading-relaxed border-t border-border pt-3">
            {faq.a}
          </div>
        </details>
      ))}
    </div>
  </section>

</BaseLayout>

<script>
  // Product image rotator for hero category cards
  document.querySelectorAll('.category-hero').forEach(hero => {
    const imgs = hero.querySelectorAll('.cat-img');
    if (imgs.length <= 1) return;
    let current = 0;
    setInterval(() => {
      imgs[current].classList.replace('opacity-100', 'opacity-0');
      imgs[current].classList.replace('relative', 'absolute');
      current = (current + 1) % imgs.length;
      imgs[current].classList.replace('opacity-0', 'opacity-100');
      imgs[current].classList.replace('absolute', 'relative');
    }, 3000);
  });
</script>
