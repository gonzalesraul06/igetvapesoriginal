---
import BaseLayout from '@layouts/BaseLayout.astro';
import SchemaMarkup from '@components/seo/SchemaMarkup.astro';
import { productCategories } from '@data/navigation';

/* ── FIXED image paths: using actual filenames on disk ── */
const categories = [
