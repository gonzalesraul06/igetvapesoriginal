    badge: 'NEW',
    description: 'Premium disposable vape with bold flavours — buy IGET vapes online Australia.',
    productImages: [
      '/images/products/jnr-cruiser/jnr-cool-mint.webp',
      '/images/products/jnr-cruiser/jnr-watermelon-ice.webp',
      '/images/products/jnr-cruiser/jnr-blueberry-raspberry-ice.webp',
      '/images/products/jnr-cruiser/jnr-cool-fanta.webp',
    ],
  },
  {
    name: 'IGET ONE 12000 PUFFS',
    slug: 'iget-one',
    href: '/products/iget-one',
    image: '/images/categories/iget-one.webp',
    price: 55,
    puffs: '12,000',
    badge: null,
    description: 'Sleek IGET One disposable vape — 12000 puffs with premium vape flavours.',
    productImages: [
      '/images/products/iget-one/one-blueberry-ice.webp',
      '/images/products/iget-one/one-strawberry-watermelon-ice.webp',
      '/images/products/iget-one/one-grape-ice.webp',
      '/images/products/iget-one/one-cherry-pomegranate.webp',
    ],
  },
  {
    name: 'IGET BAR PRO 10000 PUFFS',
    slug: 'iget-bar-pro',
    href: '/products/iget-bar-pro',
    image: '/images/categories/iget-bar-pro.webp',
    price: 48,
    puffs: '10,000',
    badge: null,
    description: "Australia's favourite IGET Bar Pro — disposable vapes with 26 incredible flavours.",
    productImages: [
      '/images/products/iget-bar-pro/pro-orange-fanta-soda.webp',
      '/images/products/iget-bar-pro/pro-kiwi-pineapple.webp',
      '/images/products/iget-bar-pro/pro-strawberry-watermelon-ice.webp',
      '/images/products/iget-bar-pro/pro-blueberry-raspberry.webp',
    ],
  },
  {
    name: 'IGET S3 10000 PUFFS',
    slug: 'iget-bar-plus-s3',
    href: '/products/iget-bar-plus-s3',
    image: '/images/categories/iget-bar-plus-s3.webp',
    price: 48,
    puffs: '10,000',
    badge: null,
    description: 'IGET Bar Plus S3 refillable pod vape system — buy online Australia.',
    productImages: [
      '/images/products/iget-bar-plus-s3/s3-kit-strawberry-watermelon-ice.webp',
      '/images/products/iget-bar-plus-s3/s3-kit-passion-fruit-kiwi-guava.webp',
      '/images/products/iget-bar-plus-s3/s3-kit-blueberry-raspberry-bubble-gum.webp',
      '/images/products/iget-bar-plus-s3/s3-kit-grape-ice.webp',
    ],
  },
  {
    name: 'S3 POD 10000 PUFFS',
    slug: 'iget-bar-plus-s3-pod',
    href: '/products/iget-bar-plus-s3-pod',
    image: '/images/categories/iget-bar-plus-s3-pod.webp',
    price: 30,
    puffs: '10,000',
    badge: null,
    description: 'Replacement pods for the IGET S3 system — cheap vapes for sale online.',
    productImages: [
      '/images/products/iget-bar-plus-s3-pod/s3-pod-strawberry-watermelon-ice.webp',
      '/images/products/iget-bar-plus-s3-pod/s3-pod-passion-fruit-kiwi-guava.webp',
      '/images/products/iget-bar-plus-s3-pod/s3-pod-blueberry-raspberry-bubble-gum.webp',
      '/images/products/iget-bar-plus-s3-pod/s3-pod-grape-ice.webp',
    ],
  },
  {
    name: 'ALIBARBAR INGOT 9000 PUFFS',
    slug: 'alibarbar-ingot',
    href: '/products/alibarbar-ingot',
    image: '/images/categories/alibarbar-ingot.webp',
    price: 40,
    puffs: '9,000',
    badge: null,
    description: 'Alibarbar Ingot 9000 — best alibarbar flavours in a compact vape design.',
    productImages: [
      '/images/products/alibarbar-ingot/alibarbar-strawberry-watermelon.webp',
      '/images/products/alibarbar-ingot/alibarbar-kiwi-pineapple.webp',
      '/images/products/alibarbar-ingot/alibarbar-grape-ice.webp',
      '/images/products/alibarbar-ingot/alibarbar-cool-mint.webp',
    ],
  },
  {
    name: 'ALIBARBAR ICE ADJUST 12000 PUFFS',
    slug: 'alibarbar-ice-adjust',
