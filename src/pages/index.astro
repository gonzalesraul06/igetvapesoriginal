    name: 'ALIBARBAR ICE ADJUST 12000 PUFFS',
    slug: 'alibarbar-ice-adjust',
    href: '/products/alibarbar-ice-adjust',
    image: '/images/categories/alibarbar-ice-adjust.webp',
    price: 50,
    puffs: '12,000',
    badge: null,
    description: 'Alibarbar Ice Adjust — adjustable ice intensity with premium alibarbar vape flavours.',
    productImages: [
      '/images/products/alibarbar-ice-adjust/alibarbar-ice-adjust-watermelon.webp',
      '/images/products/alibarbar-ice-adjust/alibarbar-ice-adjust-blueberry-blast.webp',
      '/images/products/alibarbar-ice-adjust/alibarbar-ice-adjust-mango-magic.webp',
      '/images/products/alibarbar-ice-adjust/alibarbar-ice-adjust-strawberry-kiwi.webp',
    ],
  },
];

/* ── FAQs targeting user-searched keywords ── */
const faqs = [
  {
    q: 'What is an IGET vape and where can I buy IGET vapes in Australia?',
    a: 'IGET vapes are premium disposable vaping devices from one of Australia\'s leading vape brands. You can buy IGET vapes online right here at IGET Vapes Original — Australia\'s #1 trusted vape shop. We stock IGET Bar Pro, IGET One, JNR Cruiser, IGET S3, Alibarbar Ingot and Alibarbar Ice Adjust with over 150 flavours available.',
  },
  {
    q: 'How long does an IGET disposable vape last?',
    a: 'The puff count varies by model. The JNR Cruiser and IGET One deliver up to 12,000 puffs, the IGET Bar Pro and IGET S3 offer up to 10,000 puffs, and the Alibarbar Ingot provides up to 9,000 puffs. For most users, a single disposable vape lasts 1–3 weeks depending on usage.',
  },
  {
    q: 'Do you deliver IGET vapes to all states in Australia?',
    a: 'Yes! We ship Australia-wide including Sydney, Melbourne, Brisbane, Perth, Adelaide, Gold Coast, Canberra, Hobart and Darwin. Whether you searched "vape shops near me" or "vape shop Perth" or "vape shop Brisbane" — we deliver directly to your door with state-based shipping from $10 AUD and discreet packaging.',
  },
  {
    q: 'Are your IGET vapes and Alibarbar vapes genuine?',
    a: 'Every IGET vape and Alibarbar vape sold on our store is 100% authentic, sourced directly from authorised distributors. We guarantee genuine products — never buy from unverified vape stores. All our Alibarbar flavours, IGET Bar Pro and IGET One devices are fully quality-assured.',
  },
  {
    q: 'What Alibarbar flavours are available?',
    a: 'We carry the full Alibarbar flavours list including Strawberry Watermelon, Grape Ice, Cool Mint, Kiwi Pineapple, Skittles, Mango Magic, and many more across both the Alibarbar Ingot 9000 and Alibarbar Ice Adjust 12000 ranges. Browse our Alibarbar categories to see every flavour.',
  },
  {
    q: 'What are the best cheap vapes for sale in Australia?',
    a: 'Our IGET S3 Pod replacements start from just $30, making them some of the best cheap vapes available online in Australia. The Alibarbar Ingot 9000 at $40 and IGET Bar Pro at $48 also offer excellent value. Use our Mix & Match bundle deals to save even more on bulk vape orders.',
  },
  {
    q: 'What are your most popular IGET vape flavours?',
    a: 'Top-selling vape flavours include Strawberry Watermelon, Cherry Pomegranate, Blueberry Raspberry, Cool Mint, Grape Ice, Orange Fanta Soda, and Mango Ice. These are popular across IGET Bar Pro, IGET One, and Alibarbar ranges. Red Bull-inspired flavours are also trending.',
  },
  {
    q: 'How do I buy vapes online from your vape shop?',
    a: 'Simply browse our categories, add your favourite disposable vapes to cart, and checkout securely. We accept multiple payment methods. Your order ships same day or next business day with discreet packaging. No need to search "vape shop near me" — we deliver Australia-wide!',
  },
];

const seoTitle = "Buy IGET Vapes Online Australia | Alibarbar, IGET Bar Pro, Disposable Vapes — #1 Vape Shop";
const seoDescription = "Buy IGET vapes & Alibarbar vapes online in Australia. JNR Cruiser 12000 puffs, IGET Bar Pro, IGET One, Alibarbar flavours & more. 150+ flavours, cheap vapes, best prices. Fast Australia-wide delivery from the #1 online vape shop. Order now!";

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Buy IGET Vapes & Alibarbar Vapes Online Australia',
  itemListElement: categories.map((cat, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: cat.name,
    url: `https://igetvapeshub.com${cat.href}`,
  })),
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'Store',
  name: 'IGET Vapes Original',
  alternateName: 'IGET Vapes Australia',
  description: 'Australia\'s #1 online vape shop — buy genuine IGET vapes, Alibarbar vapes & disposable vapes online with fast delivery to Sydney, Melbourne, Brisbane, Perth, Adelaide & all of Australia.',
  url: 'https://igetvapeshub.com',
  areaServed: { '@type': 'Country', name: 'Australia' },
  priceRange: '$30 - $65',
  currenciesAccepted: 'AUD',
  paymentAccepted: 'Bank Transfer, Bitcoin, PayID',
  email: 'info@igetvapeshub.com',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    bestRating: '5',
    reviewCount: '150',
  },
};
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="iget vapes, buy vapes online australia, disposable vapes australia, alibarbar, iget bar pro, iget bar, iget one, jnr cruiser, alibarbar flavours, alibarbar vape flavours, vape shop australia, cheap vapes, vape shop near me, buy vape online, online vape shop, iget vape australia, iget bar australia, disposable vapes near me"
>
  <SchemaMarkup type="organization" />
  <SchemaMarkup type="website" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

  <!-- Sale Banner (full-width image slot) -->
  <section class="mb-6 lg:mb-8">
    <a href="/mix-and-match" class="block">
      <div class="bg-surface border border-border overflow-hidden" style="border-radius: var(--radius-md);">
        <div class="flex items-center justify-center py-6 sm:py-8 lg:py-10 px-4 text-center">
          <div>
            <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold tracking-tight text-text" style="line-height: 1.15;">
              Shop IGET Vapes Online Australia
            </h1>
            <p class="mt-2 text-text-muted text-sm sm:text-base">Over 150 flavours — Fast, discreet delivery Australia-wide</p>
            <div class="mt-4 flex items-center justify-center gap-4 text-xs text-text-muted">
              <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> 100% Authentic</span>
              <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Discreet Packaging</span>
              <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Fast Delivery</span>
            </div>
          </div>
        </div>
      </div>
    </a>
  </section>

  <!-- Category Cards Grid -->
  <section class="mb-10 lg:mb-14" id="hero-categories">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 lg:gap-5">
      {categories.map((cat, idx) => (
        <a
          href={cat.href}
          class="group block bg-white border border-border text-center transition-all duration-300 hover:shadow-md overflow-hidden"
          style="border-radius: var(--radius-md);"
        >
          {/* Category title */}
          <div class="pt-5 pb-2 px-4">
            {cat.badge && (
              <span class="badge-new mb-2 mx-auto">{cat.badge}</span>
            )}
            <h2 class="text-sm sm:text-base font-bold uppercase tracking-wide text-text leading-tight">{cat.name.replace(/\d+\sPUFFS/, '').trim()}</h2>
            <p class="text-xs text-text-muted mt-1">{cat.puffs} Puffs &middot; From ${cat.price}</p>
          </div>

          {/* Product images — rotating display */}
          <div class="category-hero relative bg-white px-3 py-3" data-category={cat.slug}>
            {cat.productImages.map((img, i) => (
              <img
                src={img}
                alt={`${cat.name} ${i === 0 ? '— buy online Australia' : `flavour ${i + 1}`}`}
                class:list={[
                  'cat-img w-full object-contain h-44 sm:h-52 transition-opacity duration-700',
                  i === 0 ? 'opacity-100 relative' : 'opacity-0 absolute inset-0 px-3 py-3',
                ]}
                loading={idx < 4 ? 'eager' : 'lazy'}
                width="300"
                height="300"
              />
            ))}
          </div>

          {/* Shop Now button */}
          <div class="px-4 pb-5">
            <span class="btn-primary w-full py-2.5 text-xs group-hover:bg-gray-700">Shop Now</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Value propositions -->
  <section class="mb-10 lg:mb-14">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="bg-white border border-border p-6 text-center" style="border-radius: var(--radius-md);">
        <h3 class="text-sm font-bold mb-1">Fast Shipping</h3>
        <p class="text-xs text-text-muted">From $10 AUD. Same-day dispatch before 2pm AEST.</p>
      </div>
      <div class="bg-white border border-border p-6 text-center" style="border-radius: var(--radius-md);">
        <h3 class="text-sm font-bold mb-1">Genuine Products</h3>
        <p class="text-xs text-text-muted">Every vape authenticated from authorised distributors.</p>
      </div>
      <div class="bg-white border border-border p-6 text-center" style="border-radius: var(--radius-md);">
        <h3 class="text-sm font-bold mb-1">Best Prices</h3>
        <p class="text-xs text-text-muted">Starting from $30 AUD. Save more with Mix & Match.</p>
      </div>
    </div>
  </section>

  <!-- Mix & Match CTA -->
  <section class="mb-10 lg:mb-14">
    <a href="/mix-and-match" class="block bg-text text-white p-6 sm:p-8 group transition-all duration-300" style="border-radius: var(--radius-md);">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <h2 class="text-lg sm:text-xl font-bold">Mix & Match Any Flavours</h2>
          <p class="text-white/60 text-sm mt-1">Build your own bundle across any brand. The more you buy, the more you save.</p>
        </div>
        <span class="btn-secondary py-3 px-6 text-sm flex-shrink-0 group-hover:bg-white group-hover:text-text">
          Build Your Bundle &rarr;
        </span>
      </div>
    </a>
  </section>

  <!-- Site intro text -->
  <section class="mb-10 lg:mb-14">
    <div class="prose max-w-none">
      <h2>IGET-Vape Australia</h2>
      <p>
        Welcome to <strong>IGET Vape</strong>, the premier online destination for high-quality, innovative vapes in Australia. IGET-Vapes are known for their sleek designs, advanced technology, and top-notch flavours.
      </p>
      <p>
        At IGET Vape, we offer a wide range of IGET Vape products to meet the needs of every vaper, from beginner to advanced &mdash; Australia Wide. Our selection includes IGET Bar, IGET Bar Plus, IGET Hot, IGET Legend, and more. They come in a range of juicy flavours such as Banana Ice, Blueberry Ice, Cherry Pomegranate &mdash; and everything else you can imagine.
      </p>
      <p>
        We are committed to providing our Australian customers with the best possible shopping experience. Thank you for choosing IGET Vape &mdash; Australia for all of your vaping needs. We look forward to serving you and helping you find the perfect vape for your lifestyle.
      </p>
    </div>
  </section>

  <!-- Delivery Info -->
  <section class="mb-10 lg:mb-14 bg-surface p-6 sm:p-8 border border-border" style="border-radius: var(--radius-md);">
    <h2 class="text-xl sm:text-2xl font-bold mb-4">Vape Delivery Across Australia</h2>
    <div class="prose max-w-none">
      <p>We deliver <strong>IGET vapes</strong> and <strong>Alibarbar vapes</strong> to every state and territory in Australia. Shipping from <strong>$10 AUD</strong>, calculated by state, with discreet packaging.</p>
      <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-2.5 mt-4 not-prose">
        {['Sydney', 'Melbourne', 'Brisbane', 'Perth', 'Adelaide', 'Gold Coast', 'Canberra', 'Hobart', 'Darwin', 'Cairns', 'Townsville', 'Newcastle'].map(city => (
          <div class="bg-white px-3 py-2.5 text-center text-xs border border-border" style="border-radius: var(--radius-sm);">
            <span class="text-text font-medium">{city}</span>
          </div>
        ))}
      </div>
      <p class="mt-4 text-sm">Plus all regional areas. <a href="/delivery">View all delivery locations</a>.</p>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="mb-10 lg:mb-14">
    <h2 class="text-xl sm:text-2xl font-bold mb-5">Frequently Asked Questions</h2>
    <div class="space-y-2">
      {faqs.map((faq, i) => (
        <details class="group bg-white border border-border" id={`faq-${i}`} style="border-radius: var(--radius-md);">
          <summary class="p-4 lg:p-5 cursor-pointer flex items-center justify-between text-sm font-semibold text-text hover:text-accent transition-colors duration-200 list-none">
            <span class="pr-6">{faq.q}</span>
            <svg class="w-4 h-4 text-text-muted group-open:rotate-180 transition-transform duration-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-4 pb-4 lg:px-5 lg:pb-5 text-text-muted text-sm border-t border-border pt-3" style="line-height: 1.7;">
            {faq.a}
          </div>
        </details>
      ))}
    </div>
  </section>

</BaseLayout>

<script>
  // Product image rotator for hero category cards
  document.querySelectorAll('.category-hero').forEach(hero => {
    const imgs = hero.querySelectorAll('.cat-img');
    if (imgs.length <= 1) return;
    let current = 0;
    setInterval(() => {
      imgs[current].classList.replace('opacity-100', 'opacity-0');
      imgs[current].classList.replace('relative', 'absolute');
      current = (current + 1) % imgs.length;
      imgs[current].classList.replace('opacity-0', 'opacity-100');
      imgs[current].classList.replace('absolute', 'relative');
    }, 3000);
  });
</script>
