const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Buy IGET Vapes & Alibarbar Vapes Online Australia',
  itemListElement: categories.map((cat, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: cat.name,
    url: `https://igetvapeshub.com${cat.href}`,
  })),
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'Store',
  name: 'IGET Vapes Original',
  alternateName: 'IGET Vapes Australia',
  description: 'Australia\'s #1 online vape shop — buy genuine IGET vapes, Alibarbar vapes & disposable vapes online with fast delivery to Sydney, Melbourne, Brisbane, Perth, Adelaide & all of Australia.',
  url: 'https://igetvapeshub.com',
  areaServed: { '@type': 'Country', name: 'Australia' },
  priceRange: '$30 - $65',
  currenciesAccepted: 'AUD',
  paymentAccepted: 'Bank Transfer, Bitcoin, PayID',
  email: 'info@igetvapeshub.com',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    bestRating: '5',
    reviewCount: '150',
  },
};
