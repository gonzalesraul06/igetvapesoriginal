          <h3 class="text-sm font-semibold">{cat.name}</h3>
          <span class="text-accent text-xs mt-1">From ${cat.price}</span>
        </a>
      ))}
      <a href="/mix-and-match" class="card group p-4 flex flex-col items-center justify-center text-center hover:border-accent border border-transparent transition-colors">
        <div class="w-16 h-16 rounded-full bg-accent/20 flex items-center justify-center mb-3 group-hover:bg-accent/30 transition-colors">
          <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
        </div>
        <h3 class="text-sm font-semibold">MIX & MATCH</h3>
