const faqs = [
  {
    q: 'Are the devices on this store genuine?',
    a: 'Yes. The store positions authenticity as a first-order promise. Product lines are sourced from authorised supply and presented with a clear adult-only retail layer rather than grey-market marketplace clutter.',
  },
  {
    q: 'Which range is best if I want the longest use between orders?',
    a: 'JNR Cruiser and IGET One both sit in the high-puff, rechargeable end of the catalogue. They are the best place to start if you want longer use and fewer repeat orders.',
  },
  {
    q: 'What is the best value option on the site?',
    a: 'For long-term value, the IGET S3 ecosystem is the strongest choice. Buy the rechargeable kit once, then rotate through lower-cost replacement pods when you need new flavour.',
  },
  {
    q: 'Do you deliver across Australia?',
    a: 'Yes. The store is set up for Australia-wide delivery with discreet packaging, clear state-based shipping rules, and manual payment confirmation after checkout.',
  },
  {
    q: 'Is there a minimum order?',
    a: `Yes. The cart and checkout enforce a $${MINIMUM_ORDER} AUD minimum order so adults know the purchasing threshold before finalising payment instructions.`,
  },
  {
    q: 'How should I choose between IGET and Alibarbar?',
    a: 'IGET is positioned as the broader, more system-led family with strong everyday and refillable options. Alibarbar sits as the more flavour-forward alternative, especially if you want compact value or adjustable ice intensity.',
  },
];

const seoTitle = 'IGET and Alibarbar Vapes | Buy Online Australia';
const seoDescription = 'Shop genuine IGET and Alibarbar vapes online in Australia. Compare bestselling devices, S3 pods, mix and match bundles, and fast delivery options.';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.a,
    },
  })),
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'IGET and Alibarbar collections',
  itemListElement: categories.map((category, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: category.name,
    url: `https://igetvapeshub.com${category.href}`,
  })),
};

---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="iget vapes australia, alibarbar australia, buy vape online australia, premium vape retail australia"
>
  <SchemaMarkup type="organization" />
  <SchemaMarkup type="website" />
  <SchemaMarkup type="localbusiness" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <HomeExperience categories={categories} faqs={faqs} />
</BaseLayout>
