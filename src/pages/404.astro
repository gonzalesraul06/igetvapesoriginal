---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — IGET Vapes Australia" noindex={true}>
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <div class="text-[8rem] font-black text-accent/15 mb-2 leading-none select-none">404</div>
    <h1 class="text-2xl lg:text-3xl font-extrabold mb-3 tracking-tight">Page Not Found</h1>
    <p class="text-text-muted mb-8 max-w-md text-sm">The page you're looking for doesn't exist or has been moved.</p>
    <div class="flex items-center gap-3">
      <a href="/" class="btn-primary px-8 py-3 rounded-xl">Back to Home</a>
      <a href="/contact" class="btn-secondary px-6 py-3 rounded-xl">Contact Us</a>
    </div>
  </div>
</BaseLayout>
