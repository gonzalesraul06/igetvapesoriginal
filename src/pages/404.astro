---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — IGET Vapes Australia" noindex={true}>
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <div class="text-7xl font-black text-accent/20 mb-4">404</div>
    <h1 class="text-3xl lg:text-4xl font-extrabold mb-3 tracking-tight">Page Not Found</h1>
    <p class="text-text-muted mb-8 max-w-md text-base">Sorry, the page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="btn-primary px-8 py-3.5 rounded-xl text-base">Back to Home</a>
  </div>
</BaseLayout>
